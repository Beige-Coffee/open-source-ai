---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ChatBubble from "../components/ChatBubble.tsx";

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const { title, description, bodyClass } = Astro.props;
const fullTitle =
  title === "The Open-Source AI Stack"
    ? title
    : `${title} · The Open-Source AI Stack`;
const desc =
  description ||
  "A living map of the open-source AI stack: silicon, compute, data, training, weights, runtime, retrieval, agents, protocols. Updated daily.";

// COURSE.md decision #12: the floating ChatBubble does not appear on
// /learn routes; those pages use the dedicated CoursePanel instead.
const isCourseRoute = Astro.url.pathname.startsWith("/learn");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
      crossorigin
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Serif:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="The Open-Source AI Stack: Daily News"
      href="/rss/news.xml"
    />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class={bodyClass}>
    {/* Synchronously restore body[data-chat-open] + --chat-width before
        the first paint. Without this, the page renders full-width on
        navigation and React's hydration then snaps it inward, which
        reads as a layout glitch when the chat is open. Keeps the
        transition for genuine open/close after hydration. */}
    <script is:inline>
      {`
        try {
          var raw = localStorage.getItem("oss-ai-chat-threads-v2");
          var parsed = raw ? JSON.parse(raw) : null;
          var open = parsed && parsed.state && parsed.state.open;
          var w = Number(localStorage.getItem("oss-ai-chat-width"));
          if (!Number.isFinite(w) || w < 320) w = 480;
          if (open) {
            document.body.dataset.chatOpen = "true";
            document.body.style.setProperty("--chat-width", w + "px");
          }
        } catch (e) { /* localStorage unavailable, leave default layout */ }
      `}
    </script>
    <Nav />
    <main class="min-h-[60vh]">
      <slot />
    </main>
    <Footer />
    {!isCourseRoute && <ChatBubble client:only="react" />}
    <script>
      import "../lib/glossary-runtime";
    </script>
  </body>
</html>
