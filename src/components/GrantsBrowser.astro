---
import {
  loadFunders,
  loadGrants,
  amountBucket,
  recencyBucket,
  grantSlug,
} from "../lib/grants";
import { loadLayers } from "../lib/layers";

const grants = loadGrants();
const funders = loadFunders();
const layers = loadLayers();
const allLayers = [...layers.core, ...layers.meta];

const findFunder = (slug: string) => funders.find((f) => f.slug === slug);
const findLayer = (slug: string) => allLayers.find((l) => l.slug === slug);

// Build filter facets in the order they should render in the sidebar.
const funderFacets = [...funders]
  .filter((f) => grants.some((g) => g.funder === f.slug))
  .sort((a, b) => a.name.localeCompare(b.name));

const layerFacets = allLayers.filter((l) =>
  grants.some((g) => g.layers.includes(l.slug)),
);

const amountFacets = [
  { key: ">10M", label: "More than $10M" },
  { key: "1M-10M", label: "$1M to $10M" },
  { key: "100K-1M", label: "$100K to $1M" },
  { key: "<100K", label: "Less than $100K" },
  { key: "undisclosed", label: "Undisclosed" },
];

const regionFacets = [
  { key: "US", label: "United States" },
  { key: "EU", label: "European Union" },
  { key: "UK", label: "United Kingdom" },
  { key: "Global", label: "Global / multi-region" },
  { key: "Asia", label: "Asia" },
  { key: "Africa", label: "Africa" },
  { key: "LatAm", label: "Latin America" },
];

const recencyFacets = [
  { key: "30d", label: "Last 30 days" },
  { key: "90d", label: "Last 90 days" },
  { key: "1y", label: "Last 12 months" },
  { key: "older", label: "Older than 12 months" },
];

const today = new Date();

// Pre-compute attributes for each grant for the data-* tags.
const grantsWithMeta = grants.map((g) => ({
  ...g,
  amount_bucket: amountBucket(g.amount_usd),
  recency_bucket: recencyBucket(g.date, today),
  funder_obj: findFunder(g.funder),
}));

// Counts for the tab toggle labels.
const projectCount = grantsWithMeta.filter((g) => g.kind === "project").length;
const programCount = grantsWithMeta.filter((g) => g.kind === "program").length;
---

<section class="max-w-6xl mx-auto px-6 my-16" id="grants-browser">
  <h2 class="font-serif text-2xl mb-2">All grants</h2>
  <p class="text-sm text-[var(--color-text-muted)] mb-4 max-w-prose">
    Two kinds: specific projects that received money, and cohorts /
    programs you could apply to or model your own funding after. Toggle
    between them; filters apply within each.
  </p>

  <!-- Tab toggle: only one section visible at a time, default projects. -->
  <div
    role="tablist"
    aria-label="Grant kind"
    class="flex gap-2 mb-6 border-b border-[var(--color-border)]"
  >
    <button
      type="button"
      role="tab"
      data-grants-tab="project"
      aria-selected="true"
      class="px-4 py-2 -mb-px border-b-2 border-[var(--color-accent)] font-medium text-sm text-[var(--color-accent)] bg-transparent cursor-pointer"
    >
      Projects funded
      <span class="font-mono text-xs text-[var(--color-text-subtle)] ml-1">
        ({projectCount})
      </span>
    </button>
    <button
      type="button"
      role="tab"
      data-grants-tab="program"
      aria-selected="false"
      class="px-4 py-2 -mb-px border-b-2 border-transparent font-medium text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] bg-transparent cursor-pointer"
    >
      Cohorts &amp; programs
      <span class="font-mono text-xs text-[var(--color-text-subtle)] ml-1">
        ({programCount})
      </span>
    </button>
  </div>

  <div class="grid gap-6 md:grid-cols-[240px_1fr] items-start">
    <!-- Sticky filter sidebar -->
    <aside
      class="md:sticky md:top-20 md:self-start border border-[var(--color-border)] rounded-md bg-[var(--color-surface)] p-4 text-sm"
    >
      <div class="flex items-baseline justify-between mb-3">
        <h3
          class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)]"
        >
          Filters
        </h3>
        <button
          type="button"
          data-grants-clear-all
          class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-accent)] hover:underline bg-transparent border-0 cursor-pointer p-0"
        >
          Clear all
        </button>
      </div>

      <details open class="mb-3">
        <summary
          class="cursor-pointer font-medium text-[var(--color-text)] mb-2 list-none select-none flex items-center justify-between"
        >
          <span>Funder</span>
          <span class="font-mono text-xs text-[var(--color-text-subtle)]"
            >({funderFacets.length})</span
          >
        </summary>
        <ul class="space-y-1 max-h-48 overflow-y-auto pr-1">
          {
            funderFacets.map((f) => (
              <li>
                <label class="flex items-center gap-2 cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)]">
                  <input
                    type="checkbox"
                    data-grants-filter="funder"
                    value={f.slug}
                    class="accent-[var(--color-accent)]"
                  />
                  <span class="text-xs leading-snug">{f.name}</span>
                </label>
              </li>
            ))
          }
        </ul>
      </details>

      <details open class="mb-3">
        <summary
          class="cursor-pointer font-medium text-[var(--color-text)] mb-2 list-none select-none flex items-center justify-between"
        >
          <span>Layer</span>
          <span class="font-mono text-xs text-[var(--color-text-subtle)]"
            >({layerFacets.length})</span
          >
        </summary>
        <ul class="space-y-1 max-h-48 overflow-y-auto pr-1">
          {
            layerFacets.map((l) => (
              <li data-layer-hover={l.slug}>
                <label
                  class="flex items-center gap-2 cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)]"
                >
                  <input
                    type="checkbox"
                    data-grants-filter="layer"
                    value={l.slug}
                    class="accent-[var(--color-accent)]"
                  />
                  <span class="text-xs leading-snug">{l.title}</span>
                </label>
              </li>
            ))
          }
        </ul>
      </details>

      <details open class="mb-3">
        <summary
          class="cursor-pointer font-medium text-[var(--color-text)] mb-2 list-none select-none"
        >
          Amount
        </summary>
        <ul class="space-y-1">
          {
            amountFacets.map((a) => (
              <li>
                <label class="flex items-center gap-2 cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)]">
                  <input
                    type="checkbox"
                    data-grants-filter="amount"
                    value={a.key}
                    class="accent-[var(--color-accent)]"
                  />
                  <span class="text-xs leading-snug">{a.label}</span>
                </label>
              </li>
            ))
          }
        </ul>
      </details>

      <details class="mb-3">
        <summary
          class="cursor-pointer font-medium text-[var(--color-text)] mb-2 list-none select-none"
        >
          Region
        </summary>
        <ul class="space-y-1">
          {
            regionFacets.map((r) => (
              <li>
                <label class="flex items-center gap-2 cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)]">
                  <input
                    type="checkbox"
                    data-grants-filter="region"
                    value={r.key}
                    class="accent-[var(--color-accent)]"
                  />
                  <span class="text-xs leading-snug">{r.label}</span>
                </label>
              </li>
            ))
          }
        </ul>
      </details>

      <details>
        <summary
          class="cursor-pointer font-medium text-[var(--color-text)] mb-2 list-none select-none"
        >
          Recency
        </summary>
        <ul class="space-y-1">
          {
            recencyFacets.map((r) => (
              <li>
                <label class="flex items-center gap-2 cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)]">
                  <input
                    type="checkbox"
                    data-grants-filter="recency"
                    value={r.key}
                    class="accent-[var(--color-accent)]"
                  />
                  <span class="text-xs leading-snug">{r.label}</span>
                </label>
              </li>
            ))
          }
        </ul>
      </details>
    </aside>

    <!-- Results column. overflow-anchor:none stops the browser from
         snapping the scroll position when the visible-grants set
         shrinks. style="overflow-anchor: none" is inlined because
         Tailwind v4 has no utility for this. -->
    <div style="overflow-anchor: none;">
      <!-- Filter search box. Typing surfaces matching values across
           every filter category (funder, layer, region, amount,
           recency) plus free-text keyword. Selecting a suggestion
           adds it to the active filters; the list does not filter
           until a suggestion is chosen. -->
      <div class="mb-3 relative">
        <label class="sr-only" for="grants-search">Search filters</label>
        <div class="relative">
          <input
            id="grants-search"
            type="search"
            data-grants-search
            role="combobox"
            aria-controls="grants-typeahead"
            aria-expanded="false"
            aria-autocomplete="list"
            placeholder="Type a funder, layer, region, or keyword..."
            class="w-full pl-8 pr-3 py-2 text-sm rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] focus:outline-none focus:border-[var(--color-accent)] placeholder:text-[var(--color-text-subtle)]"
            autocomplete="off"
          />
          <svg
            aria-hidden="true"
            class="absolute left-2.5 top-2.5 w-4 h-4 text-[var(--color-text-subtle)]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </div>
        <ul
          id="grants-typeahead"
          data-grants-typeahead
          role="listbox"
          class="hidden absolute z-30 left-0 right-0 mt-1 max-h-80 overflow-y-auto rounded-md border border-[var(--color-border-strong)] bg-[var(--color-surface)] shadow-lg text-sm"
        ></ul>
      </div>

      <!-- Active filter chips + count -->
      <div
        class="flex flex-wrap items-baseline gap-3 mb-4 pb-3 border-b border-[var(--color-border)]"
      >
        <p class="font-mono text-sm text-[var(--color-text-muted)]">
          <span data-grants-visible-count class="font-semibold text-[var(--color-text)]">{projectCount}</span>
          <span data-grants-count-label>grants</span>
          <span data-grants-count-suffix class="text-[var(--color-text-subtle)] hidden">
            · <span data-grants-total-count>{projectCount}</span> total
          </span>
        </p>
        <div
          data-grants-active-chips
          class="flex flex-wrap gap-1.5 flex-1 min-w-0"
        >
          <!-- Chips inserted by client script -->
        </div>
      </div>

      <!-- Empty state -->
      <p
        data-grants-empty-state
        class="hidden italic text-[var(--color-text-subtle)] py-8 text-center"
      >
        No grants match the current filters.
      </p>

      <!-- Grants list -->
      <ul class="space-y-4" data-grants-list>
        {
          grantsWithMeta.map((g) => (
            <li
              class="relative border border-[var(--color-border)] rounded-md p-4 bg-[var(--color-surface)] hover:border-[var(--color-border-strong)] hover:bg-[var(--color-surface-warm)] transition-colors"
              data-grant
              data-kind={g.kind}
              data-funder={g.funder}
              data-layers={g.layers.join(",")}
              data-search={`${g.title} ${g.recipient} ${g.description}`.toLowerCase()}
              data-amount={g.amount_bucket}
              data-region={g.region}
              data-recency={g.recency_bucket}
            >
              <div class="flex flex-wrap items-baseline justify-between gap-3 mb-2">
                {/* Card-link overlay: the title link's ::before
                    extends to fill the entire <li>, so clicking
                    anywhere on the card navigates to the grant page.
                    Nested funder + layer links escape the overlay via
                    relative z-10. */}
                <a
                  href={`/grants/${grantSlug(g.title)}`}
                  class="font-medium text-[var(--color-text)] hover:text-[var(--color-accent)] no-underline hover:no-underline text-base before:absolute before:inset-0 before:content-[''] before:rounded-md"
                >
                  {g.title}
                </a>
                <span class="font-mono text-xs text-[var(--color-text-subtle)] relative z-10">
                  {g.date} &middot; {g.amount_label}
                </span>
              </div>
              <p class="text-sm text-[var(--color-text-muted)] mb-2">
                {g.recipient}
                {g.funder_obj && (
                  <>
                    {" "}
                    &middot; funded by{" "}
                    <a
                      href={`/grants/funder/${g.funder_obj.slug}`}
                      class="no-underline hover:underline relative z-10"
                    >
                      {g.funder_obj.name}
                    </a>
                  </>
                )}
                <span class="text-[var(--color-text-subtle)]">
                  {" "}
                  &middot; {g.region}
                </span>
              </p>
              <p class="text-sm text-[var(--color-text)] mb-3">
                {g.description}
              </p>
              <div class="flex flex-wrap gap-1.5 relative z-10">
                {g.layers.map((slug) => {
                  const layer = findLayer(slug);
                  if (!layer) return null;
                  return (
                    <a
                      href={`/stack/${layer.slug}`}
                      class="font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 border border-[var(--color-border)] rounded no-underline hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] text-[var(--color-text-muted)] bg-[var(--color-surface)]"
                    >
                      {layer.title}
                    </a>
                  );
                })}
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<script is:inline>
  // Client-side filter logic for the grants browser.
  // Reads checkbox state, hides non-matching <li data-grant> entries,
  // updates the visible count, manages active-filter chips.
  (function () {
    const root = document.getElementById("grants-browser");
    if (!root) return;

    const grantNodes = Array.from(root.querySelectorAll("[data-grant]"));
    const checkboxes = Array.from(
      root.querySelectorAll("[data-grants-filter]"),
    );
    const tabButtons = Array.from(root.querySelectorAll("[data-grants-tab]"));
    const searchInput = root.querySelector("[data-grants-search]");
    const typeaheadEl = root.querySelector("[data-grants-typeahead]");
    const visibleCountEl = root.querySelector("[data-grants-visible-count]");
    const totalCountEl = root.querySelector("[data-grants-total-count]");
    const countLabelEl = root.querySelector("[data-grants-count-label]");
    const countSuffixEl = root.querySelector("[data-grants-count-suffix]");
    const chipsEl = root.querySelector("[data-grants-active-chips]");
    const emptyEl = root.querySelector("[data-grants-empty-state]");
    const clearAllBtn = root.querySelector("[data-grants-clear-all]");

    // Active tab: "project" (default) or "program".
    let activeKind = "project";
    let searchQuery = "";

    // ------------------------------------------------------------------
    // Typeahead index: harvest each checkbox's category, value, and the
    // displayed label so a single text query can surface matches across
    // every filter sidebar group. Built once at startup and re-used.
    // ------------------------------------------------------------------
    const CATEGORY_LABELS = {
      funder: "Funder",
      layer: "Layer",
      amount: "Amount",
      region: "Region",
      recency: "When",
    };
    const typeaheadIndex = checkboxes.map((cb) => {
      const labelSpan =
        cb.parentElement && cb.parentElement.querySelector("span");
      const label = labelSpan ? labelSpan.textContent.trim() : cb.value;
      return {
        kind: "filter",
        category: cb.dataset.grantsFilter,
        value: cb.value,
        label,
        haystack: label.toLowerCase() + " " + cb.value.toLowerCase(),
      };
    });
    let typeaheadCursor = -1;
    let lastMatches = [];

    const labelFor = (key, value) => {
      const el = root.querySelector(
        `input[data-grants-filter="${key}"][value="${value}"]`,
      );
      if (!el) return value;
      const span = el.parentElement && el.parentElement.querySelector("span");
      return span ? span.textContent.trim() : value;
    };

    function readState() {
      const state = { funder: [], layer: [], amount: [], region: [], recency: [] };
      for (const cb of checkboxes) {
        if (cb.checked) {
          state[cb.dataset.grantsFilter].push(cb.value);
        }
      }
      return state;
    }

    function matchesGrant(node, state) {
      // Active tab gates everything: only show grants of the current kind.
      if (node.dataset.kind !== activeKind) return false;
      if (state.funder.length && !state.funder.includes(node.dataset.funder))
        return false;
      if (state.amount.length && !state.amount.includes(node.dataset.amount))
        return false;
      if (state.region.length && !state.region.includes(node.dataset.region))
        return false;
      if (state.recency.length && !state.recency.includes(node.dataset.recency))
        return false;
      if (state.layer.length) {
        const grantLayers = (node.dataset.layers || "")
          .split(",")
          .map((s) => s.trim())
          .filter(Boolean);
        const overlap = state.layer.some((l) => grantLayers.includes(l));
        if (!overlap) return false;
      }
      if (searchQuery) {
        const blob = node.dataset.search || "";
        if (!blob.includes(searchQuery)) return false;
      }
      return true;
    }

    function renderChips(state) {
      if (!chipsEl) return;
      chipsEl.innerHTML = "";
      const allSelected = [];
      for (const key of ["funder", "layer", "amount", "region", "recency"]) {
        for (const value of state[key]) {
          allSelected.push({ key, value });
        }
      }
      for (const { key, value } of allSelected) {
        const chip = document.createElement("button");
        chip.type = "button";
        chip.className =
          "font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 rounded border border-[var(--color-accent)] text-[var(--color-accent)] bg-[var(--color-accent-soft)] hover:bg-white cursor-pointer";
        chip.textContent = labelFor(key, value) + " ×";
        chip.addEventListener("click", () => {
          const cb = root.querySelector(
            `input[data-grants-filter="${key}"][value="${value}"]`,
          );
          if (cb) {
            cb.checked = false;
            apply();
          }
        });
        chipsEl.appendChild(chip);
      }
      if (searchQuery) {
        const kwChip = document.createElement("button");
        kwChip.type = "button";
        kwChip.className =
          "font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 rounded border border-[var(--color-accent)] text-[var(--color-accent)] bg-[var(--color-accent-soft)] hover:bg-white cursor-pointer";
        kwChip.textContent = '"' + searchQuery + '" ×';
        kwChip.addEventListener("click", () => {
          searchQuery = "";
          apply();
        });
        chipsEl.appendChild(kwChip);
      }
    }

    function apply() {
      // Anchor the user's view to the top of the grants browser to
      // prevent the browser from snapping their scroll position when
      // the page height shrinks. Save the offset from the section top
      // before mutating, then restore it after.
      const sectionTop = root.getBoundingClientRect().top + window.scrollY;
      const userOffset = window.scrollY - sectionTop;

      const state = readState();
      let visible = 0;
      let totalForKind = 0;
      for (const node of grantNodes) {
        if (node.dataset.kind === activeKind) totalForKind++;
        const ok = matchesGrant(node, state);
        node.style.display = ok ? "" : "none";
        if (ok) visible++;
      }
      if (visibleCountEl) visibleCountEl.textContent = String(visible);
      if (totalCountEl) totalCountEl.textContent = String(totalForKind);
      if (countLabelEl) {
        const kindLabel = activeKind === "project" ? "grants" : "programs";
        const filtered = visible !== totalForKind;
        countLabelEl.textContent = filtered ? `matching ${kindLabel}` : kindLabel;
      }
      if (countSuffixEl) {
        countSuffixEl.classList.toggle("hidden", visible === totalForKind);
      }
      if (emptyEl) emptyEl.classList.toggle("hidden", visible !== 0);
      renderChips(state);

      // Restore the user's relative position. If they were below the
      // section before filtering, keep them at the same offset; if
      // their offset is now past the new section bottom, clamp to top.
      if (userOffset > 0) {
        const newSectionTop = root.getBoundingClientRect().top + window.scrollY;
        const newSectionHeight = root.offsetHeight;
        const maxOffset = Math.max(0, newSectionHeight - window.innerHeight);
        const targetOffset = Math.min(userOffset, maxOffset);
        window.scrollTo({ top: newSectionTop + targetOffset, behavior: "instant" });
      }
    }

    // ------------------------------------------------------------------
    // Typeahead: as user types, surface matching filter values across
    // every category plus a free-text fallback. Selecting a category
    // suggestion checks the matching sidebar checkbox; selecting the
    // free-text suggestion applies a keyword filter across grant
    // title/recipient/description.
    // ------------------------------------------------------------------
    function buildMatches(rawQuery) {
      const q = rawQuery.trim().toLowerCase();
      if (q.length < 1) return [];
      const filterMatches = typeaheadIndex
        .filter((entry) => entry.haystack.includes(q))
        .slice(0, 8);
      // Always offer a keyword option so the user can fall back to
      // full-text search across grant body when no filter category
      // covers their query.
      const keyword = { kind: "keyword", value: q, label: rawQuery.trim() };
      return [...filterMatches, keyword];
    }

    function hideTypeahead() {
      if (!typeaheadEl) return;
      typeaheadEl.classList.add("hidden");
      typeaheadEl.innerHTML = "";
      if (searchInput) searchInput.setAttribute("aria-expanded", "false");
      typeaheadCursor = -1;
      lastMatches = [];
    }

    function renderTypeahead(matches) {
      if (!typeaheadEl) return;
      if (matches.length === 0) {
        hideTypeahead();
        return;
      }
      typeaheadEl.innerHTML = "";
      matches.forEach((m, i) => {
        const li = document.createElement("li");
        li.setAttribute("role", "option");
        li.dataset.idx = String(i);
        const isCursor = i === typeaheadCursor;
        li.className =
          "flex items-baseline justify-between gap-3 px-3 py-2 cursor-pointer hover:bg-[var(--color-surface-warm)] border-b border-[var(--color-border)] last:border-b-0 " +
          (isCursor ? "bg-[var(--color-surface-warm)]" : "");
        const tag =
          m.kind === "filter" ? CATEGORY_LABELS[m.category] || m.category : "Keyword";
        const detail = m.kind === "keyword" ? "" : m.value;
        li.innerHTML =
          '<span class="text-[var(--color-text)] truncate">' +
          escapeHtml(m.label) +
          (m.kind === "keyword"
            ? ' <span class="text-[var(--color-text-subtle)] italic">(search grant text)</span>'
            : '') +
          "</span>" +
          '<span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-subtle)] shrink-0">' +
          escapeHtml(tag) +
          (detail ? " · " + escapeHtml(detail) : "") +
          "</span>";
        li.addEventListener("mousedown", (ev) => {
          ev.preventDefault();
          selectMatch(i);
        });
        typeaheadEl.appendChild(li);
      });
      typeaheadEl.classList.remove("hidden");
      if (searchInput) searchInput.setAttribute("aria-expanded", "true");
    }

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function selectMatch(idx) {
      const m = lastMatches[idx];
      if (!m) return;
      if (m.kind === "filter") {
        const cb = root.querySelector(
          'input[data-grants-filter="' +
            m.category +
            '"][value="' +
            (window.CSS && window.CSS.escape ? window.CSS.escape(m.value) : m.value) +
            '"]',
        );
        if (cb) {
          cb.checked = true;
          // Manually call apply rather than dispatching a synthetic
          // change event: that avoids re-binding the typeahead and
          // keeps the focus on the input for fast successive picks.
          apply();
        }
      } else {
        searchQuery = m.value;
        apply();
      }
      if (searchInput) searchInput.value = "";
      hideTypeahead();
    }

    function onSearchInput(e) {
      const value = e.target.value || "";
      lastMatches = buildMatches(value);
      typeaheadCursor = lastMatches.length > 0 ? 0 : -1;
      renderTypeahead(lastMatches);
    }

    function onSearchKeyDown(e) {
      if (lastMatches.length === 0) return;
      if (e.key === "ArrowDown") {
        e.preventDefault();
        typeaheadCursor = (typeaheadCursor + 1) % lastMatches.length;
        renderTypeahead(lastMatches);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        typeaheadCursor =
          (typeaheadCursor - 1 + lastMatches.length) % lastMatches.length;
        renderTypeahead(lastMatches);
      } else if (e.key === "Enter") {
        e.preventDefault();
        if (typeaheadCursor >= 0) selectMatch(typeaheadCursor);
      } else if (e.key === "Escape") {
        hideTypeahead();
      }
    }

    // Close the dropdown on click outside.
    document.addEventListener("mousedown", (ev) => {
      if (!typeaheadEl) return;
      if (typeaheadEl.classList.contains("hidden")) return;
      const target = ev.target;
      if (
        target instanceof Node &&
        !typeaheadEl.contains(target) &&
        target !== searchInput
      ) {
        hideTypeahead();
      }
    });

    function setActiveTab(kind) {
      activeKind = kind;
      for (const btn of tabButtons) {
        const isActive = btn.dataset.grantsTab === kind;
        btn.setAttribute("aria-selected", isActive ? "true" : "false");
        if (isActive) {
          btn.classList.add("border-[var(--color-accent)]", "text-[var(--color-accent)]");
          btn.classList.remove("border-transparent", "text-[var(--color-text-muted)]");
        } else {
          btn.classList.remove("border-[var(--color-accent)]", "text-[var(--color-accent)]");
          btn.classList.add("border-transparent", "text-[var(--color-text-muted)]");
        }
      }
      apply();
    }

    for (const cb of checkboxes) {
      cb.addEventListener("change", apply);
    }
    for (const btn of tabButtons) {
      btn.addEventListener("click", () => setActiveTab(btn.dataset.grantsTab));
    }
    if (searchInput) {
      searchInput.addEventListener("input", onSearchInput);
      searchInput.addEventListener("keydown", onSearchKeyDown);
      searchInput.addEventListener("focus", (e) => {
        if ((e.target.value || "").length > 0) {
          lastMatches = buildMatches(e.target.value);
          typeaheadCursor = lastMatches.length > 0 ? 0 : -1;
          renderTypeahead(lastMatches);
        }
      });
    }
    if (clearAllBtn) {
      clearAllBtn.addEventListener("click", () => {
        for (const cb of checkboxes) cb.checked = false;
        if (searchInput) searchInput.value = "";
        searchQuery = "";
        hideTypeahead();
        apply();
      });
    }

    // Initial render: project tab active by default.
    apply();
  })();
</script>
