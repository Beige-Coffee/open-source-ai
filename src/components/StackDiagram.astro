---
import { loadLayers } from "../lib/layers";

const layers = loadLayers();
// Reverse core order so silicon (layer 1, the foundation) renders at the
// bottom and protocols (layer 9, the surface) renders at the top. Reads
// as a physical stack: foundation below, user-facing layer above.
const coreStackedTopDown = [...layers.core].sort((a, b) => b.order - a.order);
const meta = layers.meta;

// Visual stacking cues: layers shaded from light at the top (surface)
// to slightly warmer / heavier at the bottom (foundation). Each layer
// is a brick; the higher it sits, the closer to the user.
const total = coreStackedTopDown.length;
function bgForIndex(index: number): string {
  // index 0 is the top of the stack (surface); index N-1 is the foundation
  // (silicon). Subtle gradient using HSL.
  const lightness = 100 - index * 1.8; // ~98% at top, ~83% at bottom
  return `hsl(35, 38%, ${lightness}%)`;
}
---

<section aria-label="The Open-Source AI Stack diagram" class="my-12">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid gap-6 md:grid-cols-[1fr_240px] items-start">
      <!-- Core stack: silicon at bottom (foundation), protocols at top (surface) -->
      <div>
        <p
          class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2"
        >
          Core stack &middot; surface
        </p>
        <div
          class="border-x border-t border-[var(--color-border-strong)] rounded-t-lg overflow-hidden shadow-sm"
        >
          {
            coreStackedTopDown.map((layer, i) => {
              const isFirst = i === 0;
              const isLast = i === total - 1;
              return (
                <a
                  href={`/stack/${layer.slug}`}
                  class={`block group transition-colors no-underline hover:no-underline border-b border-[var(--color-border-strong)] hover:bg-[var(--color-accent-soft)] ${isLast ? "border-b-2" : ""}`}
                  style={`background: ${bgForIndex(i)};`}
                >
                  <div class="flex items-baseline gap-3 px-4 py-3.5">
                    <span class="font-mono text-xs text-[var(--color-tier-core)] font-semibold w-6 flex-none">
                      {String(layer.order).padStart(2, "0")}
                    </span>
                    <span class="font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] flex-shrink-0">
                      {layer.title}
                    </span>
                    <span class="text-xs text-[var(--color-text-subtle)] hidden sm:inline truncate flex-1 text-right">
                      {layer.short_description}
                    </span>
                  </div>
                </a>
              );
            })
          }
        </div>
        <p
          class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mt-2 text-right"
        >
          Foundation &middot; substrate
        </p>
      </div>

      <!-- Cross-cutting meta-layers (vertical band, observes all core layers) -->
      <aside class="space-y-2 md:sticky md:top-20">
        <p
          class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2"
        >
          Cross-cutting meta-layers
        </p>
        {
          meta.map((layer) => (
            <a
              href={`/stack/${layer.slug}`}
              class="block group border border-[var(--color-border)] bg-[var(--color-tier-meta-soft)] hover:border-[var(--color-tier-meta)] transition-colors rounded-md px-3 py-2 no-underline hover:no-underline"
            >
              <div class="flex flex-col gap-0.5">
                <span class="font-medium text-sm text-[var(--color-text)] group-hover:text-[var(--color-tier-meta)]">
                  {layer.title}
                </span>
                <span class="text-xs text-[var(--color-text-subtle)] leading-snug">
                  {layer.short_description}
                </span>
              </div>
            </a>
          ))
        }
        <p
          class="text-xs text-[var(--color-text-subtle)] italic mt-3 leading-snug"
        >
          Meta-layers observe or constrain every core layer; they do not sit
          between two layers in the pipeline.
        </p>
      </aside>
    </div>

    <div
      class="mt-6 pt-4 border-t border-[var(--color-border)] flex flex-wrap items-center gap-6 text-xs text-[var(--color-text-subtle)] font-mono"
    >
      <span class="flex items-center gap-2">
        <span
          class="inline-block w-3 h-3 rounded border border-[var(--color-border-strong)]"
          style="background: hsl(35, 38%, 92%);"
        ></span>
        core layer (stacked: surface above, foundation below)
      </span>
      <span class="flex items-center gap-2">
        <span
          class="inline-block w-3 h-3 rounded border border-[var(--color-border)] bg-[var(--color-tier-meta-soft)]"
        ></span>
        cross-cutting meta-layer
      </span>
    </div>
  </div>
</section>
