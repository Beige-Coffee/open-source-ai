---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { loadLayers } from "../../lib/layers";

export async function getStaticPaths() {
  const entries = await getCollection("glossary");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const layers = loadLayers();
const allLayers = [...layers.core, ...layers.meta];
const layerBySlug = Object.fromEntries(allLayers.map((l) => [l.slug, l]));
const primary = layerBySlug[entry.data.primary_layer];
const secondaries = (entry.data.secondary_layers ?? []).map(
  (s) => layerBySlug[s],
).filter(Boolean);

// Backlinks: scan layer + glossary content collections for <G term="slug">
// wraps. Use content collection bodies rather than raw fs so this works
// in both static and SSR builds.
const slug = entry.id;
const tagRe = new RegExp(
  `<G\\s+term=["']${slug.replace(/[-/\\^$*+?.()|[\]{}]/g, "\\$&")}["']`,
);

interface Backlink {
  kind: "layer" | "glossary";
  slug: string;
  title: string;
  href: string;
}
const backlinks: Backlink[] = [];

const layerEntries = await getCollection("layers");
for (const l of layerEntries) {
  if (tagRe.test(l.body ?? "")) {
    const layerSlug = l.id;
    const layer = layerBySlug[layerSlug];
    if (layer) {
      backlinks.push({
        kind: "layer",
        slug: layerSlug,
        title: layer.title,
        href: `/stack/${layerSlug}`,
      });
    }
  }
}

const allEntries = await getCollection("glossary");
for (const other of allEntries) {
  if (other.id === slug) continue;
  if (tagRe.test(other.body ?? "")) {
    backlinks.push({
      kind: "glossary",
      slug: other.id,
      title: other.data.term,
      href: `/glossary/${other.id}`,
    });
  }
}

backlinks.sort((a, b) => a.title.toLowerCase().localeCompare(b.title.toLowerCase()));
---

<BaseLayout
  title={entry.data.term}
  description={entry.data.summary}
>
  <article class="max-w-3xl mx-auto px-6 pt-16 pb-24">
    <p
      class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4"
    >
      Glossary
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-3"
    >
      {entry.data.term}
    </h1>

    <p class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-prose mb-6">
      {entry.data.summary}
    </p>

    <div class="flex flex-wrap items-center gap-2 mb-10 text-xs">
      {
        primary && (
          <a
            href={`/stack/${primary.slug}`}
            class="font-mono uppercase tracking-wider px-2 py-1 rounded border border-[var(--color-border-strong)] text-[var(--color-text)] no-underline hover:bg-[var(--color-surface-warm)]"
          >
            {primary.title}
          </a>
        )
      }
      {
        secondaries.map((l) => (
          <a
            href={`/stack/${l.slug}`}
            class="font-mono uppercase tracking-wider px-2 py-1 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] no-underline hover:bg-[var(--color-surface-warm)]"
          >
            also: {l.title}
          </a>
        ))
      }
      {
        entry.data.aliases.length > 0 && (
          <span class="font-mono uppercase tracking-wider text-[var(--color-text-subtle)] ml-2">
            aka {entry.data.aliases.join(", ")}
          </span>
        )
      }
    </div>

    <div class="prose-glossary">
      <Content />
    </div>

    {
      entry.data.sources.length > 0 && (
        <section class="mt-12 pt-6 border-t border-[var(--color-border)]">
          <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-3">
            Sources
          </h2>
          <ul class="space-y-2 text-sm">
            {entry.data.sources.map((s) => (
              <li>
                <a
                  href={s.url}
                  class="text-[var(--color-text)] hover:text-[var(--color-accent-strong)]"
                  target="_blank"
                  rel="noopener"
                >
                  {s.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      backlinks.length > 0 && (
        <section class="mt-10 pt-6 border-t border-[var(--color-border)]">
          <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-3">
            Mentioned in
          </h2>
          <ul class="flex flex-wrap gap-2 text-sm">
            {backlinks.map((b) => (
              <li>
                <a
                  href={b.href}
                  class="inline-block px-2 py-1 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-border-strong)] hover:text-[var(--color-text)] no-underline"
                >
                  {b.kind === "layer" ? (
                    <span class="font-mono text-[10px] uppercase tracking-wider mr-1 text-[var(--color-text-subtle)]">
                      layer
                    </span>
                  ) : null}
                  {b.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="mt-10 flex flex-wrap gap-3">
      <button
        type="button"
        id="glossary-chat-trigger"
        data-term-name={entry.data.term}
        data-term-slug={entry.id}
        class="px-4 py-2 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-surface)] hover:bg-[var(--color-surface-warm)] text-sm cursor-pointer"
      >
        Chat about this <span aria-hidden="true">→</span>
      </button>
      <a
        href="/glossary"
        class="px-4 py-2 rounded-md text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] no-underline"
      >
        Back to glossary
      </a>
    </section>
  </article>

  <style is:global>
    .prose-glossary {
      color: var(--color-text);
      font-size: 1rem;
      line-height: 1.65;
    }
    .prose-glossary p {
      margin: 0 0 1.1em;
    }
    .prose-glossary p:last-child {
      margin-bottom: 0;
    }
    .prose-glossary code {
      font-family: var(--font-mono);
      font-size: 0.875em;
      background: var(--color-surface-warm);
      padding: 1px 5px;
      border-radius: 3px;
    }
  </style>

  <script>
    const btn = document.getElementById("glossary-chat-trigger");
    btn?.addEventListener("click", () => {
      const term = btn.getAttribute("data-term-name") ?? "this term";
      const slug = btn.getAttribute("data-term-slug") ?? "";
      window.dispatchEvent(
        new CustomEvent("chat-trigger", {
          detail: {
            prompt:
              `Explain "${term}" for someone exploring the open-source AI stack. ` +
              `Call read_glossary("${slug}") first to ground the answer in the wiki entry, ` +
              `then add nuance the entry doesn't cover.`,
          },
        }),
      );
    });
  </script>
</BaseLayout>
