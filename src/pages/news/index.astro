---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const news = await getCollection("news");
news.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

/** Split a paragraph of editorial letter prose into short bullet
 *  sentences. The summarize-and-publish stage of the news routine
 *  writes well-formed sentences; ". " is a safe boundary, version
 *  numbers like vLLM v0.21.0 keep their dots inside (no following
 *  space). Drops anything under 4 chars to filter noise. */
function bullets(letter: string): string[] {
  return letter
    .split(/\.\s+/)
    .map((s) => s.trim().replace(/\.+$/, ""))
    .filter((s) => s.length > 3)
    .map((s) => s + ".");
}
---

<BaseLayout
  title="News archive"
  description="The full news archive. Browse by date, week, or per-layer feed."
>
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-6">
    <p
      class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4"
    >
      News archive
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-6"
    >
      Browse the archive
    </h1>
    <ul class="text-base text-[var(--color-text-muted)] leading-relaxed space-y-1.5 list-disc pl-5">
      <li>One issue per day at a permanent URL.</li>
      <li>Reverse-chronological order; most recent first.</li>
      <li>
        Per-layer item counts on each card show which layers moved that day.
      </li>
      <li>
        Click any card to open the full issue, or subscribe via{" "}
        <a href="/rss/news.xml" class="text-[var(--color-text)] hover:no-underline">RSS</a>.
      </li>
    </ul>
  </section>

  <section class="max-w-3xl mx-auto px-6 my-8">
    {
      news.length === 0 ? (
        <p class="text-[var(--color-text-subtle)]">
          No issues published yet. First issue will appear once the daily
          routine starts.
        </p>
      ) : (
        <ul class="space-y-3">
          {news.map((issue) => {
            const dateStr = issue.data.date.toISOString().slice(0, 10);
            const counts = Object.entries(issue.data.layer_buckets ?? {})
              .sort((a, b) => b[1] - a[1]);
            return (
              <li>
                <a
                  href={`/news/${dateStr}`}
                  class="block border border-[var(--color-border)] rounded-md p-4 bg-[var(--color-surface)] hover:border-[var(--color-border-strong)] hover:bg-[var(--color-surface-warm)] no-underline transition-colors"
                >
                  <div class="flex items-baseline justify-between gap-3 mb-2 flex-wrap">
                    <span class="font-mono text-sm font-medium text-[var(--color-text)]">
                      {dateStr}
                    </span>
                    {counts.length > 0 && (
                      <span class="font-mono text-[10px] text-[var(--color-text-subtle)] uppercase tracking-wider">
                        {counts.map(([slug, n]) => `${slug} ${n}`).join(" · ")}
                      </span>
                    )}
                  </div>
                  <ul class="text-sm text-[var(--color-text-muted)] leading-relaxed space-y-1 list-disc pl-5">
                    {bullets(issue.data.editorial_letter).slice(0, 4).map((b) => (
                      <li>{b}</li>
                    ))}
                  </ul>
                </a>
              </li>
            );
          })}
        </ul>
      )
    }
  </section>
</BaseLayout>
