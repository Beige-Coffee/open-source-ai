---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const news = await getCollection("news");
news.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="News archive"
  description="The full news archive. Browse by date, week, or per-layer feed."
>
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-8">
    <p
      class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4"
    >
      News archive
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-6"
    >
      Browse the archive
    </h1>
    <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
      Every day's roundup at a permanent URL. Once the scheduled agent
      starts (Week 2 of the build), this page lists every issue in
      reverse-chronological order with item counts per layer.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 my-8">
    {
      news.length === 0 ? (
        <p class="text-[var(--color-text-subtle)] italic">
          No issues published yet. First issue will appear once the daily
          routine starts.
        </p>
      ) : (
        <ul class="space-y-3">
          {news.map((issue) => (
            <li class="border border-[var(--color-border)] rounded-md p-4 bg-[var(--color-surface)]">
              <a
                href={`/news/${issue.data.date.toISOString().slice(0, 10)}`}
                class="font-mono text-sm font-medium no-underline hover:underline"
              >
                {issue.data.date.toISOString().slice(0, 10)}
              </a>
              <p class="text-sm text-[var(--color-text-muted)] mt-1">
                {issue.data.editorial_letter}
              </p>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
