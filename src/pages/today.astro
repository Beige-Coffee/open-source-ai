---
import { getCollection } from "astro:content";

const issues = await getCollection("news");
issues.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latest = issues[0];
---

{
  latest ? (
    <script
      is:inline
      define:vars={{ url: `/news/${latest.data.date.toISOString().slice(0, 10)}` }}
    >
      window.location.replace(url);
    </script>
  ) : null
}

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    {
      latest && (
        <meta
          http-equiv="refresh"
          content={`0; url=/news/${latest.data.date.toISOString().slice(0, 10)}`}
        />
      )
    }
    <title>Today &middot; The Open-Source AI Stack</title>
  </head>
  <body
    style="font-family: -apple-system, sans-serif; padding: 4rem 1.5rem; max-width: 640px; margin: 0 auto; color: #18181b; background: #fafaf9;"
  >
    {
      latest ? (
        <p>
          Redirecting to the latest issue (
          <a href={`/news/${latest.data.date.toISOString().slice(0, 10)}`}>
            {latest.data.date.toISOString().slice(0, 10)}
          </a>
          )...
        </p>
      ) : (
        <>
          <h1 style="font-family: 'IBM Plex Serif', Georgia, serif; font-size: 2.5rem; margin-bottom: 1rem;">
            Today
          </h1>
          <p style="font-size: 1.125rem; line-height: 1.55;">
            No issues published yet. The first daily roundup lands once the
            scheduled agent kicks off, around 08:00 Pacific. Until then, see
            the <a href="/stack">stack</a> or <a href="/about">about</a>{" "}
            pages for the framing and methodology.
          </p>
        </>
      )
    }
  </body>
</html>
