---
import BaseLayout from "../layouts/BaseLayout.astro";
import StackDiagram from "../components/StackDiagram.astro";
---

<BaseLayout title="The Open-Source AI Stack">
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-2">
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-3"
    >
      The Open-Source AI Stack
    </h1>
    <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-prose">
      Ten core layers, five cross-cuts. Hover any layer for what's in it; click to dive in.
    </p>
  </section>

  <StackDiagram />
</BaseLayout>
