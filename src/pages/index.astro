---
import BaseLayout from "../layouts/BaseLayout.astro";
import StackDiagram from "../components/StackDiagram.astro";
---

<BaseLayout title="The Open-Source AI Stack">
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-4">
    <p
      class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4"
    >
      A living map &middot; updated daily
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-6"
    >
      The Open-Source AI Stack
    </h1>
    <p
      class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-prose mb-3"
    >
      Ten core layers, five cross-cuts, and the projects, news, grants,
      readings, and predictions flowing through each. Click any layer
      below for what is in it.
    </p>
    <p
      class="text-sm text-[var(--color-text-subtle)] leading-relaxed max-w-prose"
    >
      Click the bubble bottom-right to ask the in-site chat anything;
      it is bring-your-own-key (add an API key on{" "}
      <a href="/settings" class="no-underline hover:underline">settings</a>).
      The course at <a href="/learn" class="no-underline hover:underline">/learn</a>
      runs against a logged-in profile; see <a href="/privacy" class="no-underline hover:underline">/privacy</a> for what that stores.
    </p>
  </section>

  <StackDiagram />
</BaseLayout>
