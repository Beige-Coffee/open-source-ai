---
import BaseLayout from "../layouts/BaseLayout.astro";
import Settings from "../components/Settings.tsx";
---

<BaseLayout
  title="Settings"
  description="Configure the in-site chat agent: API key, provider, model."
>
  <section class="max-w-2xl mx-auto px-6 pt-16 pb-12">
    <p
      class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4"
    >
      Settings
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-6"
    >
      Configure the chat
    </h1>
    <p
      class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-prose mb-10"
    >
      The in-site chat agent answers questions grounded in this site's
      curated wiki (grants, funders, projects, layers, readings,
      predictions, news). Pure BYOK: paste your own API key, it stays in
      your browser.
    </p>
    <Settings client:only="react" />
  </section>
</BaseLayout>
