---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadLayers } from "../../lib/layers";

export async function getStaticPaths() {
  const entries = await getCollection("synthesis");
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const layers = loadLayers();
const allLayers = [...layers.core, ...layers.meta];
const findLayer = (slug: string) => allLayers.find((l) => l.slug === slug);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <section class="max-w-3xl mx-auto px-6 pt-12 pb-4">
    <p class="font-mono text-xs uppercase tracking-wider mb-2">
      <a
        href="/essays"
        class="no-underline hover:underline text-[var(--color-text-subtle)]"
      >
        Essays
      </a>
      <span class="text-[var(--color-text-subtle)]"> &middot; </span>
      <span class="text-[var(--color-text-subtle)]">
        Updated {entry.data.updated.toISOString().slice(0, 10)}
      </span>
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-4"
    >
      {entry.data.title}
    </h1>
    <p
      class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-prose"
    >
      {entry.data.summary}
    </p>
  </section>

  <article class="max-w-3xl mx-auto px-6 my-8 prose">
    <Content />
  </article>

  {
    entry.data.related_layers.length > 0 && (
      <section class="max-w-3xl mx-auto px-6 my-8 pt-6 border-t border-[var(--color-border)]">
        <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-3">
          Related layers
        </p>
        <div class="flex flex-wrap gap-2">
          {entry.data.related_layers
            .map((slug: string) => findLayer(slug))
            .filter((l: any) => l)
            .map((l: any) => (
              <a
                href={`/stack/${l.slug}`}
                class="font-mono text-xs px-2 py-1 rounded border border-[var(--color-border)] no-underline hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] text-[var(--color-text-muted)]"
              >
                {l.title}
              </a>
            ))}
        </div>
      </section>
    )
  }
</BaseLayout>
