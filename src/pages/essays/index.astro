---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const essays = (await getCollection("synthesis")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---

<BaseLayout
  title="Essays"
  description="The load-bearing arguments of the site: cross-cutting essays on lock-in vectors, sovereignty, licensing, and the open AI stack."
>
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-8">
    <p
      class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4"
    >
      Essays
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-6"
    >
      The load-bearing arguments
    </h1>
    <p
      class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-prose"
    >
      Cross-cutting essays. The layer pages describe what is at each
      layer; these essays argue why the layer matters and how it chains
      to the others. The chat agent grounds in these constantly when you
      ask "why" questions.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 my-12">
    <ul class="space-y-6">
      {
        essays.map((e) => (
          <li class="border-l-2 border-[var(--color-accent-soft)] pl-4">
            <a
              href={`/essays/${e.data.slug}`}
              class="block group no-underline hover:no-underline"
            >
              <h2 class="font-serif text-2xl text-[var(--color-text)] group-hover:text-[var(--color-accent)] mb-2 leading-tight">
                {e.data.title}
              </h2>
              <p class="text-base text-[var(--color-text-muted)] leading-relaxed">
                {e.data.summary}
              </p>
              <p class="text-xs font-mono text-[var(--color-text-subtle)] mt-2">
                Updated {e.data.updated.toISOString().slice(0, 10)}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
