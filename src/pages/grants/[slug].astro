---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadLayers } from "../../lib/layers";
import {
  loadFunders,
  loadGrants,
  grantSlug,
  assertGrantSlugsUnique,
} from "../../lib/grants";

export async function getStaticPaths() {
  const grants = loadGrants();
  assertGrantSlugsUnique(grants);
  return grants.map((g) => ({
    params: { slug: grantSlug(g.title) },
    props: { grant: g },
  }));
}

const { grant } = Astro.props;

const layers = loadLayers();
const allLayers = [...layers.core, ...layers.meta];
const findLayer = (slug: string) => allLayers.find((l) => l.slug === slug);

const funders = loadFunders();
const funder = funders.find((f) => f.slug === grant.funder) ?? null;

// Up to five other recent grants from the same funder, newest first.
const grants = loadGrants();
const siblings = grants
  .filter((g) => g.funder === grant.funder && g.title !== grant.title)
  .slice(0, 5);

const kindLabel = grant.kind === "project" ? "Project grant" : "Program";
---

<BaseLayout
  title={`${grant.title} · Grant`}
  description={grant.description}
>
  <section class="max-w-3xl mx-auto px-6 pt-12 pb-2">
    <p
      class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2"
    >
      <a
        href="/grants"
        class="no-underline hover:underline text-[var(--color-text-subtle)]"
        >Grants</a
      >
      <span> &middot; </span>
      <span>{kindLabel}</span>
      <span> &middot; </span>
      <span>{grant.region}</span>
    </p>
    <h1 class="font-serif text-3xl md:text-4xl leading-tight tracking-tight mb-3">
      {grant.title}
    </h1>
    <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
      {grant.description}
    </p>
  </section>

  <div class="max-w-5xl mx-auto px-6 grid gap-10 md:grid-cols-[1fr_240px] mt-8">
    <article class="text-base text-[var(--color-text)] leading-relaxed space-y-6">
      {
        grant.explainer && (
          <section class="text-[var(--color-text)] leading-relaxed space-y-3">
            {grant.explainer.split(/\n{2,}/).map((para) => (
              <p>{para.trim()}</p>
            ))}
          </section>
        )
      }

      <section>
        <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2">
          Recipient
        </h2>
        <p>{grant.recipient}</p>
      </section>

      {
        funder && (
          <section>
            <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2">
              Funder
            </h2>
            <p>
              <a
                href={`/grants/funder/${funder.slug}`}
                class="text-[var(--color-text)] hover:no-underline"
              >
                {funder.name}
              </a>{" "}
              <span class="text-[var(--color-text-subtle)]">
                &middot; {funder.type} &middot; {funder.region}
              </span>
            </p>
            {funder.mission && (
              <p class="text-sm text-[var(--color-text-muted)] mt-1 leading-relaxed">
                {funder.mission}
              </p>
            )}
          </section>
        )
      }

      <section>
        <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2">
          Primary source
        </h2>
        <p>
          <a
            href={grant.url}
            target="_blank"
            rel="noopener"
            class="text-[var(--color-text)] hover:no-underline break-words"
          >
            {grant.url}
            <span aria-hidden="true"> &rarr;</span>
          </a>
        </p>
      </section>

      {
        grant.sources && grant.sources.length > 0 && (
          <section>
            <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2">
              Additional sources
            </h2>
            <ul class="space-y-1.5 list-disc pl-5">
              {grant.sources.map((s) => (
                <li class="leading-relaxed">
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener"
                    class="text-[var(--color-text)] hover:no-underline"
                  >
                    {s.title}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        siblings.length > 0 && funder && (
          <section class="border-t border-[var(--color-border)] pt-6">
            <h2 class="font-serif text-xl text-[var(--color-text)] mb-3">
              More from {funder.name}
            </h2>
            <ul class="space-y-3">
              {siblings.map((g) => (
                <li>
                  <a
                    href={`/grants/${grantSlug(g.title)}`}
                    class="block border border-[var(--color-border)] rounded-md p-3 bg-[var(--color-surface)] hover:border-[var(--color-border-strong)] no-underline"
                  >
                    <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
                      <span class="font-medium text-[var(--color-text)] text-sm">
                        {g.title}
                      </span>
                      <span class="font-mono text-[11px] text-[var(--color-text-subtle)]">
                        {g.date} &middot; {g.amount_label}
                      </span>
                    </div>
                    <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                      {g.description}
                    </p>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </article>

    <aside class="text-sm space-y-6">
      <div
        class="border border-[var(--color-border)] rounded-md p-4 bg-[var(--color-surface)]"
      >
        <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-1">
          Date
        </p>
        <p class="font-mono text-sm mb-3">{grant.date}</p>

        <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-1">
          Amount
        </p>
        <p class="font-mono text-sm mb-3">{grant.amount_label}</p>

        <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-1">
          Region
        </p>
        <p class="font-mono text-sm mb-3">{grant.region}</p>

        <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-1">
          Kind
        </p>
        <p class="font-mono text-sm">{kindLabel}</p>
      </div>

      {
        grant.layers.length > 0 && (
          <div>
            <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2">
              Layers
            </p>
            <ul class="flex flex-wrap gap-1.5">
              {grant.layers
                .map((slug) => findLayer(slug))
                .filter((l) => l)
                .map((l) => (
                  <li>
                    <a
                      href={`/stack/${l!.slug}`}
                      class="font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 border border-[var(--color-border)] rounded no-underline hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] text-[var(--color-text-muted)]"
                    >
                      {l!.title}
                    </a>
                  </li>
                ))}
            </ul>
          </div>
        )
      }

      <div class="text-xs text-[var(--color-text-subtle)]">
        <a href="/grants" class="no-underline hover:underline">
          ← All grants
        </a>
      </div>
    </aside>
  </div>
</BaseLayout>
