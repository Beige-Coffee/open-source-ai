---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadLayers } from "../../lib/layers";
import {
  loadProjectsForLayer,
  focusLabel,
  focusColor,
} from "../../lib/projects";
import {
  loadReadingsForLayer,
  typeLabel,
  type ReadingType,
} from "../../lib/reading-lists";
import {
  loadPredictionsForLayer,
  confidenceLabel,
} from "../../lib/predictions";
import { loadGrants, formatUsd } from "../../lib/grants";

export async function getStaticPaths() {
  const entries = await getCollection("layers");
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const layers = loadLayers();

const all = [...layers.core, ...layers.meta];
const findBySlug = (slug: string) => all.find((l) => l.slug === slug);

const tierLabel =
  entry.data.tier === "core" ? "Core layer" : "Cross-cutting meta-layer";
const tierColor =
  entry.data.tier === "core"
    ? "var(--color-tier-core)"
    : "var(--color-tier-meta)";

const projects = loadProjectsForLayer(entry.data.slug);

// Reading list: group by type, recent-first within each group.
// /stack/<slug> is the canonical destination for the layer's reading
// list; there is no longer a separate /learn/<slug>.
const allReadings = loadReadingsForLayer(entry.data.slug);
const readingTypeOrder: ReadingType[] = [
  "paper",
  "post",
  "talk",
  "podcast",
  "book",
  "docs",
  "thread",
];
const readingsByType: Record<string, typeof allReadings> = {};
for (const r of allReadings) {
  if (!readingsByType[r.type]) readingsByType[r.type] = [];
  readingsByType[r.type].push(r);
}
for (const t of Object.keys(readingsByType)) {
  readingsByType[t].sort((a, b) => b.year - a.year);
}
const readingTypeKeys = readingTypeOrder.filter(
  (t) => readingsByType[t] && readingsByType[t].length > 0,
);

const predictions = loadPredictionsForLayer(entry.data.slug);

// Pull latest news bucket count for this layer from the most recent
// daily issue. Falls back to zero if the issue does not bucket this
// layer.
const allNews = await getCollection("news");
const latestIssue = [...allNews].sort((a, b) =>
  String(b.data.date).localeCompare(String(a.data.date)),
)[0];
const latestNewsCount =
  latestIssue?.data.layer_buckets?.[entry.data.slug] ?? 0;
const latestNewsDate = latestIssue
  ? latestIssue.data.date.toISOString().slice(0, 10)
  : null;

// Grants flowing into this layer.
const allGrants = loadGrants();
const layerGrants = allGrants
  .filter((g) => g.layers.includes(entry.data.slug))
  .slice(0, 5);
const layerGrantsTotal = allGrants
  .filter((g) => g.layers.includes(entry.data.slug))
  .reduce((sum, g) => sum + (g.amount_usd || 0), 0);
const layerGrantsCount = allGrants.filter((g) =>
  g.layers.includes(entry.data.slug),
).length;

// Group projects by focus for visual ordering: open first, then
// open-weights, then everything else.
const focusOrder = {
  open: 0,
  "open-weights": 1,
  "source-available": 2,
  standard: 3,
  proprietary: 4,
};
const orderedProjects = [...projects].sort(
  (a, b) => (focusOrder[a.focus] ?? 99) - (focusOrder[b.focus] ?? 99),
);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.short_description}
>
  <section class="max-w-5xl mx-auto px-6 pt-12 pb-4">
    <p class="font-mono text-xs uppercase tracking-wider mb-2">
      <a
        href="/stack"
        class="no-underline hover:underline text-[var(--color-text-subtle)]"
      >
        The Stack
      </a>
      <span class="text-[var(--color-text-subtle)]"> &middot; </span>
      <span style={`color: ${tierColor}`}>{tierLabel}</span>
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-4"
    >
      {entry.data.title}
    </h1>
    <p
      class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-prose"
    >
      {entry.data.short_description}
    </p>
  </section>

  <div
    class="max-w-5xl mx-auto px-6 grid gap-12 md:grid-cols-[1fr_240px] mt-8 pb-16"
  >
    <article id="layer-article">
      <!-- What it is: the MDX body. Editorial intro, 3-5 sentences.
           Stays above the tab bar; it's the canonical intro everyone
           wants regardless of which tab they end up on. -->
      <section class="prose mb-8">
        <h2 class="!mt-0">What it is</h2>
        <Content />
      </section>

      <!-- Tab bar: switches the panels below. Each tab is conditional
           on its panel having content (no Grants tab if 0 grants). -->
      <div
        role="tablist"
        aria-label="Layer detail sections"
        class="sticky top-16 z-10 -mx-2 px-2 py-2 mb-6 bg-[var(--color-bg)] border-b border-[var(--color-border)]"
      >
        <div class="flex gap-1 flex-wrap">
          {projects.length > 0 && (
            <button
              type="button"
              role="tab"
              data-layer-tab="projects"
              aria-selected="true"
              class="px-3 py-1.5 rounded-md font-medium text-sm bg-[var(--color-accent-soft)] text-[var(--color-accent)] cursor-pointer"
            >
              Projects
              <span class="font-mono text-xs ml-1 opacity-70">{projects.length}</span>
            </button>
          )}
          <button
            type="button"
            role="tab"
            data-layer-tab="news"
            aria-selected={projects.length === 0 ? "true" : "false"}
            class={projects.length === 0
              ? "px-3 py-1.5 rounded-md font-medium text-sm bg-[var(--color-accent-soft)] text-[var(--color-accent)] cursor-pointer"
              : "px-3 py-1.5 rounded-md font-medium text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-warm)] cursor-pointer"
            }
          >
            News
            {latestNewsCount > 0 && (
              <span class="font-mono text-xs ml-1 opacity-70">{latestNewsCount}</span>
            )}
          </button>
          {layerGrantsCount > 0 && (
            <button
              type="button"
              role="tab"
              data-layer-tab="grants"
              aria-selected="false"
              class="px-3 py-1.5 rounded-md font-medium text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-warm)] cursor-pointer"
            >
              Grants
              <span class="font-mono text-xs ml-1 opacity-70">{layerGrantsCount}</span>
            </button>
          )}
          {predictions.length > 0 && (
            <button
              type="button"
              role="tab"
              data-layer-tab="predictions"
              aria-selected="false"
              class="px-3 py-1.5 rounded-md font-medium text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-warm)] cursor-pointer"
            >
              Predictions
              <span class="font-mono text-xs ml-1 opacity-70">{predictions.length}</span>
            </button>
          )}
          {allReadings.length > 0 && (
            <button
              type="button"
              role="tab"
              data-layer-tab="readings"
              aria-selected="false"
              class="px-3 py-1.5 rounded-md font-medium text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-warm)] cursor-pointer"
            >
              Readings
              <span class="font-mono text-xs ml-1 opacity-70">{allReadings.length}</span>
            </button>
          )}
        </div>
      </div>

      <!-- Key projects: medium cards seeded from data/projects.yaml.
           Per-project "Ask about this" button dispatches a chat-trigger
           event that ChatBubble listens for. High-priority projects
           have an inline expandable explainer with cited sources. -->
      {
        projects.length > 0 && (
          <div data-layer-panel="projects" class="mb-8">
            <h2 class="font-sans text-xl font-semibold mb-1">
              Key projects
            </h2>
            <p class="text-sm text-[var(--color-text-subtle)] mb-4 font-mono">
              {projects.length} catalogued &middot; ordered open first &middot; "Details" for a project page, "Ask" for an in-context chat
            </p>
            <ul class="grid gap-3 sm:grid-cols-2">
              {orderedProjects.map((p) => (
                <li class="border border-[var(--color-border)] rounded-md p-4 bg-[var(--color-surface)] hover:border-[var(--color-border-strong)] transition-colors">
                  <div class="flex items-start justify-between gap-2 mb-1">
                    <a
                      href={p.url}
                      target="_blank"
                      rel="noopener"
                      class="font-semibold no-underline hover:underline text-[var(--color-text)]"
                    >
                      {p.name}
                    </a>
                    <span
                      class="font-mono text-xs whitespace-nowrap"
                      style={`color: ${focusColor(p.focus)};`}
                    >
                      {focusLabel(p.focus)}
                    </span>
                  </div>
                  <p class="text-sm text-[var(--color-text-muted)] leading-snug mb-2">
                    {p.description}
                  </p>
                  <div class="flex items-center gap-3 text-xs text-[var(--color-text-subtle)] font-mono flex-wrap">
                    <span>{p.license}</span>
                    <span>&middot;</span>
                    <span>{p.maturity}</span>
                    {p.github && (
                      <>
                        <span>&middot;</span>
                        <a
                          href={p.github}
                          target="_blank"
                          rel="noopener"
                          class="no-underline hover:underline"
                        >
                          GitHub
                        </a>
                      </>
                    )}
                    {p.explainer && (
                      <>
                        <span>&middot;</span>
                        <a
                          href={`/projects/${p.slug}`}
                          class="no-underline hover:underline text-[var(--color-text)]"
                        >
                          Details &rarr;
                        </a>
                      </>
                    )}
                    <button
                      type="button"
                      class="ml-auto px-2 py-0.5 rounded border border-[var(--color-border)] hover:border-[var(--color-text)] hover:text-[var(--color-text)] cursor-pointer transition-colors"
                      data-ask-project={p.slug}
                      data-ask-project-name={p.name}
                      data-ask-layer={entry.data.slug}
                      data-ask-layer-title={entry.data.title}
                    >
                      Ask &rarr;
                    </button>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- Latest news panel. -->
      <div data-layer-panel="news" class={projects.length === 0 ? "mb-8" : "mb-8 hidden"}>
        <h2 class="font-sans text-xl font-semibold mb-1">Latest news</h2>
        <p class="text-sm text-[var(--color-text-subtle)] mb-3 font-mono">
          Updates daily at 08:00 PT
        </p>
        {
          latestIssue ? (
            <div class="border border-[var(--color-border)] rounded-md p-4 bg-[var(--color-surface)]">
              <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2">
                {latestNewsDate}
              </p>
              {latestNewsCount > 0 ? (
                <p class="text-sm text-[var(--color-text-muted)] mb-3">
                  Today's issue includes{" "}
                  <strong class="text-[var(--color-text)]">
                    {latestNewsCount}{" "}
                    {latestNewsCount === 1 ? "item" : "items"}
                  </strong>{" "}
                  at this layer.
                </p>
              ) : (
                <p class="text-sm text-[var(--color-text-muted)] mb-3">
                  No items at this layer in today's issue.
                </p>
              )}
              <a
                href={`/news/${latestNewsDate}`}
                class="font-mono text-sm no-underline hover:underline"
              >
                Read today's issue &rarr;
              </a>
            </div>
          ) : (
            <p class="text-sm text-[var(--color-text-subtle)] italic">
              No news issues published yet.
            </p>
          )
        }
      </div>

      <!-- Grants flowing in panel. -->
      {
        layerGrantsCount > 0 && (
          <div data-layer-panel="grants" class="mb-8 hidden">
            <h2 class="font-sans text-xl font-semibold mb-1">
              Grants flowing in
            </h2>
            <p class="text-sm text-[var(--color-text-subtle)] mb-4 font-mono">
              {layerGrantsCount} tracked
              {layerGrantsTotal > 0 ? (
                <> &middot; {formatUsd(layerGrantsTotal)} disclosed total</>
              ) : null}
            </p>
            <ul class="space-y-2">
              {layerGrants.map((g) => (
                <li class="border border-[var(--color-border)] rounded-md px-4 py-3 bg-[var(--color-surface)] flex items-start gap-4">
                  <time class="font-mono text-xs text-[var(--color-text-subtle)] whitespace-nowrap shrink-0 w-20 tabular-nums pt-0.5">
                    {g.date}
                  </time>
                  <div class="flex-1 min-w-0">
                    <a
                      href={g.url}
                      target="_blank"
                      rel="noopener"
                      class="font-medium text-sm text-[var(--color-text)] hover:text-[var(--color-accent)] no-underline"
                    >
                      {g.title}
                    </a>
                    <p class="text-xs text-[var(--color-text-subtle)] mt-1 leading-snug">
                      {g.funder} &rarr; {g.recipient}
                      {" · "}
                      <span class="font-mono text-[var(--color-status-fresh)]">
                        {g.amount_label}
                      </span>
                    </p>
                  </div>
                </li>
              ))}
            </ul>
            <p class="mt-3 text-xs font-mono">
              <a href="/grants" class="no-underline hover:underline">
                See all grants &rarr;
              </a>
            </p>
          </div>
        )
      }

      <!-- Predictions panel. -->
      {
        predictions.length > 0 && (
          <div data-layer-panel="predictions" class="mb-8 hidden">
            <h2 class="font-sans text-xl font-semibold mb-1">
              Predictions baseline
            </h2>
            <p class="text-sm text-[var(--color-text-subtle)] mb-4 font-mono">
              Filed 2026-05-13 &middot; we track our own calls
            </p>
            <ul class="space-y-3">
              {predictions.map((p) => (
                <li class="border-l-2 border-[var(--color-accent-soft)] pl-4">
                  <p class="text-sm text-[var(--color-text)] mb-1">
                    {p.claim}
                  </p>
                  <p class="text-xs font-mono text-[var(--color-text-subtle)]">
                    resolves by {p.horizon} &middot; confidence{" "}
                    {confidenceLabel(p.confidence)} ({p.confidence}/5)
                  </p>
                </li>
              ))}
            </ul>
            <p class="mt-3 text-xs font-mono">
              <a href="/predictions" class="no-underline hover:underline">
                See all predictions &rarr;
              </a>
            </p>
          </div>
        )
      }

      <!-- Reading list panel. -->
      {
        allReadings.length > 0 && (
          <div data-layer-panel="readings" class="mb-8 hidden">
            <h2 class="font-sans text-xl font-semibold mb-1">Reading list</h2>
            <p class="text-sm text-[var(--color-text-subtle)] mb-4 font-mono">
              {allReadings.length} hand-picked &middot; primary sources first &middot; recent within each group
            </p>
            {readingTypeKeys.map((t) => (
              <div class="mb-6">
                <h3 class="font-sans text-sm font-semibold uppercase tracking-wider text-[var(--color-text-subtle)] mb-2">
                  {typeLabel(t)}s
                </h3>
                <ul class="space-y-3">
                  {readingsByType[t].map((r) => (
                    <li class="border border-[var(--color-border)] rounded-md px-4 py-3 bg-[var(--color-surface)]">
                      <div class="flex items-start justify-between gap-3 mb-1 flex-wrap">
                        <a
                          href={r.url}
                          target="_blank"
                          rel="noopener"
                          class="font-medium no-underline hover:underline text-[var(--color-text)]"
                        >
                          {r.title}
                        </a>
                        <span class="font-mono text-xs whitespace-nowrap text-[var(--color-text-subtle)]">
                          {r.year}
                        </span>
                      </div>
                      <p class="text-xs text-[var(--color-text-subtle)] mb-1 font-mono">
                        {r.source}
                      </p>
                      <p class="text-sm text-[var(--color-text-muted)] leading-snug">
                        {r.description}
                      </p>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        )
      }
    </article>

    <aside class="text-sm space-y-6 md:sticky md:top-20 md:self-start">
      <!-- Quick-glance metadata: the old lock-in framing, now sidebar-only. -->
      <div
        class="border border-[var(--color-border)] rounded-md p-4 bg-[var(--color-surface)]"
      >
        <p
          class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-1"
        >
          Position in the stack
        </p>
        <p class="font-mono text-sm mb-3">
          {entry.data.tier === "core" ? `Layer ${entry.data.order} / 10` : "Cross-cutting"}
        </p>

        <p
          class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-1"
        >
          Lock-in vector
        </p>
        <p class="text-sm mb-3">{entry.data.lock_in_vector}</p>

        <p
          class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-1"
        >
          Sovereignty relevance
        </p>
        <p class="font-mono text-sm mb-3">
          {entry.data.sovereignty_relevance} / 5
        </p>

        <p
          class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-1"
        >
          Last updated
        </p>
        <p class="font-mono text-xs text-[var(--color-text-muted)]">
          {entry.data.updated.toISOString().slice(0, 10)}
        </p>
      </div>

      {
        entry.data.related_layers.length > 0 && (
          <div>
            <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2">
              Related layers
            </p>
            <ul class="space-y-1">
              {entry.data.related_layers
                .map((slug: string) => findBySlug(slug))
                .filter((l: any) => l)
                .map((l: any) => (
                  <li>
                    <a
                      href={`/stack/${l.slug}`}
                      class="no-underline hover:underline"
                    >
                      {l.title}
                    </a>
                  </li>
                ))}
            </ul>
          </div>
        )
      }
    </aside>
  </div>
</BaseLayout>

<script is:inline>
  // Per-project "Ask" buttons. Each carries data-ask-project,
  // data-ask-project-name, data-ask-layer, data-ask-layer-title.
  // Click dispatches CustomEvent("chat-trigger", {detail: {prompt}})
  // which ChatBubble listens for. Pre-fills a prompt asking the chat
  // to explain that project in the context of this layer.
  (function () {
    const buttons = document.querySelectorAll("[data-ask-project]");
    for (const btn of buttons) {
      btn.addEventListener("click", () => {
        const slug = btn.getAttribute("data-ask-project");
        const name = btn.getAttribute("data-ask-project-name");
        const layer = btn.getAttribute("data-ask-layer");
        const layerTitle = btn.getAttribute("data-ask-layer-title");
        const prompt =
          `Tell me about ${name} (slug: ${slug}) in the context of the ${layerTitle} layer (slug: ${layer}). ` +
          `Cover: what it is, how it compares to other projects at this layer, why it matters for open-source AI, ` +
          `who is actually using it, and whether it is production-ready. Call read_project first, then compare ` +
          `against the siblings it returns. Keep the answer tight: 3-5 short paragraphs.`;
        window.dispatchEvent(
          new CustomEvent("chat-trigger", { detail: { prompt } }),
        );
      });
    }
  })();
</script>

<script is:inline>
  // Layer-page tab switcher. Tabs (Projects / News / Grants /
  // Predictions / Readings) toggle the panels below. Active tab
  // persists in the URL hash so deep-linking works (e.g.
  // /stack/runtime#grants opens with the Grants tab active).
  (function () {
    const root = document.getElementById("layer-article");
    if (!root) return;
    const tabs = Array.from(root.querySelectorAll("[data-layer-tab]"));
    const panels = Array.from(root.querySelectorAll("[data-layer-panel]"));
    if (!tabs.length) return;

    const activeClasses = ["bg-[var(--color-accent-soft)]", "text-[var(--color-accent)]"];
    const inactiveClasses = ["text-[var(--color-text-muted)]", "hover:text-[var(--color-text)]", "hover:bg-[var(--color-surface-warm)]"];

    function setActive(name) {
      for (const t of tabs) {
        const on = t.dataset.layerTab === name;
        t.setAttribute("aria-selected", on ? "true" : "false");
        for (const c of activeClasses) t.classList.toggle(c, on);
        for (const c of inactiveClasses) t.classList.toggle(c, !on);
      }
      for (const p of panels) {
        p.classList.toggle("hidden", p.dataset.layerPanel !== name);
      }
    }

    // Honor URL hash on load if it matches a known tab.
    const hash = window.location.hash.replace(/^#/, "");
    const validTabs = tabs.map((t) => t.dataset.layerTab);
    if (hash && validTabs.includes(hash)) {
      setActive(hash);
    }

    for (const t of tabs) {
      t.addEventListener("click", () => {
        const name = t.dataset.layerTab;
        setActive(name);
        history.replaceState(null, "", "#" + name);
      });
    }
  })();
</script>
