---
import BaseLayout from "../layouts/BaseLayout.astro";
import GrantsBrowser from "../components/GrantsBrowser.astro";
import { loadLayers } from "../lib/layers";
import {
  loadFunders,
  loadGrants,
  loadUnderfunded,
  buildLayerRollup,
  formatUsd,
} from "../lib/grants";

const layers = loadLayers();
const allLayers = [...layers.core, ...layers.meta];
const funders = loadFunders();
const grants = loadGrants();
const underfunded = loadUnderfunded();
const rollup = buildLayerRollup();

const findLayer = (slug: string) => allLayers.find((l) => l.slug === slug);

const layerRollupRows = allLayers
  .map((layer) => ({
    layer,
    row: rollup[layer.slug] || {
      layer: layer.slug,
      grant_count: 0,
      total_usd: 0,
      underfunded_count: 0,
      underfunded_high_count: 0,
      funders: new Set<string>(),
    },
  }))
  .filter((entry) => entry.row.grant_count > 0 || entry.row.underfunded_count > 0)
  .sort((a, b) => b.row.total_usd - a.row.total_usd);

const totalDocumentedUsd = grants.reduce(
  (sum, g) => sum + (g.amount_usd || 0),
  0,
);
---

<BaseLayout
  title="Grants"
  description="Who funds open-source AI, what they fund, where the gaps are, and concrete project shapes for new grantees."
>
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-6">
    <p
      class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4"
    >
      Grants
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-6"
    >
      Who funds what, and where the gaps are
    </h1>
    <p
      class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-prose"
    >
      Most AI funding flows through venture capital and hyperscaler
      partnerships, not grants. The grants tier is small by comparison,
      but it is where independent and sovereignty-positioned projects
      get their start. This page tracks who funds those projects, what
      they actually fund, and where the gaps are.
    </p>
  </section>

  <!-- Tight one-line stats strip. Was a 4-card grid; shrunk to a
       single horizontal line of mono text so it does not eat the
       fold above the tab bar. -->
  <section class="max-w-5xl mx-auto px-6 mt-2">
    <p
      class="font-mono text-xs text-[var(--color-text-subtle)] flex flex-wrap gap-x-4 gap-y-1"
    >
      <span>{funders.length} funders</span>
      <span class="text-[var(--color-border-strong)]">&middot;</span>
      <span>{grants.length} grants</span>
      <span class="text-[var(--color-border-strong)]">&middot;</span>
      <span>{underfunded.length} named gaps</span>
      <span class="text-[var(--color-border-strong)]">&middot;</span>
      <span>{formatUsd(totalDocumentedUsd)} disclosed</span>
    </p>
  </section>

  <!-- Top-level page tabs. Sticky on scroll so the user can switch
       sections without scrolling back up. URL hash persists the
       selected tab (#grants, #funders, #gaps, #rollup). -->
  <section
    id="grants-page"
    class="max-w-6xl mx-auto px-6"
  >
    <div
      role="tablist"
      aria-label="Grants section"
      class="sticky top-16 z-10 -mx-6 px-6 py-2 mb-6 bg-[var(--color-bg)] border-b border-[var(--color-border)]"
    >
      <div class="flex gap-1 flex-wrap">
        <button
          type="button"
          role="tab"
          data-grants-page-tab="grants"
          aria-selected="true"
          class="px-3 py-1.5 rounded-md font-medium text-sm bg-[var(--color-accent-soft)] text-[var(--color-accent)] cursor-pointer"
        >
          Grants
          <span class="font-mono text-xs ml-1 opacity-70">{grants.length}</span>
        </button>
        <button
          type="button"
          role="tab"
          data-grants-page-tab="funders"
          aria-selected="false"
          class="px-3 py-1.5 rounded-md font-medium text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-warm)] cursor-pointer"
        >
          Funders
          <span class="font-mono text-xs ml-1 opacity-70">{funders.length}</span>
        </button>
        <button
          type="button"
          role="tab"
          data-grants-page-tab="gaps"
          aria-selected="false"
          class="px-3 py-1.5 rounded-md font-medium text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-warm)] cursor-pointer"
        >
          Gaps
          <span class="font-mono text-xs ml-1 opacity-70">{underfunded.length}</span>
        </button>
        <button
          type="button"
          role="tab"
          data-grants-page-tab="rollup"
          aria-selected="false"
          class="px-3 py-1.5 rounded-md font-medium text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-warm)] cursor-pointer"
        >
          Layer rollup
        </button>
      </div>
    </div>

    <!-- Grants tab: the filterable browser (Projects / Programs sub-toggle inside) -->
    <div data-grants-page-panel="grants">
      <GrantsBrowser />
    </div>

    <!-- Funders tab -->
    <div data-grants-page-panel="funders" class="hidden">
      <section class="my-8">
        <h2 class="font-serif text-2xl mb-2">Active funders</h2>
        <p
          class="text-sm text-[var(--color-text-muted)] mb-6 max-w-prose"
        >
          {funders.length} funders tracked. Click a name for the full
          profile and the grants attributed to them.
        </p>
        <div class="grid gap-4 md:grid-cols-2">
          {
            funders.map((f) => (
              <a
                href={`/grants/funder/${f.slug}`}
                class="block border border-[var(--color-border)] rounded-md p-4 bg-[var(--color-surface)] hover:border-[var(--color-accent)] no-underline hover:no-underline group"
              >
                <div class="flex items-baseline justify-between gap-3 mb-1">
                  <span class="font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)]">
                    {f.name}
                  </span>
                  <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-subtle)]">
                    {f.region} &middot; {f.type}
                  </span>
                </div>
                <p class="text-sm text-[var(--color-text-muted)] leading-snug mb-2">
                  {f.mission}
                </p>
                <p class="text-xs text-[var(--color-text-subtle)] font-mono">
                  {f.funding_range}
                </p>
              </a>
            ))
          }
        </div>
      </section>
    </div>

    <!-- Gaps tab: underfunded areas -->
    <div data-grants-page-panel="gaps" class="hidden">
      <section class="my-8 max-w-3xl">
        <h2 class="font-serif text-2xl mb-2">Underfunded areas</h2>
        <p
          class="text-sm text-[var(--color-text-muted)] mb-6 max-w-prose"
        >
          {underfunded.length} specific gaps in the open-source AI stack
          where credible project shapes exist and no existing funder is
          sustainably covering the work. Sorted by priority. Layer
          attribution maps back to{" "}
          <a href="/stack" class="no-underline hover:underline">the stack</a>.
        </p>
        <ul class="space-y-6">
          {
            underfunded.map((u) => {
              const layer = findLayer(u.layer);
              const priorityColor =
                u.priority === "high"
                  ? "var(--color-accent)"
                  : u.priority === "medium"
                    ? "var(--color-tier-meta)"
                    : "var(--color-text-subtle)";
              return (
                <li
                  class="border-l-4 pl-4"
                  style={`border-color: ${priorityColor}`}
                >
                  <div class="flex flex-wrap items-baseline gap-3 mb-1">
                    <span
                      class="font-mono text-[10px] uppercase tracking-wider"
                      style={`color: ${priorityColor}`}
                    >
                      {u.priority} priority
                    </span>
                    {layer && (
                      <a
                        href={`/stack/${layer.slug}`}
                        class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-subtle)] no-underline hover:underline"
                      >
                        {layer.title}
                      </a>
                    )}
                  </div>
                  <h3 class="font-medium text-base text-[var(--color-text)] mb-2">
                    {u.title}
                  </h3>
                  <p class="text-sm text-[var(--color-text-muted)] mb-3 max-w-prose">
                    {u.description}
                  </p>
                  <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-1">
                    Project shapes
                  </p>
                  <ul class="list-disc list-inside text-sm text-[var(--color-text-muted)] space-y-1">
                    {u.project_shapes.map((shape) => (
                      <li>{shape}</li>
                    ))}
                  </ul>
                </li>
              );
            })
          }
        </ul>
      </section>
    </div>

    <!-- Layer rollup tab -->
    <div data-grants-page-panel="rollup" class="hidden">
      <section class="my-8">
        <h2 class="font-serif text-2xl mb-2">
          Funded vs. underfunded, by layer
        </h2>
        <p
          class="text-sm text-[var(--color-text-muted)] mb-6 max-w-prose"
        >
          Per-layer rollup of grants flowing in versus named gaps in
          the ecosystem. "High-priority gap" counts underfunded areas
          marked as having credible budgets and near-term impact in
          <code class="text-xs">data/underfunded.yaml</code>.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-[var(--color-surface-warm)] text-left">
                <th class="border border-[var(--color-border)] px-3 py-2 font-semibold">Layer</th>
                <th class="border border-[var(--color-border)] px-3 py-2 font-semibold text-right">Grants</th>
                <th class="border border-[var(--color-border)] px-3 py-2 font-semibold text-right">Funders</th>
                <th class="border border-[var(--color-border)] px-3 py-2 font-semibold text-right">USD documented</th>
                <th class="border border-[var(--color-border)] px-3 py-2 font-semibold text-right">Gaps</th>
                <th class="border border-[var(--color-border)] px-3 py-2 font-semibold text-right">High-priority gaps</th>
              </tr>
            </thead>
            <tbody>
              {
                layerRollupRows.map(({ layer, row }) => (
                  <tr class="hover:bg-[var(--color-surface-warm)]">
                    <td class="border border-[var(--color-border)] px-3 py-2">
                      <a
                        href={`/stack/${layer.slug}`}
                        class="no-underline hover:underline font-medium"
                      >
                        {layer.title}
                      </a>
                      <span
                        class="ml-2 font-mono text-[10px] uppercase tracking-wider"
                        style={`color: ${layers.core.find((l) => l.slug === layer.slug) ? "var(--color-tier-core)" : "var(--color-tier-meta)"}`}
                      >
                        {layers.core.find((l) => l.slug === layer.slug) ? "core" : "meta"}
                      </span>
                    </td>
                    <td class="border border-[var(--color-border)] px-3 py-2 text-right font-mono">
                      {row.grant_count}
                    </td>
                    <td class="border border-[var(--color-border)] px-3 py-2 text-right font-mono">
                      {row.funders.size}
                    </td>
                    <td class="border border-[var(--color-border)] px-3 py-2 text-right font-mono">
                      {formatUsd(row.total_usd)}
                    </td>
                    <td class="border border-[var(--color-border)] px-3 py-2 text-right font-mono">
                      {row.underfunded_count}
                    </td>
                    <td class="border border-[var(--color-border)] px-3 py-2 text-right font-mono">
                      {row.underfunded_high_count}
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <p class="text-xs text-[var(--color-text-subtle)] mt-3">
          One grant can span multiple layers (e.g., OMAI hits weights +
          data + compute), so the grant count column sums to more than
          the absolute number of documented grants.
        </p>
      </section>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Page-level tab switcher. Reads/writes window.location.hash so a
  // tab selection survives reload and is shareable.
  (function () {
    const root = document.getElementById("grants-page");
    if (!root) return;
    const tabs = Array.from(root.querySelectorAll("[data-grants-page-tab]"));
    const panels = Array.from(
      root.querySelectorAll("[data-grants-page-panel]"),
    );
    const ALLOWED = new Set(["grants", "funders", "gaps", "rollup"]);

    function setActive(name) {
      if (!ALLOWED.has(name)) name = "grants";
      for (const t of tabs) {
        const on = t.dataset.grantsPageTab === name;
        t.setAttribute("aria-selected", on ? "true" : "false");
        if (on) {
          t.classList.add(
            "bg-[var(--color-accent-soft)]",
            "text-[var(--color-accent)]",
          );
          t.classList.remove(
            "text-[var(--color-text-muted)]",
            "hover:bg-[var(--color-surface-warm)]",
          );
        } else {
          t.classList.remove(
            "bg-[var(--color-accent-soft)]",
            "text-[var(--color-accent)]",
          );
          t.classList.add(
            "text-[var(--color-text-muted)]",
            "hover:bg-[var(--color-surface-warm)]",
          );
        }
      }
      for (const p of panels) {
        const on = p.dataset.grantsPagePanel === name;
        p.classList.toggle("hidden", !on);
      }
      // Reflect in hash without scrolling.
      const hashTarget = name === "grants" ? "" : "#" + name;
      if (window.location.hash !== hashTarget) {
        history.replaceState(null, "", window.location.pathname + hashTarget);
      }
    }

    for (const t of tabs) {
      t.addEventListener("click", () => setActive(t.dataset.grantsPageTab));
    }
    window.addEventListener("hashchange", () => {
      setActive(window.location.hash.replace(/^#/, ""));
    });

    // Initial state from hash, or default.
    const initial = window.location.hash.replace(/^#/, "");
    if (initial) setActive(initial);
  })();
</script>
