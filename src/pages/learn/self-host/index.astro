---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const all = await getCollection("self_host_modules");
const modules = all
  .map((m) => ({ ...m.data, id: m.id }))
  .sort((a, b) => a.order - b.order);
---

<BaseLayout
  title="Self-host the stack · Learn"
  description="A practical course on running LLMs locally and in production: VRAM math, memory bandwidth tiers, quantization formats, inference engines, hardware strategy, production serving, benchmarking."
>
  <section class="max-w-3xl mx-auto px-6 pt-20 pb-2">
    <a
      href="/learn"
      class="inline-block font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] hover:text-[var(--color-text)] no-underline mb-4"
    >
      ← All learn tracks
    </a>
    <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4">
      Self-host track
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-3"
    >
      Self-host the stack
    </h1>
    <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-prose mb-3">
      A practical companion to the stack walk. The stack-walk track teaches what each layer is;
      this one teaches how to actually run the stack on hardware you control. Read in order or
      pick the module that answers the question you have right now.
    </p>
    <p class="text-sm text-[var(--color-text-subtle)] max-w-prose">
      Inspired by the
      <a href="https://x.com/TheAhmadOsman" target="_blank" rel="noopener" class="text-[var(--color-text)] hover:underline">@TheAhmadOsman</a>
      "Self-hosted LLMs / Local AI" series:
      <a href="https://x.com/TheAhmadOsman/status/2041331757329285589" target="_blank" rel="noopener" class="hover:underline">GPU Memory Math</a>,
      <a href="https://x.com/TheAhmadOsman/status/2040103488714068245" target="_blank" rel="noopener" class="hover:underline">Memory Bandwidth</a>, and
      <a href="https://x.com/TheAhmadOsman/status/2057183854444843202" target="_blank" rel="noopener" class="hover:underline">LLM Inference Engines</a>.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 mt-8 mb-16">
    <div id="self-host-progress-summary" class="font-mono text-xs text-[var(--color-text-subtle)] mb-3" data-total={modules.length}></div>
    <ol class="border-t border-[var(--color-border)]">
      {
        modules.map((m) => (
          <li>
            <a
              href={`/learn/self-host/${m.slug}`}
              title={m.one_liner}
              class="self-host-module-row flex items-baseline gap-3 py-3 px-1 border-b border-[var(--color-border)] hover:bg-[var(--color-surface-warm)] no-underline group"
              data-slug={m.slug}
            >
              <span class="font-mono text-xs text-[var(--color-text-subtle)] w-6 shrink-0">
                {String(m.order).padStart(2, "0")}
              </span>
              <span class="flex-1">
                <span class="block font-serif text-base text-[var(--color-text)] group-hover:text-[var(--color-accent)] mb-0.5">
                  {m.title}
                </span>
                <span class="block text-xs text-[var(--color-text-muted)] leading-snug">
                  {m.one_liner}
                </span>
              </span>
              <span class="self-host-status font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-subtle)] shrink-0"></span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <script>
    // Hydrate per-module completion badges + a summary count from
    // module_progress. Anonymous visitors see no badges (and no
    // summary line); the section still works as a plain list.
    import { browserSupabase } from "../../../lib/course/supabase";

    (async () => {
      const sb = browserSupabase();
      if (!sb) return;
      const { data: u } = await sb.auth.getUser();
      const userId = u?.user?.id;
      if (!userId) return;

      const rows = Array.from(document.querySelectorAll<HTMLAnchorElement>(".self-host-module-row"));
      const slugs = rows.map((r) => r.dataset.slug!).filter(Boolean);
      const { data } = await sb.from("module_progress")
        .select("module_slug, phase")
        .eq("user_id", userId)
        .in("module_slug", slugs);
      const byModule = new Map<string, string>((data ?? []).map((r) => [r.module_slug, r.phase]));

      let complete = 0;
      for (const r of rows) {
        const slug = r.dataset.slug!;
        const phase = byModule.get(slug);
        const status = r.querySelector(".self-host-status");
        if (!status) continue;
        if (phase === "complete") {
          status.textContent = "✓ read";
          status.classList.add("text-[var(--color-status-fresh)]");
          complete++;
        }
      }

      const summary = document.getElementById("self-host-progress-summary");
      const total = summary?.dataset.total;
      if (summary && total) {
        summary.textContent = `${complete} of ${total} read`;
      }
    })();
  </script>
</BaseLayout>
