---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadLayers } from "../../lib/layers";
import { getCollection } from "astro:content";

const { user, supabase } = Astro.locals;

// Load self-host modules so the track card can show count + progress.
const selfHostRaw = await getCollection("self_host_modules");
const SELF_HOST_MODULES = selfHostRaw
  .map((m) => ({ ...m.data }))
  .sort((a, b) => a.order - b.order);
const SELF_HOST_SLUGS = new Set(SELF_HOST_MODULES.map((m) => m.slug));

// Load how-llms-work modules so the track card can show count + progress.
const howRaw = await getCollection("how_llms_work_modules");
const HOW_LLMS_WORK_MODULES = howRaw
  .map((m) => ({ ...m.data }))
  .sort((a, b) => a.order - b.order);
const HOW_SLUGS = new Set(HOW_LLMS_WORK_MODULES.map((m) => m.slug));

// If logged in, prefill the depth picker with their saved choice and
// load progress so we can show a "continue" CTA and per-module
// completion badges. Falls through to anonymous defaults if any of
// the queries error (e.g. migration not applied yet).
let currentPassChoice: "fast" | "deep" = "fast";
let displayName: string | null = null;
type ProgressRow = {
  module_slug: string;
  phase: string;
  jumped: boolean;
};
const progressBySlug = new Map<string, ProgressRow>();
let totalComplete = 0;
let nextSlug: string | null = null;
let inProgressSlug: string | null = null;

if (user && supabase) {
  const [{ data: profile }, { data: progressRows }] = await Promise.all([
    supabase
      .from("profiles")
      .select("display_name, pass_choice")
      .eq("user_id", user.id)
      .maybeSingle(),
    supabase
      .from("module_progress")
      .select("module_slug, phase, jumped")
      .eq("user_id", user.id),
  ]);
  if (profile?.pass_choice === "fast" || profile?.pass_choice === "deep") {
    currentPassChoice = profile.pass_choice;
  }
  displayName = profile?.display_name ?? (user.email ? user.email.split("@")[0] : null);
  for (const r of progressRows ?? []) {
    progressBySlug.set(r.module_slug, r as ProgressRow);
    if (r.phase === "complete") totalComplete++;
  }
}

const layers = loadLayers();
const allLayers = [...layers.core, ...layers.meta];
const layerBySlug = Object.fromEntries(allLayers.map((l) => [l.slug, l]));

// Course module list. Currently the 15 modules are defined inline here;
// once the course_modules content collection is wired, this loads from
// MDX. (Each module corresponds to one or more existing layer slugs.)
interface Module {
  order: number;
  slug: string;
  title: string;
  layer_slugs: string[];
  type: "core" | "meta" | "capstone";
  one_liner: string;
}

// Module list (also used for nextSlug computation below).
const MODULES: Module[] = [
  { order: 1, slug: "infrastructure", layer_slugs: ["infrastructure"], type: "core", title: "Infrastructure", one_liner: "Data centers, power, cooling, and the grid that runs the rest of the stack." },
  { order: 2, slug: "silicon", layer_slugs: ["silicon"], type: "core", title: "Silicon", one_liner: "Chips and ISAs that execute the math." },
  { order: 3, slug: "compute", layer_slugs: ["compute"], type: "core", title: "Compute", one_liner: "Where silicon physically runs and gets accessed." },
  { order: 4, slug: "data", layer_slugs: ["data"], type: "core", title: "Data", one_liner: "Training corpora, open and closed." },
  { order: 5, slug: "training", layer_slugs: ["training"], type: "core", title: "Training", one_liner: "Tools to pretrain and fine-tune." },
  { order: 6, slug: "weights", layer_slugs: ["weights"], type: "core", title: "Weights", one_liner: "Model artifacts and their license tiers." },
  { order: 7, slug: "evaluation", layer_slugs: ["evaluation"], type: "meta", title: "Evaluation", one_liner: "Benchmarks, harnesses, leaderboards." },
  { order: 8, slug: "governance", layer_slugs: ["governance"], type: "meta", title: "Governance", one_liner: "Licensing, definitions, foundations, OSAID." },
  { order: 9, slug: "runtime", layer_slugs: ["runtime"], type: "core", title: "Runtime", one_liner: "Inference engines that serve tokens from weights." },
  { order: 10, slug: "identity-trust", layer_slugs: ["identity-trust"], type: "meta", title: "Identity and Trust", one_liner: "TEEs, confidential computing, verifiable inference." },
  { order: 11, slug: "retrieval-memory", layer_slugs: ["retrieval-memory"], type: "core", title: "Retrieval and Memory", one_liner: "Vector databases, embeddings, agent memory, RAG." },
  { order: 12, slug: "agents", layer_slugs: ["agents"], type: "core", title: "Agents", one_liner: "Frameworks and agent products." },
  { order: 13, slug: "safety-guardrails", layer_slugs: ["safety-guardrails"], type: "meta", title: "Safety and Guardrails", one_liner: "Llama Guard, NeMo Guardrails, sandbox-escape evals." },
  { order: 14, slug: "protocols", layer_slugs: ["protocols"], type: "core", title: "Protocols", one_liner: "MCP, A2A, agentic payments, the integration wire." },
  { order: 15, slug: "sovereignty-decentralization", layer_slugs: ["sovereignty-decentralization"], type: "capstone", title: "Sovereignty and Decentralization (Capstone)", one_liner: "The synthesis: assemble your own theory of why open AI matters." },
];

// Stack-walk progress: only count rows whose slug belongs to the
// 15-module track (self-host module slugs share the same table but
// are different identifiers).
const STACK_SLUGS = new Set(MODULES.map((m) => m.slug));
let stackComplete = 0;
let stackInProgressSlug: string | null = null;
let stackNextSlug: string | null = null;
let selfHostComplete = 0;
let selfHostNextSlug: string | null = null;
let howComplete = 0;
let howNextSlug: string | null = null;

if (user) {
  for (const [slug, p] of progressBySlug.entries()) {
    if (STACK_SLUGS.has(slug) && p.phase === "complete") stackComplete++;
    if (SELF_HOST_SLUGS.has(slug) && p.phase === "complete") selfHostComplete++;
    if (HOW_SLUGS.has(slug) && p.phase === "complete") howComplete++;
  }
  // Re-derive totalComplete from the stack-walk only (the earlier
  // counter was per-row regardless of track).
  totalComplete = stackComplete;
  for (const m of MODULES) {
    const p = progressBySlug.get(m.slug);
    if (p && p.phase !== "complete" && p.phase !== "read") {
      stackInProgressSlug = m.slug;
      break;
    }
  }
  for (const m of MODULES) {
    const p = progressBySlug.get(m.slug);
    if (!p || p.phase !== "complete") {
      stackNextSlug = m.slug;
      break;
    }
  }
  for (const m of SELF_HOST_MODULES) {
    const p = progressBySlug.get(m.slug);
    if (!p || p.phase !== "complete") {
      selfHostNextSlug = m.slug;
      break;
    }
  }
  for (const m of HOW_LLMS_WORK_MODULES) {
    const p = progressBySlug.get(m.slug);
    if (!p || p.phase !== "complete") {
      howNextSlug = m.slug;
      break;
    }
  }
}

// Stack-walk resume target.
inProgressSlug = stackInProgressSlug;
nextSlug = stackNextSlug;
const stackPercent = Math.round((stackComplete / MODULES.length) * 100);
const stackResumeSlug = stackInProgressSlug ?? stackNextSlug ?? MODULES[0].slug;
const stackResumeModule = MODULES.find((m) => m.slug === stackResumeSlug) ?? MODULES[0];

// Self-host resume target.
const selfHostPercent = SELF_HOST_MODULES.length > 0
  ? Math.round((selfHostComplete / SELF_HOST_MODULES.length) * 100)
  : 0;
const selfHostResumeSlug = selfHostNextSlug ?? SELF_HOST_MODULES[0]?.slug;
const selfHostResumeModule = SELF_HOST_MODULES.find((m) => m.slug === selfHostResumeSlug) ?? SELF_HOST_MODULES[0];

// How-LLMs-work resume target.
const howPercent = HOW_LLMS_WORK_MODULES.length > 0
  ? Math.round((howComplete / HOW_LLMS_WORK_MODULES.length) * 100)
  : 0;
const howResumeSlug = howNextSlug ?? HOW_LLMS_WORK_MODULES[0]?.slug;
const howResumeModule = HOW_LLMS_WORK_MODULES.find((m) => m.slug === howResumeSlug) ?? HOW_LLMS_WORK_MODULES[0];

// Backward-compat: existing JSX below still references these names.
const progressPercent = stackPercent;
const resumeSlug = stackResumeSlug;
const resumeModule = stackResumeModule;

function progressBadge(slug: string): { label: string; cls: string } | null {
  const p = progressBySlug.get(slug);
  if (!p) return null;
  if (p.phase === "complete") return { label: "complete", cls: "bg-[var(--color-status-fresh)] text-white" };
  if (p.phase === "read") return null;
  return { label: p.phase.replace("_", " "), cls: "bg-[var(--color-accent-soft)] text-[var(--color-accent)] border border-[var(--color-border)]" };
}
---

<BaseLayout
  title="Learn"
  description="Self-paced Socratic course on the open-source AI stack: a guided path from infrastructure up to protocols, building your own theory of why openness matters at each layer."
>
  <section class="max-w-3xl mx-auto px-6 pt-20 pb-2">
    {!user && (
      <div class="mb-6 flex flex-wrap items-center justify-between gap-3 px-4 py-3 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-surface-warm)]">
        <p class="text-sm text-[var(--color-text)] leading-snug">
          <span class="font-medium">Track your progress.</span>
          <span class="text-[var(--color-text-muted)]"> Log in to sync your course progress, notes, and chat history across devices.</span>
        </p>
        <div class="flex items-center gap-2 shrink-0">
          <a
            href="/learn/login"
            class="inline-block px-3 py-1.5 rounded-md bg-[var(--color-accent-strong)] text-white text-sm font-medium hover:bg-[var(--color-accent)] no-underline"
          >
            Log in
          </a>
          <a
            href="/learn/signup"
            class="inline-block px-3 py-1.5 rounded-md border border-[var(--color-border-strong)] text-[var(--color-text)] text-sm font-medium hover:bg-[var(--color-surface)] no-underline"
          >
            Sign up
          </a>
        </div>
      </div>
    )}
    {user && (
      <div class="mb-6 flex flex-wrap items-baseline gap-x-3 gap-y-1 font-mono text-xs text-[var(--color-text-subtle)]">
        <span>Signed in as <span class="text-[var(--color-text)]">{displayName}</span></span>
        <span aria-hidden="true">·</span>
        <a href="/learn/profile" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] no-underline hover:underline">
          Profile
        </a>
        <span aria-hidden="true">·</span>
        <form method="POST" action="/api/auth/logout" class="inline">
          <button type="submit" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] no-underline hover:underline bg-transparent border-0 p-0 font-mono text-xs cursor-pointer">
            Log out
          </button>
        </form>
      </div>
    )}
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-3"
    >
      Learn
    </h1>
    <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-prose">
      Three self-paced tracks. The first walks the stack layer by layer and why openness matters
      at each one. The second covers how LLMs actually work, the mechanics from the inference loop
      to fine-tuning. The third covers how to run the stack on hardware you control. Pick any; do
      all three, in any order.
    </p>
  </section>

  {
    user && (
      <script>
        // Anonymous-writings restore (E2EE): if we got here with
        // ?restore=anon and there are stashed entries in localStorage,
        // encrypt each entry client-side with the just-unlocked DK and
        // upsert directly to Supabase. The server never sees plaintext.
        import { browserSupabase } from "../../lib/course/supabase";
        import { encryptForStorage } from "../../lib/course/encrypted-io";
        import { loadDK } from "../../lib/crypto/keystore";
        import { MODULE_BY_SLUG } from "../../lib/course/modules";

        (async () => {
          const params = new URLSearchParams(window.location.search);
          if (params.get("restore") !== "anon") return;
          const clean = () => {
            params.delete("restore");
            const qs = params.toString();
            window.history.replaceState({}, "", "/learn" + (qs ? "?" + qs : ""));
          };
          const KEY = "oas-course-v1";
          let raw: string | null = null;
          try { raw = window.localStorage.getItem(KEY); } catch { /* ignore */ }
          if (!raw) { clean(); return; }

          // DK must be unlocked first; if it isn't, defer the restore (the
          // user can retry on next login). Don't write cleartext.
          const dk = await loadDK();
          if (!dk) { clean(); return; }
          const sb = browserSupabase();
          if (!sb) { clean(); return; }
          const { data: u } = await sb.auth.getUser();
          const userId = u?.user?.id;
          if (!userId) { clean(); return; }

          let payload: any;
          try { payload = JSON.parse(raw); } catch { clean(); return; }
          const modules = payload?.modules ?? {};
          for (const [moduleSlug, entry] of Object.entries(modules) as Array<[string, any]>) {
            if (!MODULE_BY_SLUG[moduleSlug]) continue;
            if (typeof entry?.synth === "string" && entry.synth.trim().length > 0) {
              const body_enc = await encryptForStorage(entry.synth.trim());
              await sb.from("synthesize_notes").upsert({
                user_id: userId, module_slug: moduleSlug, body_enc,
              });
            }
            if (typeof entry?.why_open_saved === "string" && entry.why_open_saved.trim().length > 0) {
              const body_enc = await encryptForStorage(entry.why_open_saved.trim());
              await sb.from("why_open_notes").upsert({
                user_id: userId, module_slug: moduleSlug, body_enc,
              });
            }
            for (const [phase, turns] of Object.entries(entry?.chat ?? {})) {
              if (!Array.isArray(turns)) continue;
              for (const t of turns) {
                if (!t || (t.role !== "user" && t.role !== "assistant")) continue;
                const content_enc = await encryptForStorage(String(t.content ?? ""));
                await sb.from("chat_turns").insert({
                  user_id: userId,
                  module_slug: moduleSlug,
                  phase: phase as any,
                  role: t.role,
                  content_enc,
                  turn_index: t.turn_index ?? 0,
                });
              }
            }
          }

          try { window.localStorage.removeItem(KEY); } catch { /* ignore */ }
          clean();
        })();
      </script>
    )
  }
  {/* Two parallel track cards. Each is independently navigable and
      shows its own progress + CTA for logged-in users. Stack-walk has
      both progress and a depth-picker form (because the form's POST
      action is what initializes a brand-new course); self-host is a
      simpler standalone-content track and links straight in. */}
  <section class="max-w-6xl mx-auto px-6 mt-8 mb-10">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {/* Track 1: Walk the stack (Socratic 15-module course) */}
      <div class="p-5 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-surface)] flex flex-col relative group">
        <div class="flex items-baseline justify-between gap-3 flex-wrap mb-1">
          <span class="font-serif text-xl text-[var(--color-text)]">
            Walk the stack
          </span>
          <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-subtle)]">
            15 modules · Socratic
          </span>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">
          Bottom-up from infrastructure to protocols. Each module ends with a Probe dialog and you
          writing your own summary; the course produces a downloadable map of what you learned.
        </p>
        {user ? (
          <div class="mt-auto">
            <p class="text-xs text-[var(--color-text-muted)] mb-2 font-mono">
              {stackComplete} of {MODULES.length} complete
              <span class="text-[var(--color-text-subtle)]"> · {stackPercent}%</span>
              <span class="text-[var(--color-text-subtle)]"> · {currentPassChoice} pass</span>
            </p>
            <div class="h-1.5 w-full rounded-full bg-[var(--color-surface-warm)] mb-4 overflow-hidden">
              <div
                class="h-full bg-[var(--color-text)]"
                style={`width: ${stackPercent}%`}
                aria-label={`${stackPercent}% complete`}
              ></div>
            </div>
            {stackComplete < MODULES.length ? (
              <a
                href={`/learn/${stackResumeSlug}`}
                class="inline-block w-full px-4 py-2 rounded-md bg-[var(--color-accent-strong)] text-white text-sm font-medium hover:bg-[var(--color-accent)] no-underline text-center"
              >
                {stackInProgressSlug ? "Resume" : (stackComplete > 0 ? "Continue" : "Begin")}
                {" module "}{String(stackResumeModule.order).padStart(2, "0")} →
              </a>
            ) : (
              <a
                href="/learn/profile/notes"
                class="inline-block w-full px-4 py-2 rounded-md bg-[var(--color-accent-strong)] text-white text-sm font-medium hover:bg-[var(--color-accent)] no-underline text-center"
              >
                View your Personal Notes →
              </a>
            )}
            <a
              href="/learn/walk"
              class="block mt-3 text-center text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)] no-underline"
            >
              See all {MODULES.length} modules →
            </a>
          </div>
        ) : (
          <form
            method="POST"
            action={`/api/course/start?next=/learn/${MODULES[0].slug}`}
            class="mt-auto"
          >
            <div class="flex flex-col gap-2 mb-3 text-sm">
              <label class="inline-flex items-baseline gap-2 cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)]">
                <input type="radio" name="pass_choice" value="fast" checked={currentPassChoice === "fast"} class="accent-[var(--color-accent)]"/>
                <span><span class="text-[var(--color-text)] font-medium">Fast pass</span><span class="text-[var(--color-text-subtle)] text-xs"> · a day or two</span></span>
              </label>
              <label class="inline-flex items-baseline gap-2 cursor-pointer text-[var(--color-text-muted)] hover:text-[var(--color-text)]">
                <input type="radio" name="pass_choice" value="deep" checked={currentPassChoice === "deep"} class="accent-[var(--color-accent)]"/>
                <span><span class="text-[var(--color-text)] font-medium">Deep pass</span><span class="text-[var(--color-text-subtle)] text-xs"> · about a week</span></span>
              </label>
            </div>
            <button
              type="submit"
              class="w-full px-4 py-2 rounded-md bg-[var(--color-accent-strong)] text-white text-sm font-medium hover:bg-[var(--color-accent)] cursor-pointer"
            >
              Begin module 01 · {MODULES[0].title} →
            </button>
            <a
              href="/learn/walk"
              class="block mt-3 text-center text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)] no-underline"
            >
              See all {MODULES.length} modules →
            </a>
          </form>
        )}
        {/* Desktop hover popover: module index */}
        <div
          aria-hidden="true"
          class="hidden md:block absolute left-0 right-0 top-full z-30 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-opacity duration-150 ease-out"
        >
          <div class="p-4 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-surface)] shadow-lg max-h-[24rem] overflow-y-auto">
            <p class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-subtle)] mb-3">
              Modules
            </p>
            <ol class="space-y-2.5">
              {MODULES.map((m) => {
                const progress = progressBySlug.get(m.slug);
                const isComplete = progress?.phase === "complete";
                const isStarted = !!progress && !isComplete;
                return (
                  <li>
                    <a
                      href={`/learn/${m.slug}`}
                      class="grid grid-cols-[20px_1fr] gap-2.5 items-baseline no-underline group/row"
                    >
                      <span
                        class={`font-mono text-[10px] tabular-nums ${isComplete ? "text-[var(--color-status-fresh)]" : isStarted ? "text-[var(--color-accent-strong)]" : "text-[var(--color-text-subtle)]"}`}
                      >
                        {isComplete ? "✓" : String(m.order).padStart(2, "0")}
                      </span>
                      <div class="min-w-0">
                        <div
                          class={`text-[12px] leading-tight ${isComplete ? "text-[var(--color-text-muted)]" : "text-[var(--color-text)]"} group-hover/row:text-[var(--color-accent-strong)] transition-colors`}
                        >
                          {m.title}
                        </div>
                        <div class="text-[11px] text-[var(--color-text-muted)] leading-snug truncate font-mono mt-0.5">
                          {m.one_liner}
                        </div>
                      </div>
                    </a>
                  </li>
                );
              })}
            </ol>
          </div>
        </div>
      </div>

      {/* Track 2: How LLMs work */}
      <div class="p-5 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-surface)] flex flex-col relative group">
        <div class="flex items-baseline justify-between gap-3 flex-wrap mb-1">
          <span class="font-serif text-xl text-[var(--color-text)]">
            How LLMs work
          </span>
          <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-subtle)]">
            {HOW_LLMS_WORK_MODULES.length} modules · mechanics
          </span>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">
          The model-side foundation. Tokens, transformers, attention, the KV cache, decoding, chat
          templates, long context, RAG, tool use, fine-tuning. Start with the loop; the rest follows.
        </p>
        <div class="mt-auto">
          {user && (
            <>
              <p class="text-xs text-[var(--color-text-muted)] mb-2 font-mono">
                {howComplete} of {HOW_LLMS_WORK_MODULES.length} complete
                <span class="text-[var(--color-text-subtle)]"> · {howPercent}%</span>
              </p>
              <div class="h-1.5 w-full rounded-full bg-[var(--color-surface-warm)] mb-4 overflow-hidden">
                <div
                  class="h-full bg-[var(--color-text)]"
                  style={`width: ${howPercent}%`}
                  aria-label={`${howPercent}% complete`}
                ></div>
              </div>
            </>
          )}
          {howResumeModule ? (
            <a
              href={`/learn/how-llms-work/${howResumeSlug}`}
              class="inline-block w-full px-4 py-2 rounded-md bg-[var(--color-accent-strong)] text-white text-sm font-medium hover:bg-[var(--color-accent)] no-underline text-center"
            >
              {user && howComplete === HOW_LLMS_WORK_MODULES.length
                ? "Review the track"
                : user && howComplete > 0
                  ? `Continue module ${String(howResumeModule.order).padStart(2, "0")} →`
                  : `Begin module 01 · ${howResumeModule.title} →`}
            </a>
          ) : (
            <a
              href="/learn/how-llms-work"
              class="inline-block w-full px-4 py-2 rounded-md bg-[var(--color-accent-strong)] text-white text-sm font-medium hover:bg-[var(--color-accent)] no-underline text-center"
            >
              Open the track →
            </a>
          )}
          <a
            href="/learn/how-llms-work"
            class="block mt-3 text-center text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)] no-underline"
          >
            See all {HOW_LLMS_WORK_MODULES.length} modules →
          </a>
        </div>
        {/* Desktop hover popover: module index */}
        <div
          aria-hidden="true"
          class="hidden md:block absolute left-0 right-0 top-full z-30 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-opacity duration-150 ease-out"
        >
          <div class="p-4 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-surface)] shadow-lg max-h-[24rem] overflow-y-auto">
            <p class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-subtle)] mb-3">
              Modules
            </p>
            <ol class="space-y-2.5">
              {HOW_LLMS_WORK_MODULES.map((m) => {
                const progress = progressBySlug.get(m.slug);
                const isComplete = progress?.phase === "complete";
                const isStarted = !!progress && !isComplete;
                return (
                  <li>
                    <a
                      href={`/learn/how-llms-work/${m.slug}`}
                      class="grid grid-cols-[20px_1fr] gap-2.5 items-baseline no-underline group/row"
                    >
                      <span
                        class={`font-mono text-[10px] tabular-nums ${isComplete ? "text-[var(--color-status-fresh)]" : isStarted ? "text-[var(--color-accent-strong)]" : "text-[var(--color-text-subtle)]"}`}
                      >
                        {isComplete ? "✓" : String(m.order).padStart(2, "0")}
                      </span>
                      <div class="min-w-0">
                        <div
                          class={`text-[12px] leading-tight ${isComplete ? "text-[var(--color-text-muted)]" : "text-[var(--color-text)]"} group-hover/row:text-[var(--color-accent-strong)] transition-colors`}
                        >
                          {m.title}
                        </div>
                        <div class="text-[11px] text-[var(--color-text-muted)] leading-snug truncate font-mono mt-0.5">
                          {m.one_liner}
                        </div>
                      </div>
                    </a>
                  </li>
                );
              })}
            </ol>
          </div>
        </div>
      </div>

      {/* Track 3: Self-host the stack */}
      <div class="p-5 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-surface)] flex flex-col relative group">
        <div class="flex items-baseline justify-between gap-3 flex-wrap mb-1">
          <span class="font-serif text-xl text-[var(--color-text)]">
            Self-host the stack
          </span>
          <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-subtle)]">
            {SELF_HOST_MODULES.length} modules · practical
          </span>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">
          VRAM math, memory bandwidth tiers, quantization formats, inference engines, hardware
          strategy, production serving, benchmarking. Skim or read in order.
        </p>
        <div class="mt-auto">
          {user && (
            <>
              <p class="text-xs text-[var(--color-text-muted)] mb-2 font-mono">
                {selfHostComplete} of {SELF_HOST_MODULES.length} complete
                <span class="text-[var(--color-text-subtle)]"> · {selfHostPercent}%</span>
              </p>
              <div class="h-1.5 w-full rounded-full bg-[var(--color-surface-warm)] mb-4 overflow-hidden">
                <div
                  class="h-full bg-[var(--color-text)]"
                  style={`width: ${selfHostPercent}%`}
                  aria-label={`${selfHostPercent}% complete`}
                ></div>
              </div>
            </>
          )}
          {selfHostResumeModule ? (
            <a
              href={`/learn/self-host/${selfHostResumeSlug}`}
              class="inline-block w-full px-4 py-2 rounded-md bg-[var(--color-accent-strong)] text-white text-sm font-medium hover:bg-[var(--color-accent)] no-underline text-center"
            >
              {user && selfHostComplete === SELF_HOST_MODULES.length
                ? "Review the track"
                : user && selfHostComplete > 0
                  ? `Continue module ${String(selfHostResumeModule.order).padStart(2, "0")} →`
                  : `Begin module 01 · ${selfHostResumeModule.title} →`}
            </a>
          ) : (
            <a
              href="/learn/self-host"
              class="inline-block w-full px-4 py-2 rounded-md bg-[var(--color-accent-strong)] text-white text-sm font-medium hover:bg-[var(--color-accent)] no-underline text-center"
            >
              Open the track →
            </a>
          )}
          <a
            href="/learn/self-host"
            class="block mt-3 text-center text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)] no-underline"
          >
            See all {SELF_HOST_MODULES.length} modules →
          </a>
        </div>
        {/* Desktop hover popover: module index */}
        <div
          aria-hidden="true"
          class="hidden md:block absolute left-0 right-0 top-full z-30 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-opacity duration-150 ease-out"
        >
          <div class="p-4 rounded-md border border-[var(--color-border-strong)] bg-[var(--color-surface)] shadow-lg max-h-[24rem] overflow-y-auto">
            <p class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-subtle)] mb-3">
              Modules
            </p>
            <ol class="space-y-2.5">
              {SELF_HOST_MODULES.map((m) => {
                const progress = progressBySlug.get(m.slug);
                const isComplete = progress?.phase === "complete";
                const isStarted = !!progress && !isComplete;
                return (
                  <li>
                    <a
                      href={`/learn/self-host/${m.slug}`}
                      class="grid grid-cols-[20px_1fr] gap-2.5 items-baseline no-underline group/row"
                    >
                      <span
                        class={`font-mono text-[10px] tabular-nums ${isComplete ? "text-[var(--color-status-fresh)]" : isStarted ? "text-[var(--color-accent-strong)]" : "text-[var(--color-text-subtle)]"}`}
                      >
                        {isComplete ? "✓" : String(m.order).padStart(2, "0")}
                      </span>
                      <div class="min-w-0">
                        <div
                          class={`text-[12px] leading-tight ${isComplete ? "text-[var(--color-text-muted)]" : "text-[var(--color-text)]"} group-hover/row:text-[var(--color-accent-strong)] transition-colors`}
                        >
                          {m.title}
                        </div>
                        <div class="text-[11px] text-[var(--color-text-muted)] leading-snug truncate font-mono mt-0.5">
                          {m.one_liner}
                        </div>
                      </div>
                    </a>
                  </li>
                );
              })}
            </ol>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Per-module list intentionally removed. With two tracks, the full
      module index for each lives on its track page (/learn/<slug> for
      the stack walk, /learn/self-host for self-host). The two cards
      above are the entry points; click into a track to see its modules. */}
</BaseLayout>
