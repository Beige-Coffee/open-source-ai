---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

const { user } = Astro.locals;

// Already-logged-in users go to the course landing.
if (user) {
  return Astro.redirect("/learn");
}

/** Mirror of signup's resolveLoginEmail. If the identifier doesn't
 *  contain "@" we treat it as a username and look it up against the
 *  synthesized `@oas.local` host. Keeping the two functions parallel
 *  rather than DRY-ed because the signup file also reads it server-
 *  side and importing across .astro frontmatter would need a shared
 *  helper module; punt that until we add a third caller. */
function resolveLoginEmail(raw: string): string {
  const trimmed = raw.trim();
  if (trimmed.includes("@")) return trimmed;
  const slug = trimmed.toLowerCase().replace(/[^a-z0-9._-]/g, "");
  return `${slug}@oas.local`;
}

// On POST, attempt sign-in via Supabase. Email/username + password.
let errorMessage: string | null = null;
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const identifier = String(form.get("identifier") ?? "").trim();
  const password = String(form.get("password") ?? "");
  if (!identifier || !password) {
    errorMessage = "Username (or email) and password are both required.";
  } else {
    const email = resolveLoginEmail(identifier);
    const { error } = await Astro.locals.supabase.auth.signInWithPassword({
      email,
      password,
    });
    if (error) {
      errorMessage = error.message;
    } else {
      // Send the user to /learn with a restore sentinel so the client
      // promotes any anonymous localStorage writings to their account.
      // The /learn promote script is idempotent and a no-op if there's
      // nothing in localStorage, so this is safe for repeat logins.
      return Astro.redirect("/learn?restore=anon");
    }
  }
}
---

<BaseLayout title="Log in to /learn" description="Log in to track your progress through the open-source AI stack course.">
  <section class="max-w-md mx-auto px-6 pt-16 pb-12">
    <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-3">
      Course
    </p>
    <h1 class="font-serif text-3xl text-[var(--color-text)] mb-2">
      Log in
    </h1>
    <p class="text-sm text-[var(--color-text-muted)] mb-6 leading-relaxed">
      Sign in to save your progress and download your Personal Notes.
      Or <a href="/learn" class="text-[var(--color-text)] hover:no-underline">browse the course without an account</a>.
    </p>

    <form method="POST" class="space-y-4">
      {
        errorMessage && (
          <p class="text-sm text-red-700 border border-red-200 bg-red-50 px-3 py-2 rounded">
            {errorMessage}
          </p>
        )
      }
      <label class="block">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-text-subtle)] block mb-1">
          Email or username
        </span>
        <input
          type="text"
          name="identifier"
          required
          autocomplete="username"
          class="w-full px-3 py-2 border border-[var(--color-border-strong)] rounded-md bg-[var(--color-surface)] text-[var(--color-text)] text-sm"
        />
      </label>
      <label class="block">
        <span class="text-xs font-mono uppercase tracking-wider text-[var(--color-text-subtle)] block mb-1">
          Password
        </span>
        <input
          type="password"
          name="password"
          required
          autocomplete="current-password"
          minlength="8"
          class="w-full px-3 py-2 border border-[var(--color-border-strong)] rounded-md bg-[var(--color-surface)] text-[var(--color-text)] text-sm"
        />
      </label>
      <button
        type="submit"
        class="w-full px-4 py-2 rounded-md bg-[var(--color-accent-strong)] text-white text-sm font-medium hover:bg-[var(--color-accent)] cursor-pointer"
      >
        Log in
      </button>
    </form>

    <p class="text-sm text-[var(--color-text-muted)] mt-6 text-center">
      No account yet? <a href="/learn/signup" class="text-[var(--color-text)]">Sign up</a>.
    </p>
  </section>
</BaseLayout>
