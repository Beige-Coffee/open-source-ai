---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadLayers } from "../../lib/layers";
import {
  loadReadingsForLayer,
  loadReadings,
  typeLabel,
  type ReadingType,
} from "../../lib/reading-lists";

export async function getStaticPaths() {
  const layers = loadLayers();
  const all = [...layers.core, ...layers.meta];
  return all.map((layer) => ({
    params: { slug: layer.slug },
    props: { layer },
  }));
}

const { layer } = Astro.props;
const readings = loadReadingsForLayer(layer.slug);

// Group by type for the page sectioning. Predictable order.
const typeOrder: ReadingType[] = [
  "paper",
  "post",
  "talk",
  "podcast",
  "book",
  "docs",
  "thread",
];
const grouped: Record<string, typeof readings> = {};
for (const r of readings) {
  if (!grouped[r.type]) grouped[r.type] = [];
  grouped[r.type].push(r);
}
// Sort each group by year descending (recent first).
for (const t of Object.keys(grouped)) {
  grouped[t].sort((a, b) => b.year - a.year);
}

const tierLabel = layer.tier === "core" ? "Core layer" : "Cross-cutting meta-layer";
const tierColor =
  layer.tier === "core" ? "var(--color-tier-core)" : "var(--color-tier-meta)";
---

<BaseLayout
  title={`Learn ${layer.title}`}
  description={`Curated reading list for the ${layer.title} layer of the open-source AI stack.`}
>
  <section class="max-w-3xl mx-auto px-6 pt-12 pb-4">
    <p class="font-mono text-xs uppercase tracking-wider mb-2">
      <a
        href="/learn"
        class="no-underline hover:underline text-[var(--color-text-subtle)]"
        >Learn</a
      >
      <span class="text-[var(--color-text-subtle)]"> &middot; </span>
      <span style={`color: ${tierColor}`}>{tierLabel}</span>
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-4"
    >
      {layer.title}
    </h1>
    <p
      class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-prose"
    >
      {layer.short_description}
    </p>
    <p class="text-sm text-[var(--color-text-subtle)] font-mono mt-3">
      {readings.length} reads &middot; primary sources first
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-16">
    {
      readings.length === 0 ? (
        <p class="text-[var(--color-text-subtle)] italic mt-8">
          No reading list filed at this layer yet. Adding soon.
        </p>
      ) : (
        typeOrder
          .filter((t) => grouped[t] && grouped[t].length > 0)
          .map((t) => (
            <section class="mb-10">
              <h2 class="font-sans text-xl font-semibold mb-3">
                {typeLabel(t)}s
              </h2>
              <ul class="space-y-3">
                {grouped[t].map((r) => (
                  <li class="border border-[var(--color-border)] rounded-md px-4 py-3 bg-[var(--color-surface)]">
                    <div class="flex items-start justify-between gap-3 mb-1 flex-wrap">
                      <a
                        href={r.url}
                        target="_blank"
                        rel="noopener"
                        class="font-medium no-underline hover:underline text-[var(--color-text)]"
                      >
                        {r.title}
                      </a>
                      <span class="font-mono text-xs whitespace-nowrap text-[var(--color-text-subtle)]">
                        {r.year}
                      </span>
                    </div>
                    <p class="text-xs text-[var(--color-text-subtle)] mb-1 font-mono">
                      {r.source}
                    </p>
                    <p class="text-sm text-[var(--color-text-muted)] leading-snug">
                      {r.description}
                    </p>
                  </li>
                ))}
              </ul>
            </section>
          ))
      )
    }

    <p class="text-sm font-mono mt-8">
      <a href={`/stack/${layer.slug}`} class="no-underline hover:underline"
        >&larr; Back to the {layer.title} layer page</a
      >
    </p>
  </section>
</BaseLayout>
