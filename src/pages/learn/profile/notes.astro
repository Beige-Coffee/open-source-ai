---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { loadPersonalNotesCipher } from "../../../lib/course/notes";
import PersonalNotesView from "../../../components/PersonalNotesView.tsx";

const { user, supabase } = Astro.locals;
if (!user || !supabase) {
  return Astro.redirect("/learn/login");
}

// Server collects the encrypted document; decryption + render happens
// in the client island. The server never sees plaintext.
const cipherDoc = await loadPersonalNotesCipher(supabase, user.id, user.email ?? "");
---

<BaseLayout
  title="My Personal Notes"
  description="Your accumulated notes from the open-source AI stack course."
>
  <article class="max-w-3xl mx-auto px-6 pt-12 pb-16">
    <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-3">
      Personal Notes
    </p>
    <h1 class="font-serif text-4xl md:text-5xl text-[var(--color-text)] mb-2 leading-tight">
      My Open-Source AI Stack Notes
    </h1>

    <PersonalNotesView client:only="react" cipherDoc={cipherDoc} />
  </article>
</BaseLayout>
