---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { MODULES } from "../../lib/course/modules";

const { user, supabase } = Astro.locals;

let currentPassChoice: "fast" | "deep" = "fast";
if (user && supabase) {
  const { data } = await supabase
    .from("profiles")
    .select("pass_choice")
    .eq("user_id", user.id)
    .maybeSingle();
  if (data?.pass_choice === "fast" || data?.pass_choice === "deep") {
    currentPassChoice = data.pass_choice;
  }
}

const firstModule = MODULES[0];
---

<BaseLayout
  title="How this course works"
  description="Orientation and depth picker for the self-paced course on the open-source AI stack."
>
  <article class="max-w-3xl mx-auto px-6 pt-12 pb-16">
    <a
      href="/learn"
      class="inline-block font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] hover:text-[var(--color-text)] no-underline mb-3"
    >
      ← All modules
    </a>
    <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-3">
      Module 00 · Orientation
    </p>
    <h1 class="font-serif text-3xl md:text-4xl text-[var(--color-text)] mb-6 leading-tight">
      How this course works
    </h1>

    <section class="mb-10">
      <h2 class="font-serif text-xl text-[var(--color-text)] mb-3">
        What you're walking through
      </h2>
      <ul class="text-base text-[var(--color-text-muted)] leading-relaxed space-y-2 list-disc pl-5">
        <li>15 modules, bottom-up, from infrastructure to protocols.</li>
        <li>
          Meta-layers (evaluation, governance, identity-trust,
          safety-guardrails) are slotted where they first become
          load-bearing, not bundled at the end.
        </li>
        <li>
          The final module is the Sovereignty capstone: a synthesis
          drawing on what you wrote earlier.
        </li>
      </ul>
    </section>

    <section class="mb-10">
      <h2 class="font-serif text-xl text-[var(--color-text)] mb-3">
        How each module works
      </h2>
      <ul class="text-base text-[var(--color-text-muted)] leading-relaxed space-y-2 list-disc pl-5">
        <li>
          <strong class="text-[var(--color-text)]">Read</strong>: a focused
          passage with the layer's vocabulary and the editorial framing.
        </li>
        <li>
          <strong class="text-[var(--color-text)]">Probe</strong>: a Socratic
          dialogue with the course agent. The agent asks questions; it
          will not summarize for you.
        </li>
        <li>
          <strong class="text-[var(--color-text)]">Compare</strong>: walk
          through the major projects at this layer along axes the agent
          presents. You fill cells; the agent refuses to.
        </li>
        <li>
          <strong class="text-[var(--color-text)]">Why-Open</strong>: argue,
          in your own words, why open source matters at this layer. Vague
          answers get pushback.
        </li>
        <li>
          <strong class="text-[var(--color-text)]">Synthesize</strong>: you
          write the summary in your own words. The agent does a final
          check for missing concepts.
        </li>
      </ul>
    </section>

    <section class="mb-10">
      <h2 class="font-serif text-xl text-[var(--color-text)] mb-3">
        What you take home
      </h2>
      <ul class="text-base text-[var(--color-text-muted)] leading-relaxed space-y-2 list-disc pl-5">
        <li>
          A "My Open-Source AI Stack Notes" document at{" "}
          <a href="/learn/profile/notes" class="text-[var(--color-text)] hover:no-underline">
            /learn/profile/notes
          </a>: your synthesize + why-open writings, in order, downloadable as
          Markdown or PDF.
        </li>
        <li>
          Logged-in users keep their progress across devices; anonymous
          walkers keep work in this tab only.
        </li>
      </ul>
    </section>

    <section class="mb-10 p-5 border border-[var(--color-border-strong)] rounded-md bg-[var(--color-surface)]">
      <h2 class="font-serif text-xl text-[var(--color-text)] mb-2">
        Pick a depth
      </h2>
      <p class="text-sm text-[var(--color-text-muted)] mb-5 leading-relaxed">
        You can switch any time from{" "}
        <a href="/learn/profile" class="text-[var(--color-text)] hover:no-underline">
          /learn/profile
        </a>
        .
      </p>
      <form
        method="POST"
        action={`/api/course/start?next=/learn/${firstModule.slug}`}
        class="space-y-4"
      >
        <label class="flex items-baseline gap-3 p-3 border border-[var(--color-border)] rounded-md hover:border-[var(--color-border-strong)] cursor-pointer">
          <input
            type="radio"
            name="pass_choice"
            value="fast"
            checked={currentPassChoice === "fast"}
          />
          <span class="flex-1">
            <span class="block text-[var(--color-text)] font-medium">
              Fast pass
            </span>
            <span class="block text-sm text-[var(--color-text-muted)] mt-0.5 leading-relaxed">
              A day or two. Each module is 12 to 25 minutes. You walk
              the shape of the stack and produce a one-paragraph
              synthesis per layer.
            </span>
          </span>
        </label>
        <label class="flex items-baseline gap-3 p-3 border border-[var(--color-border)] rounded-md hover:border-[var(--color-border-strong)] cursor-pointer">
          <input
            type="radio"
            name="pass_choice"
            value="deep"
            checked={currentPassChoice === "deep"}
          />
          <span class="flex-1">
            <span class="block text-[var(--color-text)] font-medium">
              Deep pass
            </span>
            <span class="block text-sm text-[var(--color-text-muted)] mt-0.5 leading-relaxed">
              About a week. Each module is 30 to 90 minutes. Probe with
              citation grounding, four-axis compare, multi-paragraph
              synthesis. The take-home doc is substantially richer.
            </span>
          </span>
        </label>
        <button
          type="submit"
          class="w-full px-4 py-2.5 rounded-md bg-[var(--color-accent-strong)] text-white text-sm font-medium hover:bg-[var(--color-accent)] cursor-pointer"
        >
          Begin module 01 · {firstModule.title} →
        </button>
      </form>
    </section>
  </article>
</BaseLayout>
