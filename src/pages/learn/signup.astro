---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

const { user } = Astro.locals;

if (user) {
  return Astro.redirect("/learn");
}

let errorMessage: string | null = null;
let infoMessage: string | null = null;

/** If the input looks like an email, use it directly. Otherwise treat
 *  it as a username and synthesize a Supabase-compatible address at
 *  the reserved `oas.local` host. Usernames are lowercased and stripped
 *  to [a-z0-9._-] so the synthesized address is always valid. */
function resolveLoginEmail(raw: string): { email: string; isUsername: boolean } {
  const trimmed = raw.trim();
  if (trimmed.includes("@")) return { email: trimmed, isUsername: false };
  const slug = trimmed.toLowerCase().replace(/[^a-z0-9._-]/g, "");
  return { email: `${slug}@oas.local`, isUsername: true };
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const identifier = String(
    form.get("username") ?? form.get("identifier") ?? "",
  ).trim();
  const password = String(form.get("password") ?? "");
  if (!identifier || !password) {
    errorMessage = "Username (or email) and password are both required.";
  } else if (password.length < 8) {
    errorMessage = "Password must be at least 8 characters.";
  } else {
    const { email } = resolveLoginEmail(identifier);
    const { data, error } = await Astro.locals.supabase.auth.signUp({ email, password });
    if (error) {
      errorMessage = error.message;
    } else if (data.session) {
      // Email confirmation disabled: user is already signed in. Send
      // them to /learn with a sentinel so the client-side restore
      // promotes their anonymous localStorage writings.
      return Astro.redirect("/learn?restore=anon");
    } else {
      infoMessage =
        "Account created. Check your email for a confirmation link, then log in.";
    }
  }
}
---

<BaseLayout title="Sign up for /learn" description="Create an account to save your progress through the open-source AI stack course.">
  <section class="max-w-md mx-auto px-6 pt-16 pb-12">
    <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-3">
      Course
    </p>
    <h1 class="font-serif text-3xl text-[var(--color-text)] mb-2">
      Sign up
    </h1>
    <p class="text-sm text-[var(--color-text-muted)] mb-6 leading-relaxed">
      Save your progress, sync across devices, and download your
      Personal Notes when you finish. Or
      <a href="/learn" class="text-[var(--color-text)] hover:no-underline">browse without an account</a>.
    </p>

    <form
      method="POST"
      action="/learn/signup"
      name="register"
      id="signup-form"
      class="space-y-4"
    >
      {
        errorMessage && (
          <p class="text-sm text-red-700 border border-red-200 bg-red-50 px-3 py-2 rounded">
            {errorMessage}
          </p>
        )
      }
      {
        infoMessage && (
          <p class="text-sm text-[var(--color-text)] border border-[var(--color-border-strong)] bg-[var(--color-surface-warm)] px-3 py-2 rounded">
            {infoMessage}
          </p>
        )
      }
      <div>
        <label
          for="signup-username"
          class="text-xs font-mono uppercase tracking-wider text-[var(--color-text-subtle)] block mb-1"
        >
          Email or username
        </label>
        <input
          id="signup-username"
          type="text"
          name="username"
          required
          autocomplete="username"
          autocapitalize="off"
          autocorrect="off"
          spellcheck="false"
          class="w-full px-3 py-2 border border-[var(--color-border-strong)] rounded-md bg-[var(--color-surface)] text-[var(--color-text)] text-sm"
        />
        <span class="block text-xs text-[var(--color-text-subtle)] mt-1 leading-relaxed">
          Pick a username if you'd rather not share an email; password reset
          works only when a real email is on file.
        </span>
      </div>
      <div>
        <label
          for="signup-password"
          class="text-xs font-mono uppercase tracking-wider text-[var(--color-text-subtle)] block mb-1"
        >
          New password (8 chars or more)
        </label>
        <input
          id="signup-password"
          type="password"
          name="password"
          required
          minlength="8"
          autocomplete="new-password"
          class="w-full px-3 py-2 border border-[var(--color-border-strong)] rounded-md bg-[var(--color-surface)] text-[var(--color-text)] text-sm"
        />
      </div>
      <button
        type="submit"
        class="w-full px-4 py-2 rounded-md bg-[var(--color-accent-strong)] text-white text-sm font-medium hover:bg-[var(--color-accent)] cursor-pointer"
      >
        Create account
      </button>
    </form>

    <p class="text-sm text-[var(--color-text-muted)] mt-6 text-center">
      Already have an account? <a href="/learn/login" class="text-[var(--color-text)]">Log in</a>.
    </p>

    <p class="text-xs text-[var(--color-text-subtle)] mt-8 text-center leading-relaxed">
      Your email and password are stored at Supabase. The course saves
      your module progress and the text you write during the course
      (your synthesis paragraphs, your "why open source matters" answers).
      Nothing else. See <a href="/privacy" class="text-[var(--color-text-muted)]">/privacy</a> for specifics.
    </p>
    <p class="text-xs text-[var(--color-text-subtle)] mt-3 text-center leading-relaxed">
      Your course writing is encrypted with a key derived from your password.
      Only your browser can read it; the server only ever sees ciphertext.
      <strong class="text-[var(--color-text-muted)]">Password reset wipes
      that key</strong>, so your encrypted notes become unreadable. Keep
      your password.
    </p>
  </section>

  <script>
    // Client-side signup + E2EE key initialization. Intercepts the
    // form submit so the password stays in browser scope long enough
    // to generate and wrap the data key. SSR POST handler stays as a
    // no-JS fallback; that path creates the account but skips E2EE
    // init, which the next JS-enabled login will pick up.
    import { browserSupabase } from "../../lib/course/supabase";
    import { initKeys } from "../../lib/course/keys";

    const form = document.getElementById("signup-form") as HTMLFormElement | null;
    if (form) {
      form.addEventListener("submit", async (e) => {
        const supabase = browserSupabase();
        if (!supabase) return;
        e.preventDefault();
        const data = new FormData(form);
        const identifier = String(data.get("username") ?? "").trim();
        const password = String(data.get("password") ?? "");
        if (!identifier || !password) return;
        if (password.length < 8) return;
        const email = identifier.includes("@")
          ? identifier
          : `${identifier.toLowerCase().replace(/[^a-z0-9._-]/g, "")}@oas.local`;
        const showError = (msg: string) => {
          const existing = form.querySelector("[data-signup-error]") as HTMLParagraphElement | null;
          if (existing) {
            existing.textContent = msg;
            return;
          }
          const p = document.createElement("p");
          p.className = "text-sm text-red-700 border border-red-200 bg-red-50 px-3 py-2 rounded";
          p.dataset.signupError = "1";
          p.textContent = msg;
          form.insertBefore(p, form.firstChild);
        };
        const { data: authData, error } = await supabase.auth.signUp({ email, password });
        if (error) {
          showError(error.message);
          return;
        }
        if (!authData.session) {
          // Email confirmation flow: account exists but session isn't
          // live yet. Keys will be initialized on first confirmed login.
          showError("Account created. Check your email for a confirmation link, then log in.");
          return;
        }
        try {
          await initKeys(supabase, password);
        } catch (err) {
          await supabase.auth.signOut();
          showError(
            err instanceof Error
              ? `Could not initialize encryption: ${err.message}`
              : "Could not initialize encryption.",
          );
          return;
        }
        window.location.href = "/learn?restore=anon";
      });
    }
  </script>
</BaseLayout>
