---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readFileSync, existsSync } from "node:fs";
import { resolve } from "node:path";
import {
  loadModels,
  OPENNESS_LABEL,
  FAMILY_COLORS,
  familyColor,
  formatParams,
  formatContext,
  type Openness,
} from "../../lib/models";
import { QUANT_FAMILIES } from "../../lib/quantization";

const all = loadModels().slice().sort((a, b) => {
  const ad = a.released_date ?? "";
  const bd = b.released_date ?? "";
  return bd.localeCompare(ad);
});

// Per-cell verification gate. The /models page only shows numeric
// values whose corresponding claims-ledger row is currently
// supported / consistent / still_supported / pending_horizon. Anything
// else (unsupported, source_unreachable, verifier_unable, contradicted,
// drifted, needs_verification) renders as "—". The map is built at
// prebuild from audit/CLAIMS_LEDGER.md via
// scripts/build-verification-map.mjs.
const VERIFICATION_PATH = resolve("public/data/models-verification.json");
const VERIFICATION: Record<string, Record<string, string>> = existsSync(VERIFICATION_PATH)
  ? JSON.parse(readFileSync(VERIFICATION_PATH, "utf8"))
  : {};
const VERIFIED_VERDICTS = new Set([
  "supported",
  "consistent",
  "still_supported",
  "pending_horizon",
]);
function verified(slug: string, field: string): boolean {
  return VERIFIED_VERDICTS.has(VERIFICATION[slug]?.[field] ?? "");
}
function gate<T>(slug: string, field: string, value: T | null | undefined): T | null {
  if (value === null || value === undefined) return null;
  return verified(slug, field) ? (value as T) : null;
}
// Verified quantization family ids for a model (gated like every cell).
function quantsFor(slug: string): string[] {
  return QUANT_FAMILIES.filter((f) => verified(slug, `quant.${f.id}`)).map((f) => f.id);
}

const openCount = all.filter((m) => m.openness === "open").length;
const openWeightsCount = all.filter((m) => m.openness === "open-weights" || m.openness === "source-available").length;
const closedCount = all.filter((m) => m.openness === "proprietary").length;

const TIMELINE_START = new Date("2023-02-01").getTime();
const TIMELINE_END = Date.now();
function xForDate(dateStr: string, width: number): number {
  const t = new Date(dateStr).getTime();
  if (!Number.isFinite(t)) return 0;
  const pct = (t - TIMELINE_START) / (TIMELINE_END - TIMELINE_START);
  return Math.max(0, Math.min(1, pct)) * width;
}

const TIMELINE_W = 1100;
const TIMELINE_H = 180;
const TIMELINE_PAD_X = 24;
const TIMELINE_INNER_W = TIMELINE_W - TIMELINE_PAD_X * 2;

function yForOpenness(o: Openness): number {
  switch (o) {
    case "open": return 40;
    case "open-weights": return 70;
    case "source-available": return 100;
    case "proprietary": return 130;
  }
}

function opennessClass(o: Openness): string {
  return `openness-${o}`;
}

const yearTicks = [];
for (let y = 2023; y <= new Date().getFullYear(); y++) {
  yearTicks.push({
    label: String(y),
    x: xForDate(`${y}-01-01`, TIMELINE_INNER_W),
  });
}

const developers = Array.from(new Set(all.map((m) => m.developer))).sort();
const architectures = Array.from(new Set(all.map((m) => m.architecture))).sort();

// Family-color legend: only families that actually appear in the
// catalog, sorted by count desc so the most common ones show first.
// Anything not in FAMILY_COLORS falls back to the default gray and
// goes under an "other" chip at the end.
const familyCounts = new Map<string, number>();
for (const m of all) familyCounts.set(m.family, (familyCounts.get(m.family) ?? 0) + 1);
const legendFamilies = Array.from(familyCounts.entries())
  .filter(([fam]) => fam in FAMILY_COLORS)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const unmappedFamilies = Array.from(familyCounts.entries()).filter(([fam]) => !(fam in FAMILY_COLORS));

// Scatter plot: axes are user-selectable client-side. Server emits a
// JSON payload of every metric for every model, and the inline JS
// rerenders the dots whenever the user picks new X/Y metrics. Models
// missing either metric drop off the chart silently with a "shown N of
// M" counter so the omission is visible. Default axes are GPQA-Diamond
// (Y) vs input cost (X) because that's the cost/quality frontier most
// readers come here to see.
const scatterRows = all.map((m) => ({
  slug: m.slug,
  display_name: m.display_name,
  openness: m.openness,
  family: m.family,
  family_color: familyColor(m.family),
  released_date: m.released_date,
  // Flattened, picker-friendly metric map. Each numeric metric is
  // gated on the claims-ledger verdict for its corresponding row:
  // unverified rows render as null (the table shows "—") so we never
  // display a number we cannot programmatically back to a primary
  // source. released_year is derived from released_date and inherits
  // its verdict.
  metrics: {
    input_per_mtok_usd: gate(m.slug, "cost.input", m.cost?.input_per_mtok_usd ?? null),
    output_per_mtok_usd: gate(m.slug, "cost.output", m.cost?.output_per_mtok_usd ?? null),
    tokens_per_sec_output: gate(m.slug, "speed.output_tps", m.speed?.tokens_per_sec_output ?? null),
    ttft_ms: gate(m.slug, "speed.ttft", m.speed?.ttft_ms ?? null),
    context_window: gate(m.slug, "context_window", m.context_window || null),
    params_total: gate(m.slug, "params_total", m.params_total > 0 ? m.params_total : null),
    params_active: gate(m.slug, "params_active", m.params_active > 0 ? m.params_active : null),
    pretraining_tokens: gate(m.slug, "pretraining_tokens", m.pretraining_tokens ?? null),
    mmlu: gate(m.slug, "bench.mmlu", m.benchmarks?.mmlu?.score ?? null),
    mmlu_pro: gate(m.slug, "bench.mmlu_pro", m.benchmarks?.mmlu_pro?.score ?? null),
    gpqa_diamond: gate(m.slug, "bench.gpqa_diamond", m.benchmarks?.gpqa_diamond?.score ?? null),
    humaneval: gate(m.slug, "bench.humaneval", m.benchmarks?.humaneval?.score ?? null),
    swe_bench_verified: gate(m.slug, "bench.swe_bench_verified", m.benchmarks?.swe_bench_verified?.score ?? null),
    livecodebench: gate(m.slug, "bench.livecodebench", m.benchmarks?.livecodebench?.score ?? null),
    math: gate(m.slug, "bench.math", m.benchmarks?.math?.score ?? null),
    aime_2024: gate(m.slug, "bench.aime_2024", m.benchmarks?.aime_2024?.score ?? null),
    aime_2025: gate(m.slug, "bench.aime_2025", m.benchmarks?.aime_2025?.score ?? null),
    frontiermath: gate(m.slug, "bench.frontiermath", m.benchmarks?.frontiermath?.score ?? null),
    lmarena_elo: gate(m.slug, "bench.lmarena_elo", m.benchmarks?.lmarena_elo?.score ?? null),
    livebench: gate(m.slug, "bench.livebench", m.benchmarks?.livebench?.score ?? null),
    ifeval: gate(m.slug, "bench.ifeval", m.benchmarks?.ifeval?.score ?? null),
    released_year: verified(m.slug, "released_date")
      ? new Date(m.released_date).getTime() / (365.25 * 24 * 3600 * 1000) + 1970
      : null,
  },
}));

// Metric metadata table. `log` flags axes that span orders of
// magnitude (cost, params, tokens); the renderer switches to log
// scale automatically when picked. `label` is what the axis shows.
const SCATTER_METRICS: Array<{
  key: string;
  label: string;
  short_label: string;
  log: boolean;
  group: "cost" | "speed" | "scale" | "benchmark";
}> = [
  { key: "input_per_mtok_usd", label: "Input cost ($/M tokens)", short_label: "Input $/M", log: true, group: "cost" },
  { key: "output_per_mtok_usd", label: "Output cost ($/M tokens)", short_label: "Output $/M", log: true, group: "cost" },
  { key: "tokens_per_sec_output", label: "Output throughput (tokens/sec)", short_label: "tok/sec", log: false, group: "speed" },
  { key: "ttft_ms", label: "Time to first token (ms)", short_label: "TTFT ms", log: false, group: "speed" },
  { key: "context_window", label: "Context window (tokens)", short_label: "Context", log: true, group: "scale" },
  { key: "params_total", label: "Total parameters", short_label: "Total params", log: true, group: "scale" },
  { key: "params_active", label: "Active parameters", short_label: "Active params", log: true, group: "scale" },
  { key: "pretraining_tokens", label: "Pretraining tokens", short_label: "Pretrain tokens", log: true, group: "scale" },
  { key: "released_year", label: "Release year", short_label: "Year", log: false, group: "scale" },
  { key: "mmlu", label: "MMLU", short_label: "MMLU", log: false, group: "benchmark" },
  { key: "mmlu_pro", label: "MMLU-Pro", short_label: "MMLU-Pro", log: false, group: "benchmark" },
  { key: "gpqa_diamond", label: "GPQA-Diamond", short_label: "GPQA-D", log: false, group: "benchmark" },
  { key: "humaneval", label: "HumanEval", short_label: "HumanEval", log: false, group: "benchmark" },
  { key: "swe_bench_verified", label: "SWE-Bench Verified", short_label: "SWE-Bench V", log: false, group: "benchmark" },
  { key: "livecodebench", label: "LiveCodeBench", short_label: "LiveCodeBench", log: false, group: "benchmark" },
  { key: "math", label: "MATH", short_label: "MATH", log: false, group: "benchmark" },
  { key: "aime_2024", label: "AIME 2024", short_label: "AIME 2024", log: false, group: "benchmark" },
  { key: "aime_2025", label: "AIME 2025", short_label: "AIME 2025", log: false, group: "benchmark" },
  { key: "frontiermath", label: "FrontierMath", short_label: "FrontierMath", log: false, group: "benchmark" },
  { key: "lmarena_elo", label: "LMArena Elo", short_label: "Elo", log: false, group: "benchmark" },
  { key: "livebench", label: "LiveBench", short_label: "LiveBench", log: false, group: "benchmark" },
  { key: "ifeval", label: "IFEval", short_label: "IFEval", log: false, group: "benchmark" },
];

// Drop metrics no model in the catalog has data for (keeps the
// dropdowns from including dead options like FrontierMath when zero
// models have reported it).
const populatedMetrics = SCATTER_METRICS.filter((meta) =>
  scatterRows.some((r) => r.metrics[meta.key as keyof typeof r.metrics] != null),
);

// Column tooltips: short blurb shown on hover via title attribute.
const COL_HELP = {
  model: "The checkpoint's display name. Click to open its detail page.",
  developer: "The lab or organization that released the checkpoint.",
  released: "Date the checkpoint was first announced or made available.",
  openness: "License + release tier. Hover the badge on a row for the tier's definition.",
  architecture: "Model family architecture: dense, MoE (mixture of experts), hybrid, or unknown for closed models.",
  total: "Total parameter count, including inactive experts on MoE models. Closed models with undisclosed counts show —.",
  active: "Parameters activated per forward pass. Equals total for dense models; smaller for MoE (e.g. 37B active of 671B total for DeepSeek V3).",
  ctx: "Native context window in tokens, before any YaRN or extrapolation tricks.",
  cost_in: "USD per million input tokens at the source's reference vendor.",
  cost_out: "USD per million output tokens. Reasoning models output more tokens per request because the reasoning trace counts.",
  speed: "Decode throughput at the reference vendor, in output tokens per second.",
  mmlu: "MMLU general-knowledge benchmark, 0-100. Most-quoted but oldest; treat as a rough capability floor.",
  gpqa: "GPQA-Diamond, graduate-level science. The current standard for hard reasoning. 70%+ is frontier.",
  humaneval: "HumanEval pass@1 for code completion. Saturated at the frontier; SWE-Bench Verified is now the harder code benchmark.",
};

// Openness tier explainers for the popover.
const OPENNESS_EXPLAINER: Record<Openness, string> = {
  "open": "Apache-2.0 or MIT class license; OSI-approved by the most common reading. Weights and license terms unrestricted for commercial use. Does not imply training data or training code are released.",
  "open-weights": "Weights are downloadable under a permissive license, but the license carries field-of-use restrictions or revocable terms that prevent OSI approval.",
  "source-available": "Weights are downloadable but the license includes acceptable-use policy clauses, scale caps, or other restrictions. Commercial use possible with conditions.",
  "proprietary": "Weights not released. Architecture and training data typically undisclosed. Available only through the lab's API or partner endpoints.",
};

// Architecture explainers. Rendered as HTML in the popover so we can
// link to the deeper glossary entry for each architecture type.
const ARCH_POPOVER: Record<string, string> = {
  dense: 'Dense transformer. Every parameter is activated on every token; the conventional architecture before MoE became common at frontier scale. <a href="/glossary/dense">Learn more &rarr;</a>',
  moe: 'Mixture of experts. The model has more total parameters than it activates per token; a router picks a small subset of expert MLPs per token, trading sparsity for capacity at lower inference cost. <a href="/glossary/mixture-of-experts">Learn more &rarr;</a>',
  hybrid: 'Hybrid attention. Mixes different attention mechanisms across layers, typically global plus sliding-window. <a href="/glossary/hybrid-attention">Learn more &rarr;</a>',
  ssm: 'State space model. Replaces or supplements attention with a state-space recurrence (e.g. Mamba). Linear-time in sequence length. <a href="/glossary/state-space-model">Learn more &rarr;</a>',
  unknown: 'Architecture not disclosed by the developer. Proprietary models typically do not reveal their internal structure.',
};

// Openness ordering for sorting.
const OPENNESS_RANK: Record<Openness, number> = {
  "open": 0,
  "open-weights": 1,
  "source-available": 2,
  "proprietary": 3,
};
---

<BaseLayout
  title="Models"
  description="Open-source and frontier language models, side by side. Timeline, architecture, training, benchmarks, cost, speed. Every claim sourced."
>
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-6">
    <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4">
      Models
    </p>
    <h1 class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-6">
      What's actually shipped, and how it compares
    </h1>
    <p class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-prose mb-4">
      One row per checkpoint, not per family. {openCount} OSI-open, {openWeightsCount} source-available
      open-weights, {closedCount} proprietary baselines, since Feb 2023. Every architecture parameter,
      benchmark score, release date, and price is sourced.
    </p>

    <!-- "How to read model names" collapsible -->
    <details class="border border-[var(--color-border)] rounded-md bg-[var(--color-surface)] mb-2">
      <summary class="px-4 py-3 cursor-pointer font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] hover:text-[var(--color-text)] list-none flex items-center justify-between">
        <span>How to read model names</span>
        <span class="font-mono text-[10px]">expand ↓</span>
      </summary>
      <div class="px-4 pb-4 text-sm text-[var(--color-text-muted)] leading-relaxed border-t border-[var(--color-border)]">
        <p class="mt-3 mb-3">
          Model names look like jargon because labs cram several facts into one string.
          Once you know the convention they're easier to read than they look.
        </p>
        <ul class="space-y-3">
          <li>
            <p class="font-mono text-xs text-[var(--color-text)] mb-1">Llama 3.3 70B Instruct</p>
            <p class="text-xs">
              <span class="font-medium">Llama</span> = family ·
              <span class="font-medium">3.3</span> = version ·
              <span class="font-medium">70B</span> = parameter count (70 billion) ·
              <span class="font-medium">Instruct</span> = post-trained for following instructions
              (vs "Base" which is the pretrained checkpoint before any RLHF).
            </p>
          </li>
          <li>
            <p class="font-mono text-xs text-[var(--color-text)] mb-1">DeepSeek-R1</p>
            <p class="text-xs">
              <span class="font-medium">DeepSeek</span> = family ·
              <span class="font-medium">R1</span> = "Reasoning 1", a model post-trained with
              reinforcement learning to emit chain-of-thought before answering. The
              "thinking model" naming convention started with OpenAI's o1; R1 is
              DeepSeek's open answer to it.
            </p>
          </li>
          <li>
            <p class="font-mono text-xs text-[var(--color-text)] mb-1">Qwen 3 235B A22B Instruct</p>
            <p class="text-xs">
              <span class="font-medium">Qwen</span> = family ·
              <span class="font-medium">3</span> = version ·
              <span class="font-medium">235B</span> = total parameters across all experts ·
              <span class="font-medium">A22B</span> = "active 22 billion" — the parameters used per
              forward pass. This is the MoE convention: total/active. Compare to
              DeepSeek V3 at 671B total / 37B active.
            </p>
          </li>
          <li>
            <p class="font-mono text-xs text-[var(--color-text)] mb-1">Mixtral 8x7B Instruct v0.1</p>
            <p class="text-xs">
              <span class="font-medium">Mixtral</span> = family ·
              <span class="font-medium">8x7B</span> = eight 7B experts, with two activated per token
              (Mistral's earlier MoE notation; same idea as Qwen's total/active just expressed
              differently) ·
              <span class="font-medium">v0.1</span> = release version.
            </p>
          </li>
          <li>
            <p class="font-mono text-xs text-[var(--color-text)] mb-1">Claude 3.5 Sonnet</p>
            <p class="text-xs">
              <span class="font-medium">Claude</span> = family ·
              <span class="font-medium">3.5</span> = version ·
              <span class="font-medium">Sonnet</span> = tier name (Anthropic uses Haiku &lt; Sonnet
              &lt; Opus to rank speed/cost/quality within a generation; tier semantics shift
              across generations).
            </p>
          </li>
          <li>
            <p class="font-mono text-xs text-[var(--color-text)] mb-1">GPT-4o vs o1 vs o3</p>
            <p class="text-xs">
              <span class="font-medium">GPT-4o</span> is OpenAI's multimodal model. The
              <span class="font-medium">o-series</span> (o1, o3, o3-mini) is their reasoning line —
              the o stands for "OpenAI" branding here, not a version qualifier. Numbers grow
              with capability, not with chronology (o3 launched before o2 was named publicly).
            </p>
          </li>
        </ul>
      </div>
    </details>
  </section>

  <!-- Timeline strip -->
  <section class="max-w-6xl mx-auto px-6 pt-2 pb-8">
    <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-3">
      Launch timeline
    </h2>
    <div id="timeline-container" class="relative border border-[var(--color-border)] rounded-md bg-[var(--color-surface)] p-3 overflow-x-auto">
      <svg
        viewBox={`0 0 ${TIMELINE_W} ${TIMELINE_H}`}
        width="100%"
        style={`max-width: ${TIMELINE_W}px; display: block; font-family: var(--font-mono);`}
        role="img"
        aria-label="Launch timeline of catalogued models"
      >
        <g font-size="10" fill="var(--color-text-subtle)">
          <text x={4} y={44}>open</text>
          <text x={4} y={74}>open-weights</text>
          <text x={4} y={104}>source-available</text>
          <text x={4} y={134}>proprietary</text>
        </g>

        <g stroke="var(--color-border)" stroke-width="1">
          <line x1={TIMELINE_PAD_X + 110} y1={40} x2={TIMELINE_W - TIMELINE_PAD_X} y2={40}/>
          <line x1={TIMELINE_PAD_X + 110} y1={70} x2={TIMELINE_W - TIMELINE_PAD_X} y2={70}/>
          <line x1={TIMELINE_PAD_X + 110} y1={100} x2={TIMELINE_W - TIMELINE_PAD_X} y2={100}/>
          <line x1={TIMELINE_PAD_X + 110} y1={130} x2={TIMELINE_W - TIMELINE_PAD_X} y2={130}/>
        </g>

        <g font-size="10" fill="var(--color-text-muted)" stroke="none">
          {yearTicks.map((t) => (
            <>
              <line
                x1={TIMELINE_PAD_X + 110 + t.x * ((TIMELINE_INNER_W - 110) / TIMELINE_INNER_W)}
                x2={TIMELINE_PAD_X + 110 + t.x * ((TIMELINE_INNER_W - 110) / TIMELINE_INNER_W)}
                y1={20} y2={150}
                stroke="var(--color-border)"
              />
              <text
                x={TIMELINE_PAD_X + 110 + t.x * ((TIMELINE_INNER_W - 110) / TIMELINE_INNER_W) + 4}
                y={16}
                fill="var(--color-text-subtle)"
              >
                {t.label}
              </text>
            </>
          ))}
        </g>

        <g>
          {all.filter((m) => verified(m.slug, "released_date")).map((m) => {
            const x = TIMELINE_PAD_X + 110 + xForDate(m.released_date, TIMELINE_INNER_W - 110);
            const y = yForOpenness(m.openness);
            const fill = familyColor(m.family);
            const gpqa = verified(m.slug, "bench.gpqa_diamond") ? m.benchmarks?.gpqa_diamond?.score : null;
            const mmluPro = verified(m.slug, "bench.mmlu_pro") ? m.benchmarks?.mmlu_pro?.score : null;
            return (
              <g
                class="timeline-dot"
                data-slug={m.slug}
                data-name={m.display_name}
                data-family={m.family}
                data-dev={m.developer}
                data-date={m.released_date}
                data-openness={m.openness}
                data-license={m.license}
                data-arch={m.architecture}
                data-params-total={verified(m.slug, "params_total") && m.params_total > 0 ? formatParams(m.params_total) : "—"}
                data-params-active={verified(m.slug, "params_active") && m.params_active > 0 ? formatParams(m.params_active) : "—"}
                data-context={verified(m.slug, "context_window") ? formatContext(m.context_window) : "—"}
                data-gpqa={gpqa != null ? gpqa.toFixed(1) : ""}
                data-mmlu-pro={mmluPro != null ? mmluPro.toFixed(1) : ""}
                data-cost-in={verified(m.slug, "cost.input") && m.cost?.input_per_mtok_usd != null ? m.cost.input_per_mtok_usd.toFixed(2) : ""}
                data-cost-out={verified(m.slug, "cost.output") && m.cost?.output_per_mtok_usd != null ? m.cost.output_per_mtok_usd.toFixed(2) : ""}
              >
                <a href={`/models/${m.slug}`}>
                  <circle cx={x} cy={y} r="5" fill={fill} stroke="var(--color-surface)" stroke-width="1.2"/>
                </a>
              </g>
            );
          })}
        </g>
      </svg>
      <div
        id="timeline-tooltip"
        class="absolute hidden pointer-events-none z-10 border border-[var(--color-border-strong)] rounded-md bg-[var(--color-surface)] shadow-lg p-3 text-xs"
        style="min-width: 240px; max-width: 320px;"
      ></div>
    </div>
    <p class="font-mono text-[10px] text-[var(--color-text-subtle)] mt-2">
      Dots in lanes by openness, colored by family. Hover for details; click to open the model page.
    </p>
    {/* Family-color legend, shared by timeline + scatter. Compact:
        one swatch + family slug per chip; only families actually
        present in the catalog appear. Hover a chip to dim
        non-matching dots across both visualizations. */}
    <div class="flex flex-wrap gap-x-3 gap-y-1 mt-2 items-center" id="family-legend">
      {legendFamilies.map(([fam, count]) => (
        <span class="family-legend-chip inline-flex items-center gap-1 font-mono text-[10px] text-[var(--color-text-subtle)]" data-family-highlight={fam}>
          <span
            aria-hidden="true"
            style={`display:inline-block;width:8px;height:8px;border-radius:50%;background:${FAMILY_COLORS[fam]};`}
          ></span>
          <span class="family-legend-name text-[var(--color-text-muted)]">{fam}</span>
          <span class="text-[var(--color-text-subtle)]">({count})</span>
        </span>
      ))}
      {unmappedFamilies.length > 0 && (
        <span class="family-legend-chip inline-flex items-center gap-1 font-mono text-[10px] text-[var(--color-text-subtle)]" data-family-highlight="__other__">
          <span
            aria-hidden="true"
            style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#737373;"
          ></span>
          <span class="family-legend-name text-[var(--color-text-muted)]">other</span>
          <span class="text-[var(--color-text-subtle)]">({unmappedFamilies.reduce((s, [, c]) => s + c, 0)})</span>
        </span>
      )}
    </div>
  </section>

  <!-- Configurable scatter plot. Server emits the data + metric
       metadata as JSON; client JS renders the axes and dots and
       redraws when either axis selector changes. Models missing the
       picked X or Y metric drop off silently; the counter tells the
       reader how many are plotted vs hidden. -->
  <section class="max-w-6xl mx-auto px-6 pb-8" id="scatter-section">
    <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-1">
      Compare any two metrics
    </h2>
    <p class="text-xs text-[var(--color-text-subtle)] mb-3 max-w-prose leading-relaxed">
      Pick an X and Y metric; one dot per model. Cost and parameter axes use log scale
      automatically. Open as filled dot, closed as ring. Models that did not publish the
      picked metric drop off the chart. Costs and speeds via <a href="https://artificialanalysis.ai/models" target="_blank" rel="noopener" class="hover:text-[var(--color-text)] no-underline hover:underline">Artificial Analysis ↗</a>;
      benchmark scores from each model's primary source.
    </p>
    <div class="flex flex-wrap items-center gap-3 mb-3 text-sm">
      <label class="font-mono text-xs text-[var(--color-text-subtle)] flex items-center gap-2">
        Y axis
        <select id="scatter-y" class="px-2 py-1 border border-[var(--color-border)] rounded bg-[var(--color-surface)] text-sm font-sans">
          {(["benchmark", "speed", "scale", "cost"] as const).map((g) => {
            const opts = populatedMetrics.filter((m) => m.group === g);
            if (opts.length === 0) return null;
            const groupLabel = { benchmark: "Benchmarks", speed: "Speed", scale: "Scale", cost: "Cost" }[g];
            return (
              <optgroup label={groupLabel}>
                {opts.map((m) => (
                  <option value={m.key} selected={m.key === "gpqa_diamond"}>{m.label}</option>
                ))}
              </optgroup>
            );
          })}
        </select>
      </label>
      <label class="font-mono text-xs text-[var(--color-text-subtle)] flex items-center gap-2">
        X axis
        <select id="scatter-x" class="px-2 py-1 border border-[var(--color-border)] rounded bg-[var(--color-surface)] text-sm font-sans">
          {(["cost", "speed", "scale", "benchmark"] as const).map((g) => {
            const opts = populatedMetrics.filter((m) => m.group === g);
            if (opts.length === 0) return null;
            const groupLabel = { cost: "Cost", speed: "Speed", scale: "Scale", benchmark: "Benchmarks" }[g];
            return (
              <optgroup label={groupLabel}>
                {opts.map((m) => (
                  <option value={m.key} selected={m.key === "input_per_mtok_usd"}>{m.label}</option>
                ))}
              </optgroup>
            );
          })}
        </select>
      </label>
      <button id="scatter-swap" type="button" class="px-2 py-1 text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)] underline cursor-pointer">
        swap axes
      </button>
      <span id="scatter-count" class="ml-auto font-mono text-xs text-[var(--color-text-subtle)]"></span>
      <button id="scatter-reset" type="button" class="px-2 py-1 text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)] underline cursor-pointer" title="Reset zoom/pan to fit all points">
        reset view
      </button>
    </div>
    <div class="border border-[var(--color-border)] rounded-md bg-[var(--color-surface)] p-3 relative" id="scatter-frame">
      <svg
        id="scatter-svg"
        viewBox="0 0 720 320"
        width="100%"
        style="max-width: 720px; display: block; font-family: var(--font-mono); cursor: grab; touch-action: none;"
        role="img"
        aria-label="Configurable metric scatter"
      ></svg>
      <div
        id="scatter-tooltip"
        class="absolute hidden pointer-events-none z-10 border border-[var(--color-border-strong)] rounded-md bg-[var(--color-surface)] shadow-lg p-3 text-xs"
        style="min-width: 220px; max-width: 320px;"
      ></div>
    </div>
    <p class="font-mono text-[10px] text-[var(--color-text-subtle)] mt-2">
      Drag to pan. Scroll to zoom. Shift + drag to box-zoom. Click a dot to open the model page.
    </p>
    <details class="mt-2">
      <summary class="font-mono text-xs text-[var(--color-text-subtle)] hover:text-[var(--color-text)] cursor-pointer">
        Why some models are missing from the plot
      </summary>
      <div id="scatter-hidden" class="font-mono text-xs text-[var(--color-text-muted)] mt-2 pl-3 border-l border-[var(--color-border)]"></div>
    </details>
    <script type="application/json" id="scatter-data" set:html={JSON.stringify({ rows: scatterRows, metrics: populatedMetrics })}></script>
  </section>

  <!-- Filter bar + table -->
  <section class="max-w-6xl mx-auto px-6 pb-16" id="models-table-section">
    <div class="flex items-baseline justify-between mb-3 flex-wrap gap-2">
      <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)]">
        All models ({all.length})
      </h2>
      <div id="multi-compare-cta" class="hidden font-mono text-xs">
        <span id="multi-compare-count" class="text-[var(--color-text-muted)] mr-2"></span>
        <a id="multi-compare-link" href="/models/compare" class="px-2 py-1 rounded border border-[var(--color-text)] text-[var(--color-text)] no-underline hover:bg-[var(--color-surface-warm)]">
          Compare selected →
        </a>
      </div>
    </div>
    <div class="flex flex-wrap items-center gap-3 mb-4 text-sm">
      <input
        id="models-search"
        type="search"
        placeholder="Search by name, family, developer..."
        class="px-3 py-1.5 border border-[var(--color-border-strong)] rounded-md bg-[var(--color-surface)] text-sm w-64"
      />
      <select id="filter-openness" class="px-2 py-1.5 border border-[var(--color-border)] rounded-md bg-[var(--color-surface)] text-sm">
        <option value="">all openness</option>
        <option value="open">open (OSI)</option>
        <option value="open-weights">open-weights</option>
        <option value="source-available">source-available</option>
        <option value="proprietary">proprietary</option>
      </select>
      <select id="filter-architecture" class="px-2 py-1.5 border border-[var(--color-border)] rounded-md bg-[var(--color-surface)] text-sm">
        <option value="">all architectures</option>
        {architectures.map((a) => (<option value={a}>{a}</option>))}
      </select>
      <select id="filter-developer" class="px-2 py-1.5 border border-[var(--color-border)] rounded-md bg-[var(--color-surface)] text-sm">
        <option value="">all developers</option>
        {developers.map((d) => (<option value={d}>{d}</option>))}
      </select>
      <select id="filter-quant" class="px-2 py-1.5 border border-[var(--color-border)] rounded-md bg-[var(--color-surface)] text-sm">
        <option value="">any quantization</option>
        {QUANT_FAMILIES.map((f) => (<option value={f.id}>{f.label}</option>))}
      </select>
      <button id="filter-reset" type="button" class="px-2 py-1.5 text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)] underline cursor-pointer">
        reset
      </button>
      <span id="filter-count" class="ml-auto font-mono text-xs text-[var(--color-text-subtle)]">
        {all.length} models
      </span>
    </div>

    <div class="overflow-x-auto border border-[var(--color-border)] rounded-md bg-[var(--color-surface)]">
      <table class="w-full text-sm" id="models-table">
        <thead class="border-b border-[var(--color-border)] bg-[var(--color-surface-warm)]">
          <tr class="text-left font-mono text-[11px] uppercase tracking-wider text-[var(--color-text-subtle)]">
            <th class="px-2 py-2"><span data-popover="Pick up to 4 to compare side-by-side">cmp</span></th>
            <th class="px-3 py-2 sortable" data-sort="name" data-popover={COL_HELP.model}>Model <span class="sort-chev"></span></th>
            <th class="px-3 py-2 sortable" data-sort="developer" data-popover={COL_HELP.developer}>Developer <span class="sort-chev"></span></th>
            <th class="px-3 py-2 sortable" data-sort="released" data-sort-type="numeric" data-popover={COL_HELP.released}>Released <span class="sort-chev">▼</span></th>
            <th class="px-3 py-2 sortable" data-sort="openness" data-sort-type="numeric" data-popover={COL_HELP.openness}>Openness <span class="sort-chev"></span></th>
            <th class="px-3 py-2 sortable" data-sort="architecture" data-popover={COL_HELP.architecture}>Architecture <span class="sort-chev"></span></th>
            <th class="px-3 py-2 text-right sortable" data-sort="total" data-sort-type="numeric" data-popover={COL_HELP.total}>Total params <span class="sort-chev"></span></th>
            <th class="px-3 py-2 text-right sortable" data-sort="active" data-sort-type="numeric" data-popover={COL_HELP.active}>Active params <span class="sort-chev"></span></th>
            <th class="px-3 py-2 text-right sortable" data-sort="context" data-sort-type="numeric" data-popover={COL_HELP.ctx}>Context <span class="sort-chev"></span></th>
            <th class="px-3 py-2 text-right sortable" data-sort="costin" data-sort-type="numeric" data-popover={COL_HELP.cost_in}>$/M in <span class="sort-chev"></span></th>
            <th class="px-3 py-2 text-right sortable" data-sort="costout" data-sort-type="numeric" data-popover={COL_HELP.cost_out}>$/M out <span class="sort-chev"></span></th>
            <th class="px-3 py-2 text-right sortable" data-sort="speed" data-sort-type="numeric" data-popover={COL_HELP.speed}>tok/s <span class="sort-chev"></span></th>
            <th class="px-3 py-2 text-right sortable" data-sort="mmlu" data-sort-type="numeric" data-popover={COL_HELP.mmlu}>MMLU <span class="sort-chev"></span></th>
            <th class="px-3 py-2 text-right sortable" data-sort="gpqa" data-sort-type="numeric" data-popover={COL_HELP.gpqa}>GPQA-D <span class="sort-chev"></span></th>
            <th class="px-3 py-2 text-right sortable" data-sort="humaneval" data-sort-type="numeric" data-popover={COL_HELP.humaneval}>HumanEval <span class="sort-chev"></span></th>
            <th class="px-3 py-2" data-popover="Quantization format families with published weights, verified against the Hugging Face model tree. Proprietary (closed-weight) models have none.">Quants</th>
          </tr>
        </thead>
        <tbody>
          {all.map((m) => {
            const bm = m.benchmarks ?? {};
            const releasedTs = new Date(m.released_date).getTime();
            const fams = m.openness === "proprietary" ? [] : quantsFor(m.slug);
            return (
              <tr
                class="models-row border-t border-[var(--color-border)] hover:bg-[var(--color-surface-warm)]"
                data-name={m.display_name.toLowerCase()}
                data-family={m.family.toLowerCase()}
                data-developer={m.developer}
                data-openness={m.openness}
                data-architecture={m.architecture}
                data-quants={fams.join(" ")}
                data-slug={m.slug}
                data-sort-name={m.display_name.toLowerCase()}
                data-sort-developer={m.developer.toLowerCase()}
                data-sort-released={String(releasedTs)}
                data-sort-openness={String(OPENNESS_RANK[m.openness])}
                data-sort-architecture={m.architecture}
                data-sort-total={m.params_total > 0 ? String(m.params_total) : ""}
                data-sort-active={m.params_active > 0 ? String(m.params_active) : ""}
                data-sort-context={String(m.context_window)}
                data-sort-costin={m.cost?.input_per_mtok_usd !== undefined ? String(m.cost.input_per_mtok_usd) : ""}
                data-sort-costout={m.cost?.output_per_mtok_usd !== undefined ? String(m.cost.output_per_mtok_usd) : ""}
                data-sort-speed={m.speed?.tokens_per_sec_output !== undefined ? String(m.speed.tokens_per_sec_output) : ""}
                data-sort-mmlu={bm.mmlu ? String(bm.mmlu.score) : ""}
                data-sort-gpqa={bm.gpqa_diamond ? String(bm.gpqa_diamond.score) : ""}
                data-sort-humaneval={bm.humaneval ? String(bm.humaneval.score) : ""}
              >
                <td class="px-2 py-2 text-center">
                  <input type="checkbox" class="cmp-cb" data-slug={m.slug} aria-label={`Add ${m.display_name} to compare`}/>
                </td>
                <td class="px-3 py-2">
                  <a href={`/models/${m.slug}`} class="text-[var(--color-text)] no-underline hover:underline font-medium">
                    {m.display_name}
                  </a>
                </td>
                <td class="px-3 py-2 text-[var(--color-text-muted)]">{m.developer}</td>
                <td class="px-3 py-2 font-mono text-xs text-[var(--color-text-muted)] tabular-nums">{verified(m.slug, "released_date") ? m.released_date : "—"}</td>
                <td class="px-3 py-2">
                  <span
                    class={`openness-badge ${opennessClass(m.openness)} font-mono text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded`}
                    data-popover={OPENNESS_EXPLAINER[m.openness]}
                  >
                    {OPENNESS_LABEL[m.openness]}
                  </span>
                </td>
                <td class="px-3 py-2 font-mono text-xs text-[var(--color-text-muted)]">
                  <span data-popover-html={ARCH_POPOVER[m.architecture] ?? "Architecture not described."}>{m.architecture}</span>
                </td>
                <td class="px-3 py-2 text-right font-mono text-xs tabular-nums">{verified(m.slug, "params_total") && m.params_total > 0 ? formatParams(m.params_total) : "—"}</td>
                <td class="px-3 py-2 text-right font-mono text-xs tabular-nums">{verified(m.slug, "params_active") && m.params_active > 0 ? formatParams(m.params_active) : "—"}</td>
                <td class="px-3 py-2 text-right font-mono text-xs tabular-nums">{verified(m.slug, "context_window") ? formatContext(m.context_window) : "—"}</td>
                <td class="px-3 py-2 text-right font-mono text-xs tabular-nums">{verified(m.slug, "cost.input") && m.cost?.input_per_mtok_usd !== undefined ? `$${m.cost.input_per_mtok_usd.toFixed(2)}` : "—"}</td>
                <td class="px-3 py-2 text-right font-mono text-xs tabular-nums">{verified(m.slug, "cost.output") && m.cost?.output_per_mtok_usd !== undefined ? `$${m.cost.output_per_mtok_usd.toFixed(2)}` : "—"}</td>
                <td class="px-3 py-2 text-right font-mono text-xs tabular-nums">{verified(m.slug, "speed.output_tps") ? (m.speed?.tokens_per_sec_output ?? "—") : "—"}</td>
                <td class="px-3 py-2 text-right font-mono text-xs tabular-nums">{verified(m.slug, "bench.mmlu") && bm.mmlu ? bm.mmlu.score.toFixed(1) : "—"}</td>
                <td class="px-3 py-2 text-right font-mono text-xs tabular-nums">{verified(m.slug, "bench.gpqa_diamond") && bm.gpqa_diamond ? bm.gpqa_diamond.score.toFixed(1) : "—"}</td>
                <td class="px-3 py-2 text-right font-mono text-xs tabular-nums">{verified(m.slug, "bench.humaneval") && bm.humaneval ? bm.humaneval.score.toFixed(1) : "—"}</td>
                <td class="px-3 py-2 font-mono text-[10px] text-[var(--color-text-muted)] leading-tight align-middle" style="max-width:9rem">
                  {m.openness === "proprietary"
                    ? (<span class="text-[var(--color-text-subtle)]" data-popover="Closed weights: no public quantizations.">—</span>)
                    : fams.length
                      ? (<span data-popover="Quantization families with published weights (verified via the Hugging Face model tree).">{fams.join(" ")}</span>)
                      : (<span class="text-[var(--color-text-subtle)]">—</span>)}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <p class="font-mono text-[10px] text-[var(--color-text-subtle)] mt-2">
      Cost and speed via <a href="https://artificialanalysis.ai/models" target="_blank" rel="noopener" class="hover:text-[var(--color-text)] no-underline hover:underline">Artificial Analysis ↗</a>;
      benchmark scores from each model's primary source (model card or paper). Click any row name for the full record.
    </p>
  </section>
</BaseLayout>

<style>
  .openness-open { background: var(--color-surface-warm); color: var(--color-focus-open); border: 1px solid var(--color-focus-open); }
  .openness-open-weights { background: var(--color-surface-warm); color: var(--color-focus-open-weights); border: 1px solid var(--color-focus-open-weights); }
  .openness-source-available { background: var(--color-surface-warm); color: var(--color-focus-source-available); border: 1px solid var(--color-focus-source-available); }
  .openness-proprietary { background: var(--color-surface-warm); color: var(--color-focus-proprietary); border: 1px solid var(--color-focus-proprietary); }
  .timeline-dot:hover circle { r: 7; cursor: pointer; }
  .scatter-dot:hover circle { r: 8; cursor: pointer; }
  /* Custom summary chevron + remove default disclosure triangle */
  details > summary::-webkit-details-marker { display: none; }
  /* Site-wide popover styles live in global.css; data-popover attrs
     on column headers and openness badges are handled there. */
</style>

<script is:inline>
  (function () {
    const search = document.getElementById("models-search");
    const fOpen = document.getElementById("filter-openness");
    const fArch = document.getElementById("filter-architecture");
    const fDev = document.getElementById("filter-developer");
    const fQuant = document.getElementById("filter-quant");
    const reset = document.getElementById("filter-reset");
    const count = document.getElementById("filter-count");
    const rows = Array.from(document.querySelectorAll(".models-row"));
    const total = rows.length;

    function apply() {
      const q = (search.value || "").toLowerCase().trim();
      const o = fOpen.value;
      const a = fArch.value;
      const d = fDev.value;
      const qz = fQuant.value;
      let visible = 0;
      for (const row of rows) {
        const name = row.dataset.name || "";
        const fam = row.dataset.family || "";
        const dev = (row.dataset.developer || "").toLowerCase();
        const open = row.dataset.openness;
        const arch = row.dataset.architecture;
        const quants = (row.dataset.quants || "").split(" ");
        const matchesQuery = !q || name.includes(q) || fam.includes(q) || dev.includes(q);
        const matchesOpen = !o || open === o;
        const matchesArch = !a || arch === a;
        const matchesDev = !d || row.dataset.developer === d;
        const matchesQuant = !qz || quants.includes(qz);
        const show = matchesQuery && matchesOpen && matchesArch && matchesDev && matchesQuant;
        row.style.display = show ? "" : "none";
        if (show) visible++;
      }
      count.textContent = visible === total ? `${total} models` : `${visible} of ${total} models`;
    }

    for (const el of [search, fOpen, fArch, fDev, fQuant]) {
      el.addEventListener("input", apply);
      el.addEventListener("change", apply);
    }
    reset.addEventListener("click", () => {
      search.value = "";
      fOpen.value = "";
      fArch.value = "";
      fDev.value = "";
      fQuant.value = "";
      apply();
    });
  })();

  // Multi-select compare. Up to 4 checkboxes; surfaces a floating
  // "compare N selected →" link that builds /models/compare?slugs=...
  (function () {
    const MAX = 4;
    const cbs = Array.from(document.querySelectorAll(".cmp-cb"));
    const cta = document.getElementById("multi-compare-cta");
    const link = document.getElementById("multi-compare-link");
    const counter = document.getElementById("multi-compare-count");

    function update() {
      const selected = cbs.filter((c) => c.checked).map((c) => c.dataset.slug);
      // Cap selection at MAX: if the user checks a 5th, refuse it.
      if (selected.length > MAX) {
        cbs.find((c) => c.checked && !selected.slice(0, MAX).includes(c.dataset.slug)).checked = false;
        return update();
      }
      if (selected.length >= 2) {
        cta.classList.remove("hidden");
        counter.textContent = `${selected.length} selected · max ${MAX}`;
        link.href = `/models/compare?slugs=${selected.join(",")}`;
      } else {
        cta.classList.add("hidden");
      }
      // Disable empty checkboxes once max is reached.
      for (const c of cbs) {
        if (!c.checked) c.disabled = selected.length >= MAX;
      }
    }
    for (const c of cbs) c.addEventListener("change", update);
  })();

  // Configurable scatter plot. Reads the JSON payload embedded by the
  // server, then re-renders the SVG body whenever the user picks new
  // axes. Auto log-scale for metrics flagged `log` (cost + scale
  // groups). Models missing either picked metric drop off the chart.
  // Pan via drag, zoom via wheel, box-zoom via shift+drag, reset via
  // the "reset view" button. Rich hover tooltip via custom DOM element.
  (function () {
    const svg = document.getElementById("scatter-svg");
    const xSel = document.getElementById("scatter-x");
    const ySel = document.getElementById("scatter-y");
    const swap = document.getElementById("scatter-swap");
    const count = document.getElementById("scatter-count");
    const reset = document.getElementById("scatter-reset");
    const tooltip = document.getElementById("scatter-tooltip");
    const frame = document.getElementById("scatter-frame");
    const hiddenList = document.getElementById("scatter-hidden");
    const payloadEl = document.getElementById("scatter-data");
    if (!svg || !xSel || !ySel || !payloadEl) return;
    const data = JSON.parse(payloadEl.textContent || "{}");
    const rows = data.rows || [];
    const metrics = data.metrics || [];
    const metricByKey = Object.fromEntries(metrics.map((m) => [m.key, m]));
    const W = 720, H = 320, PAD = 56;
    const PLOT_W = W - PAD * 2;
    const PLOT_H = H - PAD * 2;

    // Viewport. When null, auto-fit to the data extent. Set by zoom /
    // pan interactions; reset button clears it.
    let viewport = null;
    let lastFitExtent = null;  // remembered for the wheel-zoom anchor

    // Each point carries its family color in the JSON payload; we read
    // it directly. The openness tier still distinguishes filled vs
    // ring on the dot, so cost/quality readers can still tell open
    // from closed at a glance.
    function fmtTick(meta, v) {
      if (meta.log) {
        if (meta.group === "cost") return "$" + v.toFixed(v < 1 ? 2 : 0);
        if (meta.key === "context_window") return v >= 1e6 ? (v / 1e6).toFixed(1) + "M" : (v / 1000).toFixed(0) + "K";
        if (meta.key.includes("params")) return v >= 1e12 ? (v / 1e12).toFixed(0) + "T" : v >= 1e9 ? (v / 1e9).toFixed(0) + "B" : (v / 1e6).toFixed(0) + "M";
        if (meta.key === "pretraining_tokens") return v >= 1e12 ? (v / 1e12).toFixed(0) + "T" : (v / 1e9).toFixed(0) + "B";
        return String(v);
      }
      if (meta.key === "released_year") return v.toFixed(0);
      return v.toFixed(0);
    }

    function logTicks(min, max) {
      const ticks = [];
      const lo = Math.floor(Math.log10(min));
      const hi = Math.ceil(Math.log10(max));
      for (let p = lo; p <= hi; p++) {
        for (const m of [1, 3]) {
          const v = m * Math.pow(10, p);
          if (v >= min / 1.2 && v <= max * 1.2) ticks.push(v);
        }
      }
      return ticks.slice(0, 6);
    }
    function linearTicks(min, max) {
      const span = max - min;
      const step = span / 5;
      const niceStep = Math.pow(10, Math.floor(Math.log10(step)));
      const scaled = step / niceStep;
      const nice = scaled < 1.5 ? 1 : scaled < 3 ? 2 : scaled < 7 ? 5 : 10;
      const tickStep = nice * niceStep;
      const ticks = [];
      const start = Math.ceil(min / tickStep) * tickStep;
      for (let v = start; v <= max; v += tickStep) ticks.push(v);
      return ticks;
    }

    // Auto-fit extent for points: simple min/max, no outlier trimming.
    function dataExtent(points, key) {
      const vs = points.map((p) => p.metrics[key]);
      let lo = Math.min(...vs), hi = Math.max(...vs);
      if (lo === hi) { lo -= 1; hi += 1; }
      return [lo, hi];
    }

    // Active extent: viewport (if zoomed/panned) or auto-fit.
    function activeExtent(points, key, dim) {
      if (viewport) return viewport[dim];
      return dataExtent(points, key);
    }

    // Inverse helpers: pixel -> data value, accounting for log scale.
    function pxToData(meta, px, [lo, hi], extentMin, extentMax) {
      const log = meta.log && extentMin > 0;
      const dLo = log ? Math.log10(extentMin) : extentMin;
      const dHi = log ? Math.log10(extentMax) : extentMax;
      const frac = (px - lo) / (hi - lo);
      const d = dLo + frac * (dHi - dLo);
      return log ? Math.pow(10, d) : d;
    }

    function render() {
      const xKey = xSel.value;
      const yKey = ySel.value;
      const xMeta = metricByKey[xKey];
      const yMeta = metricByKey[yKey];
      if (!xMeta || !yMeta) return;

      // Filter to rows that have both picked metrics.
      const points = rows.filter((r) => r.metrics[xKey] != null && r.metrics[yKey] != null);
      const hidden = rows.filter((r) => r.metrics[xKey] == null || r.metrics[yKey] == null);
      count.textContent = `${points.length} of ${rows.length} models plotted`;

      // Hidden-models list (the <details> drawer below the chart).
      if (hiddenList) {
        if (hidden.length === 0) {
          hiddenList.textContent = "No hidden models.";
        } else {
          const xLabel = xMeta.short_label, yLabel = yMeta.short_label;
          const items = hidden.map((p) => {
            const missX = p.metrics[xKey] == null;
            const missY = p.metrics[yKey] == null;
            const reason = missX && missY ? `${xLabel} and ${yLabel}` : missX ? xLabel : yLabel;
            return `<li><a href="/models/${p.slug}" class="hover:text-[var(--color-text)] no-underline hover:underline">${p.display_name}</a> <span class="text-[var(--color-text-subtle)]">(${reason} not verified)</span></li>`;
          }).sort();
          hiddenList.innerHTML = `<p class="mb-1">${hidden.length} models are hidden because at least one of the selected metrics has no verified value. They reappear when you pick metrics they do have.</p><ul class="list-disc list-inside space-y-0.5 max-h-48 overflow-y-auto">${items.join("")}</ul>`;
        }
      }

      // Auto-fit extents from the unfiltered point set (so the dataset
      // extent is stable across pan/zoom; viewport overrides if set).
      const [autoXmin, autoXmax] = dataExtent(points, xKey);
      const [autoYmin, autoYmax] = dataExtent(points, yKey);
      lastFitExtent = { x: [autoXmin, autoXmax], y: [autoYmin, autoYmax] };
      const [xMin, xMax] = viewport ? viewport.x : [autoXmin, autoXmax];
      const [yMin, yMax] = viewport ? viewport.y : [autoYmin, autoYmax];

      const xLog = xMeta.log && xMin > 0;
      const yLog = yMeta.log && yMin > 0;
      const xLo = xLog ? Math.log10(xMin) : xMin;
      const xHi = xLog ? Math.log10(xMax) : xMax;
      const yLo = yLog ? Math.log10(yMin) : yMin;
      const yHi = yLog ? Math.log10(yMax) : yMax;
      const xToPx = (v) => PAD + ((xLog ? Math.log10(v) : v) - xLo) / (xHi - xLo) * PLOT_W;
      const yToPx = (v) => H - PAD - ((yLog ? Math.log10(v) : v) - yLo) / (yHi - yLo) * PLOT_H;

      const xTicks = xLog ? logTicks(xMin, xMax) : linearTicks(xMin, xMax);
      const yTicks = yLog ? logTicks(yMin, yMax) : linearTicks(yMin, yMax);

      // Build SVG content.
      let html = "";
      // Clip path so dots get clipped when panned/zoomed outside.
      html += `<defs><clipPath id="scatter-clip"><rect x="${PAD}" y="${PAD}" width="${PLOT_W}" height="${PLOT_H}"/></clipPath></defs>`;
      // Axes.
      html += `<line x1="${PAD}" y1="${H - PAD}" x2="${W - PAD}" y2="${H - PAD}" stroke="var(--color-border-strong)" stroke-width="1"/>`;
      html += `<line x1="${PAD}" y1="${PAD}" x2="${PAD}" y2="${H - PAD}" stroke="var(--color-border-strong)" stroke-width="1"/>`;
      // Grid + ticks.
      for (const t of xTicks) {
        const x = xToPx(t);
        if (x < PAD - 0.5 || x > W - PAD + 0.5) continue;
        html += `<line x1="${x}" y1="${PAD}" x2="${x}" y2="${H - PAD}" stroke="var(--color-border)" stroke-dasharray="2 4"/>`;
        html += `<text x="${x}" y="${H - PAD + 14}" text-anchor="middle" font-size="10" fill="var(--color-text-subtle)">${fmtTick(xMeta, t)}</text>`;
      }
      for (const t of yTicks) {
        const y = yToPx(t);
        if (y < PAD - 0.5 || y > H - PAD + 0.5) continue;
        html += `<line x1="${PAD}" y1="${y}" x2="${W - PAD}" y2="${y}" stroke="var(--color-border)" stroke-dasharray="2 4"/>`;
        html += `<text x="${PAD - 6}" y="${y + 3}" text-anchor="end" font-size="10" fill="var(--color-text-subtle)">${fmtTick(yMeta, t)}</text>`;
      }
      // Axis labels.
      html += `<text x="${W / 2}" y="${H - 12}" text-anchor="middle" font-size="11" fill="var(--color-text-muted)">${xMeta.label}${xLog ? " (log)" : ""}</text>`;
      html += `<text x="${PAD - 36}" y="${H / 2}" text-anchor="middle" font-size="11" fill="var(--color-text-muted)" transform="rotate(-90, ${PAD - 36}, ${H / 2})">${yMeta.label}${yLog ? " (log)" : ""}</text>`;

      // Points. Color by family; ring (no fill) for proprietary so the
      // closed-vs-open distinction is still visible even with the
      // family palette taking the primary color slot. data-* attrs
      // carry the info the tooltip needs.
      html += `<g clip-path="url(#scatter-clip)">`;
      for (const p of points) {
        const cx = xToPx(p.metrics[xKey]);
        const cy = yToPx(p.metrics[yKey]);
        const isClosed = p.openness === "proprietary";
        const c = p.family_color || "#737373";
        const xVal = fmtTick(xMeta, p.metrics[xKey]).replace(/"/g, "&quot;");
        const yVal = fmtTick(yMeta, p.metrics[yKey]).replace(/"/g, "&quot;");
        const name = p.display_name.replace(/"/g, "&quot;");
        html += `<a href="/models/${p.slug}" class="scatter-dot" data-family="${p.family}" data-slug="${p.slug}" data-name="${name}" data-fam-label="${p.family}" data-openness="${p.openness}" data-x-label="${xMeta.short_label}" data-x-val="${xVal}" data-y-label="${yMeta.short_label}" data-y-val="${yVal}"><circle cx="${cx}" cy="${cy}" r="5" fill="${isClosed ? "transparent" : c}" stroke="${c}" stroke-width="1.5"/></a>`;
      }
      html += `</g>`;

      // Box-zoom selection rect (rendered by drag handlers).
      html += `<rect id="scatter-box" x="0" y="0" width="0" height="0" fill="rgba(0,0,0,0.06)" stroke="var(--color-text-muted)" stroke-dasharray="3 3" pointer-events="none" style="display:none;"/>`;

      svg.innerHTML = html;
    }

    xSel.addEventListener("change", () => { viewport = null; render(); });
    ySel.addEventListener("change", () => { viewport = null; render(); });
    swap.addEventListener("click", () => {
      const x = xSel.value, y = ySel.value;
      xSel.value = y;
      ySel.value = x;
      viewport = null;
      render();
    });
    if (reset) {
      reset.addEventListener("click", () => { viewport = null; render(); });
    }

    // Hover tooltip. Uses event delegation so dynamically-rendered
    // dots all hook in. Tooltip is positioned relative to the
    // scatter-frame container.
    function showTooltip(target, clientX, clientY) {
      if (!tooltip || !frame) return;
      const ds = target.dataset;
      const isClosed = ds.openness === "proprietary";
      const opennessLabel = {
        open: "Open",
        "open-weights": "Open-weights",
        "source-available": "Source-available",
        proprietary: "Proprietary",
      }[ds.openness] || ds.openness;
      tooltip.innerHTML = `
        <p class="font-serif text-sm text-[var(--color-text)] mb-1">${ds.name}</p>
        <p class="font-mono text-[10px] text-[var(--color-text-subtle)] mb-2">
          ${ds.famLabel} family · ${opennessLabel}
        </p>
        <p class="font-mono text-xs text-[var(--color-text-muted)] mb-0.5">
          <span class="text-[var(--color-text-subtle)]">${ds.xLabel}:</span> <span class="text-[var(--color-text)] tabular-nums">${ds.xVal}</span>
        </p>
        <p class="font-mono text-xs text-[var(--color-text-muted)] mb-2">
          <span class="text-[var(--color-text-subtle)]">${ds.yLabel}:</span> <span class="text-[var(--color-text)] tabular-nums">${ds.yVal}</span>
        </p>
        <p class="font-mono text-[10px] text-[var(--color-text-subtle)]">Click for full page →</p>
      `;
      tooltip.classList.remove("hidden");
      // Position: prefer right of cursor, flip left if it would clip
      const frameRect = frame.getBoundingClientRect();
      const tipRect = tooltip.getBoundingClientRect();
      const margin = 8;
      let left = clientX - frameRect.left + 12;
      let top = clientY - frameRect.top + 12;
      if (left + tipRect.width > frameRect.width - margin) {
        left = clientX - frameRect.left - tipRect.width - 12;
      }
      if (top + tipRect.height > frameRect.height - margin) {
        top = clientY - frameRect.top - tipRect.height - 12;
      }
      tooltip.style.left = `${Math.max(margin, left)}px`;
      tooltip.style.top = `${Math.max(margin, top)}px`;
    }
    function hideTooltip() {
      if (tooltip) tooltip.classList.add("hidden");
    }

    svg.addEventListener("mousemove", (e) => {
      const target = e.target.closest(".scatter-dot");
      if (target) {
        showTooltip(target, e.clientX, e.clientY);
      } else {
        hideTooltip();
      }
    });
    svg.addEventListener("mouseleave", hideTooltip);

    // Pan + zoom. svgPoint(e) converts a mouse event into chart-area
    // coordinates (PAD..PAD+PLOT_W).
    function svgPoint(e) {
      const rect = svg.getBoundingClientRect();
      const scale = W / rect.width;
      return {
        x: (e.clientX - rect.left) * scale,
        y: (e.clientY - rect.top) * scale,
      };
    }
    function currentExtent() {
      // Read the current x/y range from active state. Returns log-aware bounds.
      const xKey = xSel.value, yKey = ySel.value;
      const xMeta = metricByKey[xKey], yMeta = metricByKey[yKey];
      const xs = rows.filter((r) => r.metrics[xKey] != null && r.metrics[yKey] != null).map((r) => r.metrics[xKey]);
      const ys = rows.filter((r) => r.metrics[xKey] != null && r.metrics[yKey] != null).map((r) => r.metrics[yKey]);
      const ax = viewport ? viewport.x : [Math.min(...xs), Math.max(...xs)];
      const ay = viewport ? viewport.y : [Math.min(...ys), Math.max(...ys)];
      return { xMeta, yMeta, ax, ay };
    }
    function pxToValue(meta, px, lo, hi, pxLo, pxHi) {
      const log = meta.log && lo > 0;
      const dLo = log ? Math.log10(lo) : lo;
      const dHi = log ? Math.log10(hi) : hi;
      const frac = (px - pxLo) / (pxHi - pxLo);
      const d = dLo + frac * (dHi - dLo);
      return log ? Math.pow(10, d) : d;
    }

    // Drag: pan (no modifier) or box-zoom (shift). Mousedown captures
    // start; mousemove updates either viewport or selection box;
    // mouseup commits.
    let drag = null;
    svg.addEventListener("mousedown", (e) => {
      if (e.button !== 0) return;
      // Don't start drag on a dot — let click navigate
      if (e.target.closest(".scatter-dot")) return;
      const pt = svgPoint(e);
      if (pt.x < PAD || pt.x > W - PAD || pt.y < PAD || pt.y > H - PAD) return;
      drag = {
        startPt: pt,
        lastPt: pt,
        mode: e.shiftKey ? "box" : "pan",
        startExtent: currentExtent(),
      };
      svg.style.cursor = e.shiftKey ? "crosshair" : "grabbing";
      hideTooltip();
      e.preventDefault();
    });
    window.addEventListener("mousemove", (e) => {
      if (!drag) return;
      const pt = svgPoint(e);
      if (drag.mode === "pan") {
        // Translate viewport by the difference between last and current pt.
        const { xMeta, yMeta, ax, ay } = drag.startExtent;
        const dx = drag.startPt.x - pt.x;
        const dy = pt.y - drag.startPt.y;
        // Convert pixel-deltas into data-deltas (in data space, log-aware).
        const xLog = xMeta.log && ax[0] > 0;
        const yLog = yMeta.log && ay[0] > 0;
        const dataDx = (xLog ? (Math.log10(ax[1]) - Math.log10(ax[0])) : (ax[1] - ax[0])) * (dx / PLOT_W);
        const dataDy = (yLog ? (Math.log10(ay[1]) - Math.log10(ay[0])) : (ay[1] - ay[0])) * (dy / PLOT_H);
        const newXLo = xLog ? Math.pow(10, Math.log10(ax[0]) + dataDx) : ax[0] + dataDx;
        const newXHi = xLog ? Math.pow(10, Math.log10(ax[1]) + dataDx) : ax[1] + dataDx;
        const newYLo = yLog ? Math.pow(10, Math.log10(ay[0]) + dataDy) : ay[0] + dataDy;
        const newYHi = yLog ? Math.pow(10, Math.log10(ay[1]) + dataDy) : ay[1] + dataDy;
        viewport = { x: [newXLo, newXHi], y: [newYLo, newYHi] };
        render();
      } else if (drag.mode === "box") {
        // Update the dashed selection box.
        const box = svg.querySelector("#scatter-box");
        if (box) {
          const x = Math.min(drag.startPt.x, pt.x);
          const y = Math.min(drag.startPt.y, pt.y);
          const w = Math.abs(pt.x - drag.startPt.x);
          const h = Math.abs(pt.y - drag.startPt.y);
          box.setAttribute("x", x);
          box.setAttribute("y", y);
          box.setAttribute("width", w);
          box.setAttribute("height", h);
          box.style.display = "block";
        }
      }
      drag.lastPt = pt;
    });
    window.addEventListener("mouseup", (e) => {
      if (!drag) return;
      if (drag.mode === "box") {
        // Commit box-zoom: convert pixel rect to data-space viewport.
        const pt = svgPoint(e);
        const x0 = Math.min(drag.startPt.x, pt.x);
        const x1 = Math.max(drag.startPt.x, pt.x);
        const y0 = Math.min(drag.startPt.y, pt.y);
        const y1 = Math.max(drag.startPt.y, pt.y);
        const { xMeta, yMeta, ax, ay } = drag.startExtent;
        if (x1 - x0 > 6 && y1 - y0 > 6) {
          const newXLo = pxToValue(xMeta, x0, ax[0], ax[1], PAD, W - PAD);
          const newXHi = pxToValue(xMeta, x1, ax[0], ax[1], PAD, W - PAD);
          // Y is inverted in pixels — top of box = higher y value.
          const newYHi = pxToValue(yMeta, y0, ay[0], ay[1], H - PAD, PAD);
          const newYLo = pxToValue(yMeta, y1, ay[0], ay[1], H - PAD, PAD);
          viewport = { x: [newXLo, newXHi], y: [newYLo, newYHi] };
          render();
        } else {
          // Tiny drag = treated as click; re-render to clear the box.
          render();
        }
      }
      svg.style.cursor = "grab";
      drag = null;
    });

    // Wheel = zoom centered on cursor. Positive deltaY = zoom out.
    svg.addEventListener("wheel", (e) => {
      const pt = svgPoint(e);
      if (pt.x < PAD || pt.x > W - PAD || pt.y < PAD || pt.y > H - PAD) return;
      e.preventDefault();
      const { xMeta, yMeta, ax, ay } = currentExtent();
      const zoom = e.deltaY > 0 ? 1.25 : 0.8;
      // Cursor in data space:
      const xCursor = pxToValue(xMeta, pt.x, ax[0], ax[1], PAD, W - PAD);
      const yCursor = pxToValue(yMeta, pt.y, ay[0], ay[1], H - PAD, PAD);
      function rescale(meta, cursor, [lo, hi]) {
        const log = meta.log && lo > 0;
        const dCursor = log ? Math.log10(cursor) : cursor;
        const dLo = log ? Math.log10(lo) : lo;
        const dHi = log ? Math.log10(hi) : hi;
        const newLo = dCursor - (dCursor - dLo) * zoom;
        const newHi = dCursor + (dHi - dCursor) * zoom;
        return [log ? Math.pow(10, newLo) : newLo, log ? Math.pow(10, newHi) : newHi];
      }
      viewport = {
        x: rescale(xMeta, xCursor, ax),
        y: rescale(yMeta, yCursor, ay),
      };
      render();
    }, { passive: false });

    render();
  })();

  // Sortable column headers. Click a header to toggle asc/desc on
  // that column. Chevron beside the column name shows direction.
  // Numeric columns sort numerically (empty values land at the end
  // regardless of direction).
  (function () {
    const table = document.getElementById("models-table");
    if (!table) return;
    const tbody = table.querySelector("tbody");
    const headers = Array.from(table.querySelectorAll("thead th.sortable"));
    let current = { key: "released", dir: "desc" };

    function getVal(row, key) {
      // data-sort-name -> dataset.sortName, etc. The key matches the
      // suffix used in the data-sort attribute on each row.
      return row.dataset[`sort${key.charAt(0).toUpperCase()}${key.slice(1)}`];
    }

    function applySort(key) {
      const header = headers.find((h) => h.dataset.sort === key);
      if (!header) return;
      const isNumeric = header.dataset.sortType === "numeric";
      const dir = current.key === key && current.dir === "asc" ? "desc" : "asc";
      current = { key, dir };
      const rows = Array.from(tbody.querySelectorAll(".models-row"));
      rows.sort((a, b) => {
        const av = getVal(a, key);
        const bv = getVal(b, key);
        if (isNumeric) {
          const an = av === "" || av == null ? null : parseFloat(av);
          const bn = bv === "" || bv == null ? null : parseFloat(bv);
          if (an === null && bn === null) return 0;
          if (an === null) return 1;
          if (bn === null) return -1;
          return dir === "asc" ? an - bn : bn - an;
        }
        const cmp = (av || "").localeCompare(bv || "");
        return dir === "asc" ? cmp : -cmp;
      });
      // Reattach in new order.
      for (const r of rows) tbody.appendChild(r);
      // Update chevrons.
      for (const h of headers) {
        const chev = h.querySelector(".sort-chev");
        if (!chev) continue;
        if (h.dataset.sort === key) chev.textContent = dir === "asc" ? "▲" : "▼";
        else chev.textContent = "";
      }
    }

    for (const h of headers) {
      h.style.cursor = "pointer";
      h.addEventListener("click", (e) => {
        // Ignore clicks on the popover icon or on links inside the header.
        if (e.target instanceof Element && e.target.tagName === "A") return;
        applySort(h.dataset.sort);
      });
    }
  })();

  // Family-legend hover dimming. Hovering a legend chip fades dots in
  // both visualizations that don't belong to the picked family. Use
  // both timeline-dot (group) and scatter-dot (anchor) selectors so
  // the styling applies in both charts.
  (function () {
    const legend = document.getElementById("family-legend");
    if (!legend) return;
    const chips = Array.from(legend.querySelectorAll(".family-legend-chip"));

    function setHighlight(family) {
      const timelineDots = document.querySelectorAll(".timeline-dot");
      const scatterDots = document.querySelectorAll(".scatter-dot");
      const mappedFamilies = new Set(Object.keys(
        // The family color list is in lib/models.ts; we just check via
        // the dot's actual data-family — anything matching the chip's
        // data-family-highlight is "in"; for the "__other__" chip we
        // pass null and dim everything that DOES have a known family.
        {}
      ));
      const apply = (el) => {
        if (!family) {
          el.classList.remove("viz-dimmed");
          return;
        }
        const elFamily = el.dataset.family || el.getAttribute("data-family") || "";
        if (family === "__other__") {
          // Other = families not in the legend (no swatch).
          const inLegend = chips.find(
            (c) => c.dataset.familyHighlight === elFamily && elFamily !== "__other__"
          );
          if (inLegend) el.classList.add("viz-dimmed");
          else el.classList.remove("viz-dimmed");
        } else {
          if (elFamily === family) el.classList.remove("viz-dimmed");
          else el.classList.add("viz-dimmed");
        }
      };
      for (const d of timelineDots) apply(d);
      for (const d of scatterDots) apply(d);
    }

    for (const chip of chips) {
      chip.addEventListener("mouseenter", () => setHighlight(chip.dataset.familyHighlight));
      chip.addEventListener("mouseleave", () => setHighlight(null));
      chip.addEventListener("focus", () => setHighlight(chip.dataset.familyHighlight));
      chip.addEventListener("blur", () => setHighlight(null));
    }
  })();

  // Rich timeline tooltip. On hover over a dot, position a small panel
  // near the cursor showing the headline fields.
  (function () {
    const container = document.getElementById("timeline-container");
    const tip = document.getElementById("timeline-tooltip");
    if (!container || !tip) return;
    const dots = Array.from(document.querySelectorAll(".timeline-dot"));

    function show(g, evt) {
      const d = g.dataset;
      const rect = container.getBoundingClientRect();
      const x = evt.clientX - rect.left;
      const y = evt.clientY - rect.top;
      tip.style.left = `${Math.min(x + 12, rect.width - 320)}px`;
      tip.style.top = `${Math.max(8, y - 110)}px`;
      const gpqaLine = d.gpqa ? `GPQA-D ${d.gpqa}` : "";
      const mmluLine = d.mmluPro ? `MMLU-Pro ${d.mmluPro}` : "";
      const benches = [gpqaLine, mmluLine].filter(Boolean).join(" · ");
      const costLine = d.costIn && d.costOut ? `$${d.costIn} / $${d.costOut} per Mtok` : "no public price";
      tip.innerHTML = `
        <div style="font-family: var(--font-sans); font-weight: 600; color: var(--color-text); margin-bottom: 2px;">${d.name}</div>
        <div style="font-family: var(--font-mono); font-size: 10px; color: var(--color-text-subtle); margin-bottom: 6px;">${d.dev} · ${d.date} · ${d.license}</div>
        <div style="font-family: var(--font-mono); font-size: 10px; color: var(--color-text-muted); line-height: 1.6;">
          <div>${d.arch} · ${d.paramsTotal} total / ${d.paramsActive} active · ${d.context} ctx</div>
          ${benches ? `<div>${benches}</div>` : ""}
          <div>${costLine}</div>
        </div>
      `;
      tip.classList.remove("hidden");
    }
    function hide() { tip.classList.add("hidden"); }
    for (const g of dots) {
      g.addEventListener("mouseenter", (e) => show(g, e));
      g.addEventListener("mousemove", (e) => show(g, e));
      g.addEventListener("mouseleave", hide);
    }
  })();
</script>
