---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  loadModels,
  loadModelBySlug,
  BENCHMARK_GROUPS,
  BENCHMARK_LABEL,
  OPENNESS_LABEL,
  formatParams,
  formatTokens,
  formatContext,
  type Model,
  type BenchmarkSlug,
} from "../../lib/models";

const params = Astro.url.searchParams;
const all = loadModels();

// Accept either ?slugs=a,b,c,d (new, up to 4) OR ?a=&b= (legacy
// pairwise, still works for back-compat). Cap at 4.
let slugs: string[] = [];
const slugsParam = params.get("slugs");
if (slugsParam) {
  slugs = slugsParam.split(",").map((s) => s.trim()).filter(Boolean).slice(0, 4);
} else {
  const a = params.get("a");
  const b = params.get("b");
  if (a) slugs.push(a);
  if (b) slugs.push(b);
}

const models = slugs
  .map((s) => loadModelBySlug(s))
  .filter((m): m is Model => !!m);

const benchmarkGroupOrder = ["general", "code", "math", "arena"] as const;
const benchmarkGroupLabel: Record<typeof benchmarkGroupOrder[number], string> = {
  general: "General reasoning",
  code: "Code",
  math: "Math",
  arena: "Held-out / arena",
};

function fmtBool(v: boolean | undefined): string {
  if (v === undefined) return "—";
  return v ? "yes" : "no";
}

interface CompareRow {
  label: string;
  values: string[];
  differs: boolean;
}

const rows: CompareRow[] = [];

if (models.length >= 2) {
  function add(label: string, vals: string[]) {
    const differs = vals.some((v, i) => i > 0 && v !== vals[0]);
    rows.push({ label, values: vals, differs });
  }
  add("Released", models.map((m) => m.released_date));
  add("Developer", models.map((m) => m.developer));
  add("Openness", models.map((m) => OPENNESS_LABEL[m.openness]));
  add("License", models.map((m) => m.license));
  add("OSI-approved", models.map((m) => fmtBool(m.osi_approved)));
  add("Data released", models.map((m) => fmtBool(m.data_released)));
  add("Training code", models.map((m) => fmtBool(m.training_code_released)));
  add("Architecture", models.map((m) => m.architecture));
  add("Total params", models.map((m) => m.params_total > 0 ? formatParams(m.params_total) : "—"));
  add("Active params", models.map((m) => m.params_active > 0 ? formatParams(m.params_active) : "—"));
  add("Experts", models.map((m) => m.experts ? `${m.experts} (${m.experts_active ?? "?"} active)` : "—"));
  add("Context window", models.map((m) => formatContext(m.context_window)));
  add("Attention", models.map((m) => m.attention_variant));
  add("Position enc.", models.map((m) => m.position_encoding));
  add("Pretraining tokens", models.map((m) => formatTokens(m.pretraining_tokens)));
  add("Post-training", models.map((m) => (m.post_training ?? []).join(", ") || "—"));
  add("Training hardware", models.map((m) => m.training_hardware ?? "—"));
  add("$/M input", models.map((m) => m.cost?.input_per_mtok_usd !== undefined ? `$${m.cost.input_per_mtok_usd.toFixed(2)}` : "—"));
  add("$/M output", models.map((m) => m.cost?.output_per_mtok_usd !== undefined ? `$${m.cost.output_per_mtok_usd.toFixed(2)}` : "—"));
  add("Output tok/sec", models.map((m) => m.speed?.tokens_per_sec_output !== undefined ? String(m.speed.tokens_per_sec_output) : "—"));
}
---

<BaseLayout
  title={models.length >= 2 ? `${models.map(m=>m.display_name).join(" vs ")} · Models` : "Compare models"}
  description="Side-by-side model comparison."
>
  <section class="max-w-5xl mx-auto px-6 pt-12 pb-4">
    <a href="/models" class="inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] hover:text-[var(--color-text)] no-underline mb-4 transition-colors">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 12H5"/>
        <path d="M12 19l-7-7 7-7"/>
      </svg>
      All models
    </a>
    <p class="font-mono text-xs uppercase tracking-wider mb-2">
      <a href="/models" class="no-underline hover:underline text-[var(--color-text-subtle)]">Models</a>
      <span class="text-[var(--color-text-subtle)]">·</span>
      <span class="text-[var(--color-text-subtle)]">Compare</span>
    </p>

    {models.length < 2 ? (
      <div>
        <h1 class="font-serif text-3xl text-[var(--color-text)] mb-4">Pick 2 to 4 models</h1>
        <p class="text-base text-[var(--color-text-muted)] leading-relaxed mb-6 max-w-prose">
          Use the checkbox column on <a href="/models" class="text-[var(--color-text)] no-underline hover:underline">/models</a> to select up to 4 checkpoints
          and click the "compare selected" button. Or pass <code class="font-mono text-sm">?slugs=a,b,c,d</code> directly.
        </p>
        <form method="GET" class="flex flex-wrap items-center gap-3">
          <select name="a" class="px-2 py-1 border border-[var(--color-border)] rounded bg-[var(--color-surface)] text-sm">
            {all.map((m) => (<option value={m.slug}>{m.display_name}</option>))}
          </select>
          <select name="b" class="px-2 py-1 border border-[var(--color-border)] rounded bg-[var(--color-surface)] text-sm">
            {all.map((m) => (<option value={m.slug}>{m.display_name}</option>))}
          </select>
          <button type="submit" class="px-3 py-1.5 rounded-md bg-[var(--color-accent-strong)] text-white text-sm cursor-pointer">Compare</button>
        </form>
      </div>
    ) : (
      <div>
        <h1 class="font-serif text-3xl md:text-4xl text-[var(--color-text)] mb-4 leading-tight">
          {models.map(m => m.display_name).join("  vs  ")}
        </h1>
        <p class="text-sm text-[var(--color-text-subtle)] mb-2 max-w-prose">
          Rows highlighted in warm gray are where the models differ. Numbers carry their
          as-of date and primary source.
        </p>
      </div>
    )}
  </section>

  {models.length >= 2 && (
    <div class="max-w-5xl mx-auto px-6 pb-16">
      <section class="mb-8">
        <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2">
          Specs
        </h2>
        <div class="border border-[var(--color-border)] rounded-md bg-[var(--color-surface)] overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="border-b border-[var(--color-border)] bg-[var(--color-surface-warm)]">
              <tr class="text-left font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-subtle)]">
                <th class="px-3 py-2 w-32">Field</th>
                {models.map((m, i) => (
                  <th class="px-3 py-2">
                    <span class="text-[10px] text-[var(--color-text-subtle)]">{String.fromCharCode(65 + i)}: </span>
                    <a href={`/models/${m.slug}`} class="text-[var(--color-text-muted)] no-underline hover:underline normal-case tracking-normal">{m.display_name}</a>
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {rows.map((r) => (
                <tr class={`border-t border-[var(--color-border)] ${r.differs ? "bg-[var(--color-surface-warm)]" : ""}`}>
                  <td class="px-3 py-1.5 font-mono text-xs text-[var(--color-text-subtle)]">{r.label}</td>
                  {r.values.map((v) => (
                    <td class={`px-3 py-1.5 text-xs ${r.differs ? "font-semibold text-[var(--color-text)]" : "text-[var(--color-text-muted)]"}`}>{v}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-2">
          Benchmarks
        </h2>
        <p class="text-xs text-[var(--color-text-subtle)] mb-3">
          Missing scores render as not reported; never inferred. Bold highlights the leader per benchmark.
        </p>
        {benchmarkGroupOrder.map((g) => {
          const slugs = BENCHMARK_GROUPS[g];
          const reportedAny = slugs.some((s) => models.some((m) => m.benchmarks?.[s as BenchmarkSlug]));
          if (!reportedAny) return null;
          return (
            <div class="mb-4">
              <h3 class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-text-muted)] mb-2">
                {benchmarkGroupLabel[g]}
              </h3>
              <div class="overflow-x-auto">
                <table class="w-full text-sm border border-[var(--color-border)] rounded">
                  <tbody>
                    {slugs.map((bSlug) => {
                      const vals = models.map((m) => m.benchmarks?.[bSlug as BenchmarkSlug]);
                      if (!vals.some(Boolean)) return null;
                      const scores = vals.map((v) => v?.score ?? -Infinity);
                      const max = Math.max(...scores);
                      return (
                        <tr class="border-t border-[var(--color-border)] first:border-t-0">
                          <td class="px-3 py-1.5 font-mono text-xs text-[var(--color-text-muted)] w-40">{BENCHMARK_LABEL[bSlug as BenchmarkSlug]}</td>
                          {vals.map((v) => v ? (
                            <td class={`px-3 py-1.5 text-right ${v.score === max ? "font-semibold text-[var(--color-text)]" : "text-[var(--color-text-muted)]"}`}>
                              <span class="font-mono text-xs tabular-nums">{v.score.toFixed(1)}</span>
                              <span class="block font-mono text-[9px] text-[var(--color-text-subtle)]">{v.as_of}</span>
                            </td>
                          ) : (
                            <td class="px-3 py-1.5 text-right font-mono text-xs text-[var(--color-text-subtle)]">—</td>
                          ))}
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>
          );
        })}
      </section>

      <section class={`mb-8 grid gap-6 ${models.length === 2 ? "md:grid-cols-2" : models.length === 3 ? "md:grid-cols-3" : "md:grid-cols-4"}`}>
        {models.map((m, i) => (
          <div>
            <h3 class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-text-subtle)] mb-2">
              Context · {String.fromCharCode(65 + i)}
            </h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{m.release_context ?? "—"}</p>
          </div>
        ))}
      </section>

      <p class="font-mono text-xs text-[var(--color-text-subtle)] mt-6">
        {models.map((m, i) => (
          <>
            <a href={`/models/${m.slug}`} class="hover:text-[var(--color-text)] no-underline hover:underline">{m.display_name} detail →</a>
            {i < models.length - 1 ? <span class="mx-2">·</span> : null}
          </>
        ))}
      </p>
    </div>
  )}
</BaseLayout>

<style>
  .compare-diff { background: var(--color-surface-warm); }
</style>
