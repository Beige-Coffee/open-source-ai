---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadLayers } from "../lib/layers";

const layers = loadLayers();
---

<BaseLayout
  title="Learn"
  description="Per-layer reading lists for going deeper at each part of the open-source AI stack."
>
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-12">
    <p
      class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4"
    >
      Learn
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-6"
    >
      How to read the stack
    </h1>
    <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
      Per-layer reading lists for going deeper at each layer. Curated
      papers, posts, podcasts, and talks. A daily concept hook (rotates
      through one layer per day) appears here once Week 4 of the build
      lands.
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-6">
    <h2 class="font-serif text-2xl mb-6">Start with a layer</h2>
    <div class="grid gap-4 md:grid-cols-2">
      {
        [...layers.core, ...layers.meta].map((layer) => (
          <a
            href={`/stack/${layer.slug}`}
            class="block border border-[var(--color-border)] rounded-md p-4 hover:border-[var(--color-accent)] no-underline hover:no-underline group transition-colors bg-[var(--color-surface)]"
          >
            <span class="font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)]">
              {layer.title}
            </span>
            <span class="block text-sm text-[var(--color-text-muted)] mt-1">
              {layer.short_description}
            </span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
