---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadLayers } from "../lib/layers";
import { loadReadings } from "../lib/reading-lists";

const layers = loadLayers();
const allLayers = [...layers.core, ...layers.meta];
const readings = loadReadings();

// Count readings per layer for the hub card density.
const countsByLayer: Record<string, number> = {};
for (const r of readings) {
  for (const l of r.layers) {
    countsByLayer[l] = (countsByLayer[l] || 0) + 1;
  }
}

// Daily concept hook: deterministically rotate one layer per day so the
// hook is stable across the day but rotates between days. Pick by day
// of year mod number of layers.
const today = new Date();
const start = new Date(today.getFullYear(), 0, 0);
const diff = today.getTime() - start.getTime();
const oneDay = 1000 * 60 * 60 * 24;
const dayOfYear = Math.floor(diff / oneDay);
const hookLayer = allLayers[dayOfYear % allLayers.length];
const hookReadings = readings
  .filter((r) => r.layers.includes(hookLayer.slug))
  .slice(0, 3);
const todayIso = today.toISOString().slice(0, 10);
---

<BaseLayout
  title="Learn"
  description="Per-layer reading lists for going deeper at each part of the open-source AI stack."
>
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-8">
    <p
      class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4"
    >
      Learn
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-6"
    >
      How to read the stack
    </h1>
    <p
      class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-prose"
    >
      Per-layer reading lists for going deeper at each part of the stack.
      Curated papers, posts, podcasts, talks, and docs. Primary sources
      first, secondary commentary mixed in sparingly. The list is
      hand-curated and revised. The latest revision date and any
      additions are tracked at the bottom of each layer page.
    </p>
  </section>

  <!-- Daily concept hook -->
  <section class="max-w-4xl mx-auto px-6 mb-16">
    <div
      class="border border-[var(--color-accent)] bg-[var(--color-accent-soft)] rounded-md p-6"
    >
      <p
        class="font-mono text-xs uppercase tracking-wider text-[var(--color-accent-strong)] mb-2"
      >
        Daily concept hook &middot; {todayIso}
      </p>
      <h2 class="font-serif text-2xl mb-2 mt-0">
        Today's layer: <a
          href={`/stack/${hookLayer.slug}`}
          class="no-underline hover:underline">{hookLayer.title}</a
        >
      </h2>
      <p class="text-[var(--color-text-muted)] mb-4 leading-relaxed">
        {hookLayer.short_description}
      </p>
      {
        hookReadings.length > 0 && (
          <ul class="space-y-2 mb-4">
            {hookReadings.map((r) => (
              <li class="text-sm">
                <a
                  href={r.url}
                  target="_blank"
                  rel="noopener"
                  class="font-medium no-underline hover:underline"
                >
                  {r.title}
                </a>
                <span class="text-[var(--color-text-subtle)]">
                  {" "}
                  &middot; {r.source}
                </span>
              </li>
            ))}
          </ul>
        )
      }
      <p class="text-xs font-mono">
        <a
          href={`/learn/${hookLayer.slug}`}
          class="no-underline hover:underline">Open the full reading list at this layer &rarr;</a
        >
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 mb-16">
    <h2 class="font-serif text-2xl mb-4">All layer reading lists</h2>
    <div class="grid gap-4 md:grid-cols-2">
      {
        allLayers.map((layer) => (
          <a
            href={`/learn/${layer.slug}`}
            class="block border border-[var(--color-border)] rounded-md p-4 hover:border-[var(--color-accent)] no-underline hover:no-underline group transition-colors bg-[var(--color-surface)]"
          >
            <div class="flex items-baseline justify-between gap-3 mb-1">
              <span class="font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)]">
                {layer.title}
              </span>
              <span class="font-mono text-xs text-[var(--color-text-subtle)] whitespace-nowrap">
                {countsByLayer[layer.slug] || 0} reads
              </span>
            </div>
            <span class="block text-sm text-[var(--color-text-muted)]">
              {layer.short_description}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-6 mb-16">
    <h2 class="font-serif text-2xl mb-4">Other entry points</h2>
    <ul class="space-y-3">
      <li>
        <a href="/stack" class="font-medium no-underline hover:underline"
          >The Stack diagram</a
        >
        <p class="text-sm text-[var(--color-text-muted)]">
          The 9-core + 5-meta-layer taxonomy with one-line descriptions.
          Start here if you do not know the layers yet.
        </p>
      </li>
      <li>
        <a href="/today" class="font-medium no-underline hover:underline"
          >Today's news</a
        >
        <p class="text-sm text-[var(--color-text-muted)]">
          Yesterday's primary-source releases across the open AI stack,
          summarized once a day at 08:00 PT.
        </p>
      </li>
      <li>
        <a
          href="/predictions"
          class="font-medium no-underline hover:underline"
          >Our predictions baseline</a
        >
        <p class="text-sm text-[var(--color-text-muted)]">
          Falsifiable predictions filed for each layer, with horizons and
          resolution criteria. We track our own calls.
        </p>
      </li>
      <li>
        <a href="/grants" class="font-medium no-underline hover:underline"
          >Grants landscape</a
        >
        <p class="text-sm text-[var(--color-text-muted)]">
          Funders, recent grants, and underfunded gaps across the stack.
        </p>
      </li>
    </ul>
  </section>
</BaseLayout>
