---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadLayers } from "../lib/layers";
import { loadPredictions, confidenceLabel } from "../lib/predictions";

const layers = loadLayers();
const allLayers = [...layers.core, ...layers.meta];
const findBySlug = (slug: string) => allLayers.find((l) => l.slug === slug);

const predictions = loadPredictions();

// Group predictions by layer.
const byLayer: Record<string, typeof predictions> = {};
for (const p of predictions) {
  if (!byLayer[p.layer]) byLayer[p.layer] = [];
  byLayer[p.layer].push(p);
}

// Layer order: core first by `order`, then meta by `order`.
const orderedLayerSlugs = [
  ...layers.core.map((l) => l.slug),
  ...layers.meta.map((l) => l.slug),
];

// Aggregate counts.
const totalCount = predictions.length;
const highConfidence = predictions.filter((p) => p.confidence >= 4).length;
const lowConfidence = predictions.filter((p) => p.confidence <= 2).length;
---

<BaseLayout
  title="Predictions"
  description="Falsifiable predictions about the open-source AI stack, filed publicly with horizons and resolution criteria."
>
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-8">
    <p
      class="font-mono text-xs uppercase tracking-wider text-[var(--color-text-subtle)] mb-4"
    >
      Predictions
    </p>
    <h1
      class="font-serif text-4xl md:text-5xl leading-tight tracking-tight text-[var(--color-text)] mb-6"
    >
      We track our own calls
    </h1>
    <p
      class="text-lg text-[var(--color-text-muted)] leading-relaxed max-w-prose mb-4"
    >
      Every prediction below is filed publicly with a horizon and a
      resolution criterion. Confidence is on a 1-5 scale: 1 is vibes, 5
      is market-priced. When a prediction resolves we keep the original
      text and note the outcome in the news log on the resolution date.
    </p>
    <p class="text-sm text-[var(--color-text-subtle)] font-mono">
      {totalCount} filed &middot; {highConfidence} high confidence
      (4-5) &middot; {lowConfidence} low confidence (1-2)
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-6 pb-16">
    {
      orderedLayerSlugs.map((slug) => {
        const layer = findBySlug(slug);
        const layerPreds = byLayer[slug] || [];
        if (!layer || layerPreds.length === 0) return null;
        return (
          <section class="mb-10">
            <h2 class="font-sans text-xl font-semibold mb-1">
              <a
                href={`/stack/${layer.slug}`}
                class="no-underline hover:underline"
              >
                {layer.title}
              </a>
            </h2>
            <p class="text-sm text-[var(--color-text-subtle)] mb-3 font-mono">
              {layerPreds.length} prediction{layerPreds.length === 1 ? "" : "s"}
            </p>
            <ul class="space-y-3">
              {layerPreds.map((p) => (
                <li class="border-l-2 border-[var(--color-accent-soft)] pl-4 py-1">
                  <p class="text-base text-[var(--color-text)] mb-2">
                    {p.claim}
                  </p>
                  <div class="text-xs font-mono text-[var(--color-text-subtle)] space-y-1">
                    <p>
                      Resolves by{" "}
                      <span class="text-[var(--color-text-muted)]">
                        {p.horizon}
                      </span>{" "}
                      &middot; confidence{" "}
                      <span class="text-[var(--color-text-muted)]">
                        {confidenceLabel(p.confidence)} ({p.confidence}/5)
                      </span>
                    </p>
                    <p class="text-[var(--color-text-muted)] leading-snug">
                      Resolves when: {p.resolves_when}
                    </p>
                    <p>Filed {p.filed}</p>
                  </div>
                </li>
              ))}
            </ul>
          </section>
        );
      })
    }
  </section>
</BaseLayout>
