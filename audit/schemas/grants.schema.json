{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-source-ai.tech/audit/schemas/grants.schema.json",
  "title": "Grants (data/grants.yaml)",
  "type": "object",
  "required": ["grants"],
  "properties": {
    "grants": {
      "type": "array",
      "items": { "$ref": "#/$defs/grant" }
    }
  },
  "$defs": {
    "grant": {
      "type": "object",
      "required": ["title", "kind", "funder", "recipient", "date", "amount_label", "layers", "region", "url", "description"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "kind": { "type": "string", "enum": ["project", "program"] },
        "funder": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "recipient": { "type": "string", "minLength": 1 },
        "date": {
          "type": "string",
          "pattern": "^([0-9]{4}(-[0-9]{2})?(-[0-9]{2})?|[0-9]{4}-Q[1-4]|[0-9]{4}-[0-9]{4})$"
        },
        "amount_usd": { "type": ["number", "null"], "minimum": 0 },
        "amount_label": { "type": "string", "minLength": 1 },
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "infrastructure",
              "silicon", "compute", "data", "training", "weights",
              "runtime", "retrieval-memory", "agents", "protocols",
              "evaluation", "governance", "identity-trust",
              "safety-guardrails", "sovereignty-decentralization"
            ]
          }
        },
        "region": {
          "type": "string",
          "enum": ["US", "EU", "UK", "Global", "Asia", "Africa", "LatAm"]
        },
        "url": { "type": "string", "format": "uri", "pattern": "^https?://" },
        "description": { "type": "string", "minLength": 10 },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/source" }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["title", "url"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri", "pattern": "^https?://" }
      }
    }
  }
}
