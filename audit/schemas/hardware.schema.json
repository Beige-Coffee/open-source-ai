{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-source-ai.tech/audit/schemas/hardware.schema.json",
  "title": "Hardware (data/hardware.yaml)",
  "type": "object",
  "required": ["hardware"],
  "properties": {
    "hardware": {
      "type": "array",
      "items": { "$ref": "#/$defs/hardware" }
    }
  },
  "$defs": {
    "hardware": {
      "type": "object",
      "required": [
        "slug", "name", "vendor", "class", "memory_capacity_gb",
        "memory_type", "memory_bandwidth_gbs", "form_factor", "power_w",
        "interconnect", "multi_unit_default", "release_date", "url", "sources"
      ],
      "additionalProperties": false,
      "properties": {
        "slug": { "type": "string", "pattern": "^[a-z0-9-.]+$" },
        "name": { "type": "string", "minLength": 1 },
        "vendor": { "type": "string", "minLength": 1 },
        "class": {
          "type": "string",
          "enum": ["datacenter", "workstation", "apple-unified", "x86-unified", "ai-pc"]
        },
        "memory_capacity_gb": { "type": "number", "exclusiveMinimum": 0 },
        "memory_type": {
          "type": "string",
          "enum": ["hbm3", "hbm3e", "hbm2e", "hbm4", "gddr7", "gddr6x", "gddr6", "lpddr5x", "unified-lpddr5x"]
        },
        "memory_bandwidth_gbs": { "type": "number", "exclusiveMinimum": 0 },
        "compute": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fp16_dense_tflops": { "type": "number" },
            "fp8_dense_tflops": { "type": "number" },
            "fp4_dense_tflops": { "type": "number" },
            "int8_dense_tops": { "type": "number" }
          }
        },
        "form_factor": {
          "type": "string",
          "enum": ["sxm", "oam", "pcie", "soc", "superchip"]
        },
        "power_w": { "type": "number", "exclusiveMinimum": 0 },
        "interconnect": {
          "type": "string",
          "enum": ["nvlink", "nvswitch", "pcie", "infinity-fabric", "none"]
        },
        "multi_unit_default": { "type": "integer", "minimum": 1 },
        "npu_int8_tops": { "type": "number" },
        "release_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}(-[0-9]{2})?$" },
        "url": { "type": "string", "format": "uri", "pattern": "^https?://" },
        "silicon_project": { "type": "string", "pattern": "^[a-z0-9-.]+$" },
        "notes": { "type": "string" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source" }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["title", "url"],
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string", "format": "uri", "pattern": "^https?://" }
      }
    }
  }
}
